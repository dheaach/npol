        "unit": "px",
        "default": 60
      },
      {
        "type": "range",
        "id": "font_size_h2",
        "label": "H2 size",
        "min": 24,
        "max": 56,
        "step": 2,
        "unit": "px",
        "default": 36
      },
      {
        "type": "range",
        "id": "font_size_h3",
        "label": "H3 size",
        "min": 18,
        "max": 36,
        "step": 1,
        "unit": "px",
        "default": 24
