{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'content-block__inner', gap_fallback_tablet: 32, gap_fallback_mobile: 32 %}

{%- liquid
  assign bg_color = section.settings.background_color
  assign text_align = section.settings.text_alignment
  assign layout = section.settings.layout
  assign show_divider = section.settings.show_divider
  assign divider_style = section.settings.divider_style | default: 'dotted'
  assign divider_color = section.settings.divider_color | default: '#51ADA0'
  assign divider_thickness = section.settings.divider_thickness | default: 2
  assign divider_dot_size = section.settings.divider_dot_size | default: 4
  assign divider_dot_spacing = section.settings.divider_dot_spacing | default: 12
  assign divider_spacing = section.settings.divider_spacing | default: 32
  assign text_2_spacing = section.settings.text_2_spacing_top | default: 24
  assign show_heading_dot_divider = section.settings.show_heading_dot_divider
  assign heading_dot_color = section.settings.heading_dot_divider_color | default: '#7EC8D0'
  assign heading_dot_size = section.settings.heading_dot_divider_size | default: 4
  assign heading_dot_spacing = section.settings.heading_dot_divider_spacing | default: 10
  assign heading_dot_width = section.settings.heading_dot_divider_width | default: 85
  assign heading_dot_margin_top = section.settings.heading_dot_divider_margin_top | default: 8
  assign heading_dot_margin_bottom = section.settings.heading_dot_divider_margin_bottom | default: 4
  assign section_offset_top = section.settings.section_offset_top | default: 0
  assign section_offset_unit = section.settings.section_offset_unit | default: 'em'
  assign enable_section_offset = section.settings.enable_section_offset
-%}

<section
  class="content-block section-spacing{% if layout == 'reverse' %} content-block--reverse{% endif %}"
  aria-labelledby="content-block-heading-{{ section.id }}"
>
  <div class="page-width">
    <div class="content-block__wrapper">
      <div class="content-block__inner{% if layout == 'reverse' %} content-block__inner--reverse{% endif %}">
        <div class="content-block__media">
          {% render 'responsive-image',
            image: section.settings.image,
            alt: section.settings.image_alt,
            class: 'content-block__image',
            loading: section.settings.image_loading
          %}
        </div>

        <div class="content-block__content text-{{ text_align }}">
          {%- if section.settings.badge != blank -%}
            <span class="content-block__badge">{{ section.settings.badge }}</span>
          {%- endif -%}

          <div id="content-block-heading-{{ section.id }}">
            {% render 'highlighted-heading',
              heading: section.settings.heading,
              heading_weight: section.settings.heading_weight,
              heading_url: section.settings.heading_url,
              heading_link_new_tab: section.settings.heading_link_new_tab,
              heading_before: section.settings.heading_before,
              heading_highlight: section.settings.heading_highlight,
              heading_after: section.settings.heading_after,
              heading_before_weight: section.settings.heading_before_weight,
              heading_highlight_weight: section.settings.heading_highlight_weight,
              heading_after_weight: section.settings.heading_after_weight,
              heading_tag: section.settings.heading_tag,
              heading_size: section.settings.heading_tag,
              highlight_color: section.settings.highlight_color
            %}
          </div>

          {%- if show_heading_dot_divider -%}
            <span class="content-block__heading-dots" aria-hidden="true"></span>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="section-text rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            {% render 'button',
              label: section.settings.button_label,
              url: section.settings.button_url,
              style: section.settings.button_style
            %}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.text_2 != blank -%}
        <div class="content-block__description-2 section-text rte text-{{ text_align }}">
          {{ section.settings.text_2 }}
        </div>
      {%- endif -%}

      {%- if show_divider -%}
        <hr
          class="content-block__divider content-block__divider--{{ divider_style }}"
          aria-hidden="true"
        >
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {%- if bg_color != blank and bg_color != 'rgba(0,0,0,0)' -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ bg_color }};
    }
  {%- endif -%}
  {%- if enable_section_offset -%}
    #shopify-section-{{ section.id }} {
      position: relative;
      top: {{ section_offset_top }}{{ section_offset_unit }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .content-block__wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .content-block__description-2 {
    width: 100%;
    margin-top: {{ text_2_spacing }}px;
  }
  {%- if section.settings.text_2_font_size > 0 -%}
    #shopify-section-{{ section.id }} .content-block__description-2,
    #shopify-section-{{ section.id }} .content-block__description-2 p {
      font-size: {{ section.settings.text_2_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_2_font_weight != blank and section.settings.text_2_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .content-block__description-2,
    #shopify-section-{{ section.id }} .content-block__description-2 p {
      font-weight: {{ section.settings.text_2_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_2_font_color != blank -%}
    #shopify-section-{{ section.id }} .content-block__description-2,
    #shopify-section-{{ section.id }} .content-block__description-2 p,
    #shopify-section-{{ section.id }} .content-block__description-2 a {
      color: {{ section.settings.text_2_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .content-block__divider {
    display: block;
    width: 100%;
    flex-shrink: 0;
    margin: {{ divider_spacing }}px 0 0;
    padding: 0;
    border: none;
    color: {{ divider_color }};
  }
  #shopify-section-{{ section.id }} .content-block__divider--dotted {
    height: {{ divider_dot_size }}px;
    background-image: radial-gradient(
      circle,
      {{ divider_color }} calc({{ divider_dot_size }}px / 2),
      transparent calc({{ divider_dot_size }}px / 2)
    );
    background-size: {{ divider_dot_spacing }}px {{ divider_dot_size }}px;
    background-repeat: repeat-x;
    background-position: center;
  }
  #shopify-section-{{ section.id }} .content-block__divider--dashed {
    height: 0;
    border-top: {{ divider_thickness }}px dashed {{ divider_color }};
  }
  #shopify-section-{{ section.id }} .content-block__divider--solid {
    height: 0;
    border-top: {{ divider_thickness }}px solid {{ divider_color }};
  }
  #shopify-section-{{ section.id }} .content-block__heading-dots {
    display: block;
    width: {{ heading_dot_width }}%;
    max-width: 100%;
    height: {{ heading_dot_size }}px;
    margin-top: {{ heading_dot_margin_top }}px;
    margin-bottom: {{ heading_dot_margin_bottom }}px;
    flex-shrink: 0;
    background-image: radial-gradient(
      circle,
      {{ heading_dot_color }} calc({{ heading_dot_size }}px / 2),
      transparent calc({{ heading_dot_size }}px / 2)
    );
    background-size: {{ heading_dot_spacing }}px {{ heading_dot_size }}px;
    background-repeat: repeat-x;
    background-position: 0 50%;
  }
  #shopify-section-{{ section.id }} .text-center .content-block__heading-dots {
    margin-left: auto;
    margin-right: auto;
    background-position: center;
  }
  {%- liquid
    assign highlight_color = section.settings.highlight_color | default: '#51ADA0'
    assign highlight_weight = section.settings.heading_highlight_weight | default: '900'
    if highlight_weight == blank or highlight_weight == 'inherit'
      assign highlight_weight = '900'
    endif
  -%}
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ highlight_color }};
    font-weight: {{ highlight_weight }};
  }
</style>

{% schema %}
{
  "name": "Content Block",
  "tag": "section",
  "class": "section-content-block",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)",
      "default": "Your Heading Here",
      "info": "Or use split heading fields below."
    },
    {
      "type": "url",
      "id": "heading_url",
      "label": "Heading link",
      "info": "Optional. Makes the heading clickable."
    },
    {
      "type": "checkbox",
      "id": "heading_link_new_tab",
      "label": "Open heading link in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#51ADA0"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2",
      "info": "Use only one H1 per page for SEO"
    },
    {
      "type": "header",
      "content": "Heading dot divider"
    },
    {
      "type": "checkbox",
      "id": "show_heading_dot_divider",
      "label": "Show dot divider below heading",
      "default": false,
      "info": "Dotted line between the heading and description, beside the image."
    },
    {
      "type": "color",
      "id": "heading_dot_divider_color",
      "label": "Dot color",
      "default": "#7EC8D0"
    },
    {
      "type": "range",
      "id": "heading_dot_divider_size",
      "label": "Dot size",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "heading_dot_divider_spacing",
      "label": "Dot spacing",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "heading_dot_divider_width",
      "label": "Divider width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85,
      "info": "Width relative to the text column."
    },
    {
      "type": "range",
      "id": "heading_dot_divider_margin_top",
      "label": "Space above divider",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 8,
      "info": "Gap between heading and dots."
    },
    {
      "type": "range",
      "id": "heading_dot_divider_margin_bottom",
      "label": "Space below divider",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 4,
      "info": "Extra gap before description (column gap also applies)."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description (beside image)",
      "default": "<p>Add your content here. This reusable section can be duplicated across any page.</p>"
    },
    {
      "type": "header",
      "content": "Description 2"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Description (full width below row)",
      "info": "Optional second paragraph shown full width between the image/text row and the divider."
    },
    {
      "type": "color",
      "id": "text_2_font_color",
      "label": "Description 2 color"
    },
    {
      "type": "range",
      "id": "text_2_font_size",
      "label": "Description 2 font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "text_2_font_weight",
      "label": "Description 2 font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "text_2_spacing_top",
      "label": "Space above description 2",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24,
      "info": "Gap between the image/text row and description 2."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" },
        { "value": "yellow", "label": "Yellow" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Upload or select an image from your Shopify media library"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text (SEO)",
      "info": "Describe the image for accessibility and search engines"
    },
    {
      "type": "select",
      "id": "image_loading",
      "label": "Image loading",
      "options": [
        { "value": "lazy", "label": "Lazy (recommended)" },
        { "value": "eager", "label": "Eager (above the fold)" }
      ],
      "default": "lazy"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout direction",
      "options": [
        { "value": "default", "label": "Image left, text right" },
        { "value": "reverse", "label": "Image right, text left" }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "column_1_width",
      "label": "Image column width",
      "min": 25,
      "max": 75,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Text column uses the remainder. Desktop only; stacks on tablet and mobile."
    },
    {
      "type": "range",
      "id": "column_2_width",
      "label": "Text column width (override)",
      "min": 0,
      "max": 75,
      "step": 5,
      "unit": "%",
      "default": 0,
      "info": "0 = auto (100% minus image column width)."
    },
    {
      "type": "header",
      "content": "Column spacing"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns (desktop)",
      "min": 0,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default (48px)."
    },
    {
      "type": "range",
      "id": "column_gap_tablet",
      "label": "Gap between columns (tablet)",
      "min": 0,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 0,
      "info": "768px–1023px when stacked. 0 = theme default (32px)."
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "Gap between columns (mobile)",
      "min": 0,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 0,
      "info": "767px and below when stacked. 0 = theme default (32px)."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "info": "Applies to the outer section only, not inner cards or banners."
    },
    {
      "type": "header",
      "content": "Section position"
    },
    {
      "type": "checkbox",
      "id": "enable_section_offset",
      "label": "Enable vertical offset",
      "default": false,
      "info": "Shift the entire section up (negative) or down (positive), e.g. top: -5em to overlap the section above."
    },
    {
      "type": "range",
      "id": "section_offset_top",
      "label": "Vertical offset value",
      "min": -20,
      "max": 20,
      "step": 1,
      "default": -5,
      "info": "Use with em for relative sizing (e.g. -5). Positive moves down."
    },
    {
      "type": "select",
      "id": "section_offset_unit",
      "label": "Vertical offset unit",
      "options": [
        { "value": "em", "label": "em (relative to font size)" },
        { "value": "px", "label": "px (fixed pixels)" }
      ],
      "default": "em"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider below content",
      "default": false,
      "info": "Displays a horizontal line below the text and image row."
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider style",
      "options": [
        { "value": "dotted", "label": "Dotted" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "dotted"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#51ADA0"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Divider thickness (solid/dashed)",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "divider_dot_size",
      "label": "Dot size (dotted)",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "divider_dot_spacing",
      "label": "Dot spacing (dotted)",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "label": "Space above divider",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32,
      "info": "Gap between description 2 (or the image/text row) and the divider."
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "presets": [
    {
      "name": "Content Block"
    }
  ]
}
{% endschema %}
