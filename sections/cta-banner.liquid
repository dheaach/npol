{% render 'section-font-vars', section: section %}

{%- liquid
  assign bg_color = section.settings.background_color | default: settings.color_secondary
-%}

<section
  class="cta-banner section-spacing"
  aria-labelledby="cta-heading-{{ section.id }}"
>
  <div class="page-width">
    <div class="cta-banner__inner" style="background-color: {{ bg_color }};">
      <div class="cta-banner__content">
        {% render 'section-heading',
          heading: section.settings.heading,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}

        {%- if section.settings.text != blank -%}
          <div class="section-text rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.image != blank -%}
        <div class="cta-banner__media">
          {% render 'responsive-image',
            image: section.settings.image,
            alt: section.settings.image_alt,
            class: 'cta-banner__image',
            width: 400
          %}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {% render 'button',
          label: section.settings.button_label,
          url: section.settings.button_url,
          style: section.settings.button_style
        %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "tag": "section",
  "class": "section-cta-banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Get Started?"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "yellow", "label": "Yellow" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "yellow"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Optional image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text (SEO)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0A1D3C"
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
