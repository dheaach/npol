{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'cta-teal__inner' %}

<section class="cta-teal section-spacing" style="background-color: {{ section.settings.background_color | default: '#1BCDC4' }};" aria-labelledby="cta-teal-heading-{{ section.id }}">
  <div class="page-width">
    <div
      class="cta-teal__inner"
      style="--cta-teal-content-gap: {{ section.settings.content_gap | default: 24 }}px;"
    >
      <div class="cta-teal__content">
        {%- if section.settings.tag_label != blank -%}
          <div
            class="cta-teal__tag"
            style="{% if section.settings.tag_bg_image != blank %}background-image: url('{{ section.settings.tag_bg_image | image_url: width: 1200 }}');{% endif %}{% if section.settings.tag_color != blank %} background-color: {{ section.settings.tag_color }};{% endif %}"
          >
            <span class="cta-teal__tag-label">{{ section.settings.tag_label }}</span>
          </div>
        {%- endif -%}

        <div id="cta-teal-heading-{{ section.id }}">
          {% render 'highlighted-heading',
            heading: section.settings.heading,
            heading_font_size: section.settings.heading_font_size,
            heading_weight: section.settings.heading_weight,
            heading_before: section.settings.heading_before,
            heading_highlight: section.settings.heading_highlight,
            heading_after: section.settings.heading_after,
            heading_before_weight: section.settings.heading_before_weight,
            heading_before_font_size: section.settings.heading_before_font_size,
            heading_highlight_weight: section.settings.heading_highlight_weight,
            heading_highlight_font_size: section.settings.heading_highlight_font_size,
            heading_after_weight: section.settings.heading_after_weight,
            heading_after_font_size: section.settings.heading_after_font_size,
            heading_tag: section.settings.heading_tag,
            heading_size: section.settings.heading_tag,
            highlight_color: section.settings.highlight_color
          %}
        </div>

        {%- if section.settings.text != blank -%}
          <div class="section-text rte cta-teal__text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          {% render 'button', label: section.settings.button_label, url: section.settings.button_url, style: 'yellow' %}
        {%- endif -%}
      </div>

      {%- if section.settings.decoration_image != blank -%}
        <div class="cta-teal__decoration" aria-hidden="true">
          {% render 'responsive-image',
            image: section.settings.decoration_image,
            alt: section.settings.decoration_image_alt,
            class: 'cta-teal__decoration-image',
            width: 600
          %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color | default: '#0A1D3C' }};
  }
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .cta-teal__text,
    #shopify-section-{{ section.id }} .cta-teal__text p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .cta-teal__text,
    #shopify-section-{{ section.id }} .cta-teal__text p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .cta-teal__text,
    #shopify-section-{{ section.id }} .cta-teal__text p,
    #shopify-section-{{ section.id }} .cta-teal__text a {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- elsif section.settings.text_color != blank -%}
    #shopify-section-{{ section.id }} .cta-teal__text {
      color: {{ section.settings.text_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .cta-teal__content {
    gap: var(--cta-teal-content-gap, 24px);
  }
  #shopify-section-{{ section.id }} .cta-teal__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: max-content;
    max-width: 100%;
    {%- assign tag_pad_y = section.settings.tag_padding_y | default: 10 -%}
    {%- assign tag_pad_x = section.settings.tag_padding_x | default: 20 -%}
    padding: {{ tag_pad_y }}px {{ tag_pad_x }}px;
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
    background-color: {{ section.settings.tag_color | default: '#FFC300' }};
  }
  #shopify-section-{{ section.id }} .cta-teal__tag-label {
    display: inline-block;
    font-family: var(--font-heading);
    line-height: {{ section.settings.tag_label_line_height | default: 120 }}%;
  }
  {%- if section.settings.tag_label_font_size > 0 -%}
    #shopify-section-{{ section.id }} .cta-teal__tag-label {
      font-size: {{ section.settings.tag_label_font_size }}px !important;
    }
  {%- endif -%}
  {%- if section.settings.tag_label_font_weight != blank and section.settings.tag_label_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .cta-teal__tag-label {
      font-weight: {{ section.settings.tag_label_font_weight }} !important;
    }
  {%- endif -%}
  {%- if section.settings.tag_label_font_color != blank -%}
    #shopify-section-{{ section.id }} .cta-teal__tag-label {
      color: {{ section.settings.tag_label_font_color }} !important;
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .cta-teal__decoration-image {
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: contain;
  }
</style>

{% schema %}
