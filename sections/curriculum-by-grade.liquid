{% render 'section-font-vars', section: section %}

{%- liquid
  assign heading_align = section.settings.heading_alignment | default: 'center'

  assign col_gap_d = section.settings.column_gap | default: 0
  if col_gap_d == 0
    assign col_gap_d = 24
  endif
  assign col_gap_t = section.settings.column_gap_tablet | default: 0
  if col_gap_t == 0
    assign col_gap_t = col_gap_d
  endif
  assign col_gap_m = section.settings.column_gap_mobile | default: 0
  if col_gap_m == 0
    assign col_gap_m = col_gap_t
  endif

  assign cols_d = section.settings.cards_per_row | default: 3
  assign cols_t = section.settings.cards_per_row_tablet | default: 2
  assign cols_m = section.settings.cards_per_row_mobile | default: 1
-%}

<section
  class="curriculum-by-grade section-spacing"
  aria-labelledby="curriculum-heading-{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div
        class="curriculum-by-grade__header text-{{ heading_align }}"
        id="curriculum-heading-{{ section.id }}"
      >
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_font_size: section.settings.heading_font_size,
          heading_weight: section.settings.heading_weight,
          heading_font_color: section.settings.heading_font_color,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}
      </div>
    {%- endif -%}

    <div
      class="curriculum-by-grade__grid"
      style="
        --curriculum-columns: {{ cols_d }};
        --curriculum-columns-tablet: {{ cols_t }};
        --curriculum-columns-mobile: {{ cols_m }};
        --curriculum-gap: {{ col_gap_d }}px;
        --curriculum-gap-tablet: {{ col_gap_t }}px;
        --curriculum-gap-mobile: {{ col_gap_m }}px;
      "
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign grade_collection = block.settings.collection
          assign card_image = blank
          assign card_url = '#'
          assign image_source = block.settings.image_source | default: 'collection'
          assign img_src_width = block.settings.image_width | default: 600
          assign img_max_d = block.settings.image_max_width | default: 0
          if img_max_d == 0
            assign img_max_d = 280
          endif
          assign img_max_t = block.settings.image_max_width_tablet | default: 0
          if img_max_t == 0
            assign img_max_t = img_max_d
          endif
          assign img_max_m = block.settings.image_max_width_mobile | default: 0
          if img_max_m == 0
            assign img_max_m = img_max_t
          endif

          if grade_collection != blank
            assign card_url = grade_collection.url
          endif

          assign card_title = block.settings.title
          if card_title == blank and grade_collection != blank
            assign card_title = grade_collection.title
          endif

          if image_source == 'custom' and block.settings.image != blank
            assign card_image = block.settings.image
          elsif grade_collection != blank
            if grade_collection.featured_image != blank
              assign card_image = grade_collection.featured_image
            elsif grade_collection.image != blank
              assign card_image = grade_collection.image
            else
              assign first_product = grade_collection.products.first
              if first_product != blank and first_product.featured_image != blank
                assign card_image = first_product.featured_image
              endif
            endif
          endif

          assign card_image_alt = block.settings.image_alt
          if card_image_alt == blank
            assign card_image_alt = card_title
          endif

          assign button_label = block.settings.button_label
          if button_label == blank and card_title != blank
            assign button_label = 'View ' | append: card_title | append: ' Curriculum'
          endif

          assign box_bg = block.settings.box_bg_color | default: '#26C6DA'
        -%}
        <article
          id="curriculum-grade-card-{{ block.id }}"
          class="curriculum-grade-card"
          {{ block.shopify_attributes }}
          style="
            background-color: {{ box_bg }};
            --curriculum-card-image-max: {{ img_max_d }}px;
            --curriculum-card-image-max-tablet: {{ img_max_t }}px;
            --curriculum-card-image-max-mobile: {{ img_max_m }}px;
          "
        >
          {%- if card_title != blank -%}
            <h3 class="section-heading section-heading--h3 curriculum-grade-card__title">
              {{ card_title }}
            </h3>
          {%- endif -%}

          <div class="curriculum-grade-card__image">
            {%- if card_image != blank -%}
              {% render 'responsive-image',
                image: card_image,
                alt: card_image_alt,
                class: 'curriculum-grade-card__image-el',
                width: img_src_width
              %}
            {%- else -%}
              <div class="curriculum-grade-card__image-el curriculum-grade-card__image-el--placeholder" role="img" aria-label="{{ card_title | default: 'Grade curriculum' | escape }}">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          {%- if button_label != blank -%}
            <div class="curriculum-grade-card__actions">
              {% render 'button',
                label: button_label,
                url: card_url,
                style: section.settings.button_style,
                class: 'curriculum-grade-card__btn'
              %}
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}
  {% render 'section-spacing-styles', root: '.curriculum-by-grade', pad_x: '.page-width' %}
  {% render 'section-spacing-gap', section: section, selector: '.curriculum-by-grade__grid', gap_id: 'column_gap', stack_breakpoint: '0' %}
  {%- if section.settings.heading_font_color != blank -%}
    #shopify-section-{{ section.id }} #curriculum-heading-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.heading_font_size > 0 -%}
    #shopify-section-{{ section.id }} #curriculum-heading-{{ section.id }} .section-heading {
      font-size: {{ section.settings.heading_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.heading_weight != blank and section.settings.heading_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} #curriculum-heading-{{ section.id }} .section-heading {
      font-weight: {{ section.settings.heading_weight }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .curriculum-by-grade__header {
    margin-bottom: 40px;
  }
  #shopify-section-{{ section.id }} .curriculum-by-grade__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-sizing: border-box;
    flex: 0 0 calc((100% - (var(--curriculum-columns, 3) - 1) * var(--curriculum-gap, 24px)) / var(--curriculum-columns, 3));
    max-width: calc((100% - (var(--curriculum-columns, 3) - 1) * var(--curriculum-gap, 24px)) / var(--curriculum-columns, 3));
    min-width: 0;
    padding: 24px 20px 28px;
    min-height: 320px;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__title {
    margin: 0 0 16px;
    width: 100%;
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__image {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-bottom: 20px;
    min-height: 0;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__image-el {
    width: 100%;
    max-width: var(--curriculum-card-image-max, 280px);
    height: auto;
    display: block;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__image-el--placeholder {
    max-width: 200px;
    opacity: 0.5;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__actions {
    width: 100%;
    margin-top: auto;
  }
  #shopify-section-{{ section.id }} .curriculum-grade-card__btn {
    width: 100%;
    text-align: center;
    border-radius: 0;
  }
  {%- for block in section.blocks -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #curriculum-grade-card-{{ block.id }} .curriculum-grade-card__title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #curriculum-grade-card-{{ block.id }} .curriculum-grade-card__title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #curriculum-grade-card-{{ block.id }} .curriculum-grade-card__title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
  {%- endfor -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .curriculum-grade-card {
      flex-basis: calc((100% - (var(--curriculum-columns-tablet, 2) - 1) * var(--curriculum-gap-tablet, 24px)) / var(--curriculum-columns-tablet, 2));
      max-width: calc((100% - (var(--curriculum-columns-tablet, 2) - 1) * var(--curriculum-gap-tablet, 24px)) / var(--curriculum-columns-tablet, 2));
    }
    #shopify-section-{{ section.id }} .curriculum-grade-card__image-el {
      max-width: var(--curriculum-card-image-max-tablet, var(--curriculum-card-image-max, 280px));
    }
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .curriculum-grade-card {
      flex-basis: calc((100% - (var(--curriculum-columns-mobile, 1) - 1) * var(--curriculum-gap-mobile, 24px)) / var(--curriculum-columns-mobile, 1));
      max-width: calc((100% - (var(--curriculum-columns-mobile, 1) - 1) * var(--curriculum-gap-mobile, 24px)) / var(--curriculum-columns-mobile, 1));
    }
    #shopify-section-{{ section.id }} .curriculum-grade-card__image-el {
      max-width: var(--curriculum-card-image-max-mobile, var(--curriculum-card-image-max-tablet, var(--curriculum-card-image-max, 280px)));
    }
    #shopify-section-{{ section.id }} .curriculum-by-grade__header {
      margin-bottom: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Curriculum by Grade",
  "tag": "section",
  "class": "section-curriculum-by-grade",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Curriculum by Grade"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color",
      "info": "Empty = theme heading color."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2",
      "info": "Use only one H1 per page for SEO."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards per row (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "info": "1024px and up."
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "label": "Cards per row (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "768px–1023px."
    },
    {
      "type": "range",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1,
      "info": "767px and below."
