{% render 'section-font-vars', section: section %}
{% render 'section-column-widths',
  section: section,
  grid_class: 'dark-plan-cta__inner',
  gap_fallback_tablet: 32,
  gap_fallback_mobile: 32
%}

{%- liquid
  assign has_bg_desktop = false
  assign bg_url = blank
  if section.settings.background_image != blank
    assign has_bg_desktop = true
    assign bg_url = section.settings.background_image | image_url: width: 3840
  endif

  assign has_bg_tablet = false
  assign bg_tablet_url = blank
  if section.settings.background_image_tablet != blank
    assign has_bg_tablet = true
    assign bg_tablet_url = section.settings.background_image_tablet | image_url: width: 2400
  endif

  assign has_bg_mobile = false
  assign bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign has_bg_mobile = true
    assign bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif

  assign bg_layered = false
  if has_bg_mobile or has_bg_tablet
    assign bg_layered = true
  endif

  assign image_position = section.settings.image_position | default: 'left'
  assign body_content_gap = section.settings.content_gap | default: 24
  assign image_align = section.settings.image_align | default: 'center'
  assign image_aspect = section.settings.image_aspect_ratio | default: 'auto'

  assign bg_type = section.settings.background_type | default: 'color'
  assign grad_start = section.settings.gradient_color_start | default: '#0A1D3C'
  assign grad_end = section.settings.gradient_color_end | default: '#51ADA0'
  assign grad_dir = section.settings.gradient_direction | default: 'vertical'

  if grad_dir == 'horizontal'
    assign grad_css = 'linear-gradient(to right, ' | append: grad_start | append: ' 0%, ' | append: grad_end | append: ' 50%)'
  else
    assign grad_css = 'linear-gradient(to bottom, ' | append: grad_start | append: ' 0%, ' | append: grad_end | append: ' 50%)'
  endif
-%}

<section
  class="dark-plan-cta"
  aria-labelledby="dark-plan-cta-heading-{{ section.id }}"
>
  {%- if has_bg_mobile -%}
    <div
      class="dark-plan-cta__bg dark-plan-cta__bg--mobile"
      style="background-image: url({{ bg_mobile_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}
  {%- if has_bg_tablet -%}
    <div
      class="dark-plan-cta__bg dark-plan-cta__bg--tablet"
      style="background-image: url({{ bg_tablet_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}
  {%- if has_bg_desktop -%}
    <div
      class="dark-plan-cta__bg{% if bg_layered %} dark-plan-cta__bg--desktop{% endif %}"
      style="background-image: url({{ bg_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="dark-plan-cta__content section-spacing">
    <div class="page-width">
      <div class="dark-plan-cta__inner{% if image_position == 'right' %} dark-plan-cta__inner--image-right{% endif %}">
        <div class="dark-plan-cta__media dark-plan-cta__media--align-{{ image_align }}">
          <div class="dark-plan-cta__image-wrap{% if image_aspect == 'auto' %} dark-plan-cta__image-wrap--auto{% endif %}">
            {% render 'responsive-image',
              image: section.settings.image,
              alt: section.settings.image_alt,
              class: 'dark-plan-cta__image',
              loading: section.settings.image_loading,
              width: section.settings.image_width | default: 800
            %}
          </div>
        </div>

        <div class="dark-plan-cta__body">
          <div id="dark-plan-cta-heading-{{ section.id }}">
            {% render 'highlighted-heading',
              heading: section.settings.heading,
              heading_font_size: section.settings.heading_font_size,
              heading_weight: section.settings.heading_weight,
              heading_before: section.settings.heading_before,
              heading_highlight: section.settings.heading_highlight,
              heading_after: section.settings.heading_after,
              heading_before_weight: section.settings.heading_before_weight,
              heading_before_font_size: section.settings.heading_before_font_size,
              heading_highlight_weight: section.settings.heading_highlight_weight,
              heading_highlight_font_size: section.settings.heading_highlight_font_size,
              heading_after_weight: section.settings.heading_after_weight,
              heading_after_font_size: section.settings.heading_after_font_size,
              heading_tag: section.settings.heading_tag,
              heading_size: section.settings.heading_tag,
              highlight_color: section.settings.highlight_color
            %}
          </div>

          {%- if section.settings.text != blank -%}
            <div class="section-text rte dark-plan-cta__text">{{ section.settings.text }}</div>
          {%- endif -%}

          <div class="dark-plan-cta__actions">
            {%- if section.settings.button_primary_label != blank -%}
              {% render 'button',
                label: section.settings.button_primary_label,
                url: section.settings.button_primary_url,
                style: 'yellow',
                class: 'dark-plan-cta__btn-primary'
              %}
            {%- endif -%}
            {%- if section.settings.button_secondary_label != blank -%}
              {% render 'button',
                label: section.settings.button_secondary_label,
                url: section.settings.button_secondary_url,
                style: 'primary',
                class: 'dark-plan-cta__btn-secondary'
              %}
            {%- endif -%}
          </div>

          {%- if section.settings.caption != blank -%}
            <p class="dark-plan-cta__caption section-text">{{ section.settings.caption }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  {%- if bg_type == 'gradient' -%}
    #shopify-section-{{ section.id }} {
      background: {{ grad_css }};
    }
  {%- else -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color | default: '#0A1D3C' }};
    }
  {%- endif -%}
  {%- liquid
    assign btn_primary_bg = section.settings.button_primary_bg_color
    assign btn_primary_text = section.settings.button_primary_text_color
    assign btn_primary_border = section.settings.button_primary_border_color
    if btn_primary_border == blank and btn_primary_bg != blank
      assign btn_primary_border = btn_primary_bg
    endif
    assign btn_secondary_bg = section.settings.button_secondary_bg_color
    assign btn_secondary_text = section.settings.button_secondary_text_color
    assign btn_secondary_border = section.settings.button_secondary_border_color
    if btn_secondary_border == blank and btn_secondary_bg != blank
      assign btn_secondary_border = btn_secondary_bg
    endif
  -%}
  {%- if btn_primary_bg != blank or btn_primary_text != blank or btn_primary_border != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__btn-primary {
      {%- if btn_primary_bg != blank -%}
      background-color: {{ btn_primary_bg }};
      {%- endif -%}
      {%- if btn_primary_text != blank -%}
      color: {{ btn_primary_text }};
      {%- endif -%}
      {%- if btn_primary_border != blank -%}
      border-color: {{ btn_primary_border }};
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .dark-plan-cta__btn-primary:hover {
      {%- if btn_primary_bg != blank -%}
      background-color: {{ btn_primary_bg }};
      border-color: {{ btn_primary_border | default: btn_primary_bg }};
      filter: brightness(0.92);
      {%- endif -%}
      {%- if btn_primary_text != blank -%}
      color: {{ btn_primary_text }};
      {%- endif -%}
    }
  {%- endif -%}
  {%- if btn_secondary_bg != blank or btn_secondary_text != blank or btn_secondary_border != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__btn-secondary {
      {%- if btn_secondary_bg != blank -%}
      background-color: {{ btn_secondary_bg }};
      {%- endif -%}
      {%- if btn_secondary_text != blank -%}
      color: {{ btn_secondary_text }};
      {%- endif -%}
      {%- if btn_secondary_border != blank -%}
      border-color: {{ btn_secondary_border }};
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .dark-plan-cta__btn-secondary:hover {
      {%- if btn_secondary_bg != blank -%}
      background-color: {{ btn_secondary_bg }};
      border-color: {{ btn_secondary_border | default: btn_secondary_bg }};
      filter: brightness(0.92);
      {%- endif -%}
      {%- if btn_secondary_text != blank -%}
      color: {{ btn_secondary_text }};
      {%- endif -%}
    }
  {%- endif -%}
  {% render 'section-spacing-styles', root: '.dark-plan-cta', pad_y: '.dark-plan-cta__content', pad_x: '.page-width' %}
  #shopify-section-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color | default: '#FFFFFF' }};
  }
  {%- if section.settings.heading_font_color != blank -%}
    #shopify-section-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#51ADA0' }} !important;
  }
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__text,
    #shopify-section-{{ section.id }} .dark-plan-cta__text p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__text,
    #shopify-section-{{ section.id }} .dark-plan-cta__text p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__text,
    #shopify-section-{{ section.id }} .dark-plan-cta__text p,
    #shopify-section-{{ section.id }} .dark-plan-cta__text a {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- elsif section.settings.text_color != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__text,
    #shopify-section-{{ section.id }} .dark-plan-cta__text p {
      color: {{ section.settings.text_color }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_size > 0 -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__caption {
      font-size: {{ section.settings.caption_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.caption_font_weight != blank and section.settings.caption_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__caption {
      font-weight: {{ section.settings.caption_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_color != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__caption {
      color: {{ section.settings.caption_font_color }};
    }
  {%- elsif section.settings.text_color != blank -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__caption {
      color: {{ section.settings.text_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .dark-plan-cta__body {
    gap: {{ body_content_gap }}px;
  }
  {%- if image_position == 'right' -%}
    #shopify-section-{{ section.id }} .dark-plan-cta__inner--image-right .dark-plan-cta__media {
      grid-column: 2;
      grid-row: 1;
    }
    #shopify-section-{{ section.id }} .dark-plan-cta__inner--image-right .dark-plan-cta__body {
      grid-column: 1;
      grid-row: 1;
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .dark-plan-cta__image-wrap {
    width: 100%;
    {%- if section.settings.image_max_width > 0 -%}
    max-width: {{ section.settings.image_max_width }}px;
    {%- endif -%}
    {%- if image_aspect != 'auto' -%}
    aspect-ratio: {{ image_aspect }};
    overflow: hidden;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .dark-plan-cta__image-wrap--auto .dark-plan-cta__image {
    height: auto;
  }
  #shopify-section-{{ section.id }} .dark-plan-cta__image {
    width: 100%;
    display: block;
    object-fit: {{ section.settings.image_object_fit | default: 'cover' }};
    {%- if image_aspect != 'auto' -%}
    height: 100%;
    {%- endif -%}
    {%- if section.settings.image_border_radius > 0 -%}
    border-radius: {{ section.settings.image_border_radius }}px;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .dark-plan-cta__image-wrap .responsive-image--placeholder {
    width: 100%;
    {%- if image_aspect != 'auto' -%}
    height: 100%;
    min-height: 200px;
    {%- endif -%}
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .dark-plan-cta__image-wrap {
      {%- if section.settings.image_max_width_mobile > 0 -%}
      max-width: {{ section.settings.image_max_width_mobile }}px;
      {%- elsif section.settings.image_max_width > 0 -%}
      max-width: {{ section.settings.image_max_width }}px;
      {%- endif -%}
    }
  }
  {%- liquid
    assign bg_mode_mobile = section.settings.background_size_mobile | default: 'cover'
    assign bg_mode_tablet = section.settings.background_size_tablet | default: 'cover'
    assign bg_mode_laptop = section.settings.background_size_laptop | default: 'cover'
    assign bg_mode_desktop = section.settings.background_size_desktop | default: 'cover'
    assign bg_mode_4k = section.settings.background_size_4k | default: 'cover'
    assign bg_pos_base = section.settings.background_position | default: 'center center'
    assign bg_pos_mobile = section.settings.background_position_mobile | default: bg_pos_base
    assign bg_pos_tablet = section.settings.background_position_tablet | default: bg_pos_base
    assign bg_pos_laptop = section.settings.background_position_laptop | default: bg_pos_base
    assign bg_pos_desktop = section.settings.background_position_desktop | default: bg_pos_base
    assign bg_pos_4k = section.settings.background_position_4k | default: bg_pos_base
  -%}
  {%- capture bg_size_mobile -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_mobile %}{%- endcapture -%}
  {%- capture bg_size_tablet -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_tablet %}{%- endcapture -%}
  {%- capture bg_size_laptop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_laptop %}{%- endcapture -%}
  {%- capture bg_size_desktop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_desktop %}{%- endcapture -%}
  {%- capture bg_size_4k -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_4k %}{%- endcapture -%}
  #shopify-section-{{ section.id }} .dark-plan-cta__bg {
    background-size: {{ bg_size_mobile | strip }};
    background-position: {{ bg_pos_mobile }};
    background-repeat: no-repeat;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .dark-plan-cta__bg {
      background-size: {{ bg_size_tablet | strip }};
      background-position: {{ bg_pos_tablet }};
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .dark-plan-cta__bg {
      background-size: {{ bg_size_laptop | strip }};
      background-position: {{ bg_pos_laptop }};
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .dark-plan-cta__bg {
      background-size: {{ bg_size_desktop | strip }};
      background-position: {{ bg_pos_desktop }};
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .dark-plan-cta__bg {
      background-size: {{ bg_size_4k | strip }};
      background-position: {{ bg_pos_4k }};
    }
  }
  {%- if has_bg_mobile -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .dark-plan-cta__bg--mobile {
        display: none;
      }
    }
  {%- endif -%}
  {%- if has_bg_mobile -%}
    {%- if has_bg_desktop or has_bg_tablet -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .dark-plan-cta__bg--desktop,
      #shopify-section-{{ section.id }} .dark-plan-cta__bg--tablet {
        display: none;
      }
    }
    {%- endif -%}
  {%- endif -%}
  {%- if has_bg_tablet and has_bg_desktop -%}
    @media screen and (min-width: 768px) and (max-width: 1023px) {
      #shopify-section-{{ section.id }} .dark-plan-cta__bg--desktop {
        display: none;
      }
    }
    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} .dark-plan-cta__bg--tablet {
        display: none;
      }
    }
  {%- endif -%}
  {%- liquid
    assign min_height_mobile = section.settings.section_min_height_mobile | default: 480
    assign min_height_tablet = section.settings.section_min_height_tablet | default: 520
    assign min_height_laptop = section.settings.section_min_height_laptop | default: 560
    assign min_height_desktop = section.settings.section_min_height_desktop | default: 600
    assign min_height_4k = section.settings.section_min_height_4k | default: 640
  -%}
  #shopify-section-{{ section.id }} .dark-plan-cta,
  #shopify-section-{{ section.id }} .dark-plan-cta__content {
    min-height: {{ min_height_mobile }}px;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .dark-plan-cta,
    #shopify-section-{{ section.id }} .dark-plan-cta__content {
      min-height: {{ min_height_tablet }}px;
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .dark-plan-cta,
    #shopify-section-{{ section.id }} .dark-plan-cta__content {
      min-height: {{ min_height_laptop }}px;
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .dark-plan-cta,
    #shopify-section-{{ section.id }} .dark-plan-cta__content {
      min-height: {{ min_height_desktop }}px;
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .dark-plan-cta,
    #shopify-section-{{ section.id }} .dark-plan-cta__content {
      min-height: {{ min_height_4k }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Dark Plan CTA",
  "tag": "section",
  "class": "section-dark-plan-cta",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)",
      "default": "Plan Your Next Steps Toward Student-Centered Mathematics",
      "info": "Or use split heading fields below."
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size (single line)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading font weight (single line)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)"
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight"
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)"
    },
    {
      "type": "range",
      "id": "heading_after_font_size",
      "label": "Font size (after highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (fallback)",
      "default": "#FFFFFF",
      "info": "Used when Heading color above is empty."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#51ADA0"
    },
    {
      "type": "header",
