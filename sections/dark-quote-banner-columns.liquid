{% render 'section-font-vars', section: section %}

{%- liquid
  assign section_bg_url = blank
  if section.settings.background_image != blank
    assign section_bg_url = section.settings.background_image | image_url: width: 2400
  endif

  assign section_bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign section_bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif

  assign columns_count = section.settings.columns_count | default: '1'
  assign col1 = section.settings.column_1_width | default: 50
  assign col2_setting = section.settings.column_2_width | default: 0
  assign col3_setting = section.settings.column_3_width | default: 0

  if col2_setting > 0
    assign col2 = col2_setting
  elsif columns_count == '3'
    assign col2 = 100 | minus: col1 | divided_by: 2
  else
    assign col2 = 100 | minus: col1
  endif

  if col3_setting > 0
    assign col3 = col3_setting
  else
    assign col3 = 100 | minus: col1 | minus: col2
  endif

  assign columns_alignment = section.settings.columns_alignment | default: 'center'
  assign columns_horizontal_alignment = section.settings.columns_horizontal_alignment | default: 'center'

  assign bg_type = section.settings.background_type | default: 'color'
  assign grad_start = section.settings.gradient_color_start | default: '#0A1D3C'
  assign grad_end = section.settings.gradient_color_end | default: '#51ADA0'
  assign grad_dir = section.settings.gradient_direction | default: 'vertical'

  if grad_dir == 'horizontal'
    assign grad_css = 'linear-gradient(to right, ' | append: grad_start | append: ', ' | append: grad_end | append: ')'
  else
    assign grad_css = 'linear-gradient(to bottom, ' | append: grad_start | append: ', ' | append: grad_end | append: ')'
  endif
-%}

<section
  class="dark-quote-banner-columns"
  aria-label="{{ section.settings.section_aria_label | default: 'Quote banner' | escape }}"
>
  {%- liquid
    assign bg_flip_desktop = section.settings.background_flip | default: 'none'
    assign bg_flip_mobile = section.settings.background_flip_mobile | default: 'none'
  -%}
  {%- if section_bg_mobile_url != blank -%}
    <div
      class="dark-quote-banner-columns__bg dark-quote-banner-columns__bg--mobile{% if bg_flip_mobile != 'none' %} dark-quote-banner-columns__bg--flip-{{ bg_flip_mobile }}{% endif %}"
      style="background-image: url({{ section_bg_mobile_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}
  {%- if section_bg_url != blank -%}
    <div
      class="dark-quote-banner-columns__bg{% if section_bg_mobile_url != blank %} dark-quote-banner-columns__bg--desktop{% endif %}{% if bg_flip_desktop != 'none' %} dark-quote-banner-columns__bg--flip-{{ bg_flip_desktop }}{% endif %}"
      style="background-image: url({{ section_bg_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="dark-quote-banner-columns__content section-spacing">
    <div class="page-width">
      <div class="dark-quote-banner-columns__grid dark-quote-banner-columns__grid--cols-{{ columns_count }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign col_text_color = block.settings.text_color
            if col_text_color == blank
              assign col_text_color = section.settings.text_color
            endif
            assign col_subtext_color = block.settings.subtext_font_color
            if col_subtext_color == blank
              assign col_subtext_color = col_text_color
            endif
            assign col_highlight = block.settings.highlight_color
            if col_highlight == blank
              assign col_highlight = section.settings.highlight_color
            endif
            assign col_align = block.settings.text_align | default: 'center'
            assign img_position = block.settings.image_position | default: 'above'
            assign img_side = false
            if img_position == 'left' or img_position == 'right'
              assign img_side = true
            endif
            assign col_img_width = block.settings.image_width | default: 800
            if block.settings.image_src_width_tablet > 0 and block.settings.image_src_width_tablet < col_img_width
              assign col_img_width = block.settings.image_src_width_tablet
            endif
            if block.settings.image_src_width_mobile > 0 and block.settings.image_src_width_mobile < col_img_width
              assign col_img_width = block.settings.image_src_width_mobile
            endif
          -%}
          <div
            id="quote-column-{{ block.id }}"
            class="dark-quote-banner-columns__column text-{{ col_align }}{% if img_side %} dark-quote-banner-columns__column--image-side dark-quote-banner-columns__column--image-{{ img_position }}{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank and img_position == 'above' -%}
              <div class="dark-quote-banner-columns__media dark-quote-banner-columns__media--align-{{ block.settings.image_align | default: 'center' }}">
                {% render 'responsive-image',
                  image: block.settings.image,
                  alt: block.settings.image_alt,
                  class: 'dark-quote-banner-columns__image',
                  loading: block.settings.image_loading,
                  width: col_img_width
                %}
              </div>
            {%- endif -%}

            {%- if img_side -%}
              <div class="dark-quote-banner-columns__row">
                {%- if img_position == 'left' and block.settings.image != blank -%}
                  <div class="dark-quote-banner-columns__media dark-quote-banner-columns__media--side dark-quote-banner-columns__media--align-{{ block.settings.image_align | default: 'center' }}">
                    {% render 'responsive-image',
                      image: block.settings.image,
                      alt: block.settings.image_alt,
                      class: 'dark-quote-banner-columns__image',
                      loading: block.settings.image_loading,
                      width: col_img_width
                    %}
                  </div>
                {%- endif -%}

                <div class="dark-quote-banner-columns__body">
                  <div class="dark-quote-banner-columns__heading{% if block.settings.heading != blank %} dark-quote-banner-columns__heading--single{% endif %}">
                    {% render 'highlighted-heading',
                      heading: block.settings.heading,
                      heading_weight: block.settings.heading_weight,
                      heading_before: block.settings.heading_before,
                      heading_highlight: block.settings.heading_highlight,
                      heading_after: block.settings.heading_after,
                      heading_before_weight: block.settings.heading_before_weight,
                      heading_highlight_weight: block.settings.heading_highlight_weight,
                      heading_after_weight: block.settings.heading_after_weight,
                      heading_tag: block.settings.heading_tag,
                      heading_size: block.settings.heading_tag,
                      highlight_color: col_highlight
                    %}
                  </div>

                  {%- if block.settings.subtext != blank -%}
                    <div class="dark-quote-banner-columns__subtext section-text rte">{{ block.settings.subtext }}</div>
                  {%- endif -%}
                </div>

                {%- if img_position == 'right' and block.settings.image != blank -%}
                  <div class="dark-quote-banner-columns__media dark-quote-banner-columns__media--side dark-quote-banner-columns__media--align-{{ block.settings.image_align | default: 'center' }}">
                    {% render 'responsive-image',
                      image: block.settings.image,
                      alt: block.settings.image_alt,
                      class: 'dark-quote-banner-columns__image',
                      loading: block.settings.image_loading,
                      width: col_img_width
                    %}
                  </div>
                {%- endif -%}
              </div>
            {%- else -%}
              <div class="dark-quote-banner-columns__heading{% if block.settings.heading != blank %} dark-quote-banner-columns__heading--single{% endif %}">
                {% render 'highlighted-heading',
                  heading: block.settings.heading,
                  heading_weight: block.settings.heading_weight,
                  heading_before: block.settings.heading_before,
                  heading_highlight: block.settings.heading_highlight,
                  heading_after: block.settings.heading_after,
                  heading_before_weight: block.settings.heading_before_weight,
                  heading_highlight_weight: block.settings.heading_highlight_weight,
                  heading_after_weight: block.settings.heading_after_weight,
                  heading_tag: block.settings.heading_tag,
                  heading_size: block.settings.heading_tag,
                  highlight_color: col_highlight
                %}
              </div>

              {%- if block.settings.subtext != blank -%}
                <div class="dark-quote-banner-columns__subtext section-text rte">{{ block.settings.subtext }}</div>
              {%- endif -%}
            {%- endif -%}

            {%- if block.settings.image != blank and img_position == 'below' -%}
              <div class="dark-quote-banner-columns__media dark-quote-banner-columns__media--below dark-quote-banner-columns__media--align-{{ block.settings.image_align | default: 'center' }}">
                {% render 'responsive-image',
                  image: block.settings.image,
                  alt: block.settings.image_alt,
                  class: 'dark-quote-banner-columns__image',
                  loading: block.settings.image_loading,
                  width: col_img_width
                %}
              </div>
            {%- endif -%}
          </div>

          <style>
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .section-heading {
              color: {{ col_text_color | default: '#FFFFFF' }};
            }
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext,
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext p,
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext a,
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext li {
              color: {{ col_subtext_color | default: '#FFFFFF' }};
            }
            {%- if block.settings.subtext_font_size > 0 -%}
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext,
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext p {
                font-size: {{ block.settings.subtext_font_size }}px;
              }
            {%- endif -%}
            {%- if block.settings.subtext_font_weight != blank and block.settings.subtext_font_weight != 'inherit' -%}
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext,
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__subtext p {
                font-weight: {{ block.settings.subtext_font_weight }};
              }
            {%- endif -%}
            #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .text-highlight {
              color: {{ col_highlight | default: '#51ADA0' }} !important;
            }
            {%- if block.settings.heading != blank -%}
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__heading--single .section-heading {
                max-width: {{ block.settings.heading_max_width | default: 720 }}px;
                {%- if col_align == 'center' -%}
                  margin-left: auto;
                  margin-right: auto;
                {%- elsif col_align == 'right' -%}
                  margin-left: auto;
                  margin-right: 0;
                {%- else -%}
                  margin-left: 0;
                  margin-right: auto;
                {%- endif -%}
              }
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                width: 100%;
                height: auto;
                display: block;
                object-fit: {{ block.settings.image_object_fit | default: 'contain' }};
                {%- if block.settings.image_border_radius > 0 -%}
                border-radius: {{ block.settings.image_border_radius }}px;
                {%- endif -%}
                {%- if block.settings.image_max_width > 0 -%}
                max-width: {{ block.settings.image_max_width }}px;
                {%- endif -%}
              }
              {%- if block.settings.image_align == 'center' or block.settings.image_max_width > 0 -%}
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__media {
                  display: flex;
                  justify-content: center;
                }
              {%- elsif block.settings.image_align == 'right' -%}
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__media {
                  display: flex;
                  justify-content: flex-end;
                }
              {%- elsif block.settings.image_align == 'left' -%}
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__media {
                  display: flex;
                  justify-content: flex-start;
                }
              {%- endif -%}
              {%- if block.settings.image_display_width > 0 -%}
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                  width: {{ block.settings.image_display_width }}%;
                }
              {%- endif -%}
              {%- if block.settings.image_display_width_tablet > 0 -%}
              @media screen and (min-width: 768px) and (max-width: 1023px) {
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                  width: {{ block.settings.image_display_width_tablet }}%;
                  max-width: 100%;
                }
              }
              {%- endif -%}
              {%- if block.settings.image_display_width_mobile > 0 -%}
              @media screen and (max-width: 767px) {
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                  width: {{ block.settings.image_display_width_mobile }}%;
                  max-width: 100%;
                }
              }
              {%- endif -%}
              {%- if block.settings.image_max_width_tablet > 0 -%}
              @media screen and (min-width: 768px) and (max-width: 1023px) {
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                  max-width: {{ block.settings.image_max_width_tablet }}px;
                }
              }
              {%- endif -%}
              {%- if block.settings.image_max_width_mobile > 0 -%}
              @media screen and (max-width: 767px) {
                #shopify-section-{{ section.id }} #quote-column-{{ block.id }} .dark-quote-banner-columns__image {
                  max-width: {{ block.settings.image_max_width_mobile }}px;
                }
              }
              {%- endif -%}
            {%- endif -%}
          </style>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    overflow: hidden;
    {%- if bg_type == 'gradient' -%}
    background: {{ grad_css }};
    {%- else -%}
    background-color: {{ section.settings.background_color | default: '#0A1D3C' }};
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-repeat: no-repeat;
    pointer-events: none;
  }
  {% render 'section-spacing-styles', root: '.dark-quote-banner-columns', pad_y: '.dark-quote-banner-columns__content', pad_x: '.page-width' %}
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#51ADA0' }} !important;
  }
  {%- liquid
    assign legacy_bg_mode = section.settings.background_size | default: 'fit_width'
    if legacy_bg_mode == '100% auto' or legacy_bg_mode == 'contain'
      assign legacy_bg_mode = 'fit_width'
    elsif legacy_bg_mode == '100% 100%'
      assign legacy_bg_mode = 'stretch'
    endif
    assign bg_mode_mobile = section.settings.background_size_mobile | default: 'fit_width'
    assign bg_mode_tablet = section.settings.background_size_tablet | default: 'fit_width'
    assign bg_mode_laptop = section.settings.background_size_laptop | default: legacy_bg_mode
    assign bg_mode_desktop = section.settings.background_size_desktop | default: 'fit_width'
    assign bg_mode_4k = section.settings.background_size_4k | default: 'fit_width'
    assign bg_position = section.settings.background_position | default: 'center center'
  -%}
  {%- capture bg_size_mobile -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_mobile %}{%- endcapture -%}
  {%- capture bg_size_tablet -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_tablet %}{%- endcapture -%}
  {%- capture bg_size_laptop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_laptop %}{%- endcapture -%}
  {%- capture bg_size_desktop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_desktop %}{%- endcapture -%}
  {%- capture bg_size_4k -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_4k %}{%- endcapture -%}
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
    background-size: {{ bg_size_mobile | strip }};
    background-position: {{ bg_position }};
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg--flip-horizontal {
    transform: scaleX(-1);
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg--flip-vertical {
    transform: scaleY(-1);
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg--flip-both {
    transform: scale(-1, -1);
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
      background-size: {{ bg_size_tablet | strip }};
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
      background-size: {{ bg_size_laptop | strip }};
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
      background-size: {{ bg_size_desktop | strip }};
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg {
      background-size: {{ bg_size_4k | strip }};
    }
  }
  {%- if section_bg_mobile_url != blank and section_bg_url != blank -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg--desktop {
        display: none;
      }
    }
  {%- endif -%}
  {%- if section_bg_mobile_url != blank -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .dark-quote-banner-columns__bg--mobile {
        display: none;
      }
    }
  {%- endif -%}
  {%- liquid
    assign legacy_min_height = section.settings.section_min_height | default: 320
    assign min_height_mobile = section.settings.section_min_height_mobile | default: 240
    assign min_height_tablet = section.settings.section_min_height_tablet | default: 280
    assign min_height_laptop = section.settings.section_min_height_laptop | default: legacy_min_height
    assign min_height_desktop = section.settings.section_min_height_desktop | default: 400
    assign min_height_4k = section.settings.section_min_height_4k | default: 480
  -%}
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .dark-quote-banner-columns,
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
    min-height: {{ min_height_mobile }}px;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__grid {
    display: grid;
    width: 100%;
    align-items: {{ columns_alignment }};
    justify-items: {{ columns_horizontal_alignment }};
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__column {
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__media {
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__media--below {
    margin-bottom: 0;
    margin-top: 20px;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__column--image-right .dark-quote-banner-columns__row {
    flex-direction: row-reverse;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__body {
    flex: 1;
    min-width: 0;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__media--side {
    margin: 0;
    flex-shrink: 0;
    max-width: 45%;
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__column--image-side .dark-quote-banner-columns__row {
      flex-direction: column;
    }
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__media--side {
      max-width: 100%;
      width: 100%;
    }
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__heading {
    width: 100%;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__subtext {
    margin-top: 16px;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__column.text-center .dark-quote-banner-columns__subtext {
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__column.text-left .dark-quote-banner-columns__subtext {
    margin-left: 0;
    margin-right: auto;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner-columns__column.text-right .dark-quote-banner-columns__subtext {
    margin-left: auto;
    margin-right: 0;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }},
    #shopify-section-{{ section.id }} .dark-quote-banner-columns,
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
      min-height: {{ min_height_tablet }}px;
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }},
    #shopify-section-{{ section.id }} .dark-quote-banner-columns,
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
      min-height: {{ min_height_laptop }}px;
    }
    {%- if columns_count == '1' -%}
      #shopify-section-{{ section.id }} .dark-quote-banner-columns__grid--cols-1 {
        grid-template-columns: minmax(0, 1fr);
      }
    {%- elsif columns_count == '2' -%}
      #shopify-section-{{ section.id }} .dark-quote-banner-columns__grid--cols-2 {
        grid-template-columns: minmax(0, {{ col1 }}fr) minmax(0, {{ col2 }}fr);
      }
    {%- elsif columns_count == '3' -%}
      #shopify-section-{{ section.id }} .dark-quote-banner-columns__grid--cols-3 {
        grid-template-columns: minmax(0, {{ col1 }}fr) minmax(0, {{ col2 }}fr) minmax(0, {{ col3 }}fr);
      }
    {%- endif -%}
  }
  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }},
    #shopify-section-{{ section.id }} .dark-quote-banner-columns,
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
      min-height: {{ min_height_desktop }}px;
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }},
    #shopify-section-{{ section.id }} .dark-quote-banner-columns,
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__content {
      min-height: {{ min_height_4k }}px;
    }
  }
  {% render 'section-spacing-gap', section: section, selector: '.dark-quote-banner-columns__grid', stack_breakpoint: '0' %}
  {%- if section.settings.col_padding_top > 0 -%}
    #shopify-section-{{ section.id }} .dark-quote-banner-columns__column {
