{% render 'section-font-vars', section: section %}

{%- liquid
  assign banner_bg_url = blank
  if section.settings.background_image != blank
    assign banner_bg_url = section.settings.background_image | image_url: width: 2400
  elsif settings.dark_quote_banner_background != blank
    assign banner_bg_url = settings.dark_quote_banner_background | image_url: width: 2400
  endif

  assign banner_bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign banner_bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif
-%}

<section
  class="dark-quote-banner"
  style="background-color: {{ section.settings.background_color | default: '#0A1D3C' }};"
  aria-labelledby="quote-heading-{{ section.id }}"
>
  {%- liquid
    assign bg_flip_desktop = section.settings.background_flip | default: 'none'
    assign bg_flip_mobile = section.settings.background_flip_mobile | default: 'none'
  -%}
  {%- if banner_bg_mobile_url != blank -%}
    <div
      class="dark-quote-banner__bg dark-quote-banner__bg--mobile{% if bg_flip_mobile != 'none' %} dark-quote-banner__bg--flip-{{ bg_flip_mobile }}{% endif %}"
      style="background-image: url({{ banner_bg_mobile_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}
  {%- if banner_bg_url != blank -%}
    <div
      class="dark-quote-banner__bg{% if banner_bg_mobile_url != blank %} dark-quote-banner__bg--desktop{% endif %}{% if bg_flip_desktop != 'none' %} dark-quote-banner__bg--flip-{{ bg_flip_desktop }}{% endif %}"
      style="background-image: url({{ banner_bg_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="dark-quote-banner__content section-spacing">
    <div class="page-width text-center">
      <div class="dark-quote-banner__heading{% if section.settings.heading != blank %} dark-quote-banner__heading--single{% endif %}">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_weight: section.settings.heading_weight,
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_after: section.settings.heading_after,
          heading_before_weight: section.settings.heading_before_weight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_after_weight: section.settings.heading_after_weight,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>

      {%- if section.settings.subtext != blank -%}
        <p class="dark-quote-banner__subtext section-text">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.dark-quote-banner', pad_y: '.dark-quote-banner__content', pad_x: '.page-width' %}
  #shopify-section-{{ section.id }} .section-heading {
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
  }
  {%- liquid
    assign subtext_color = section.settings.subtext_color
    if subtext_color == blank
      assign subtext_color = section.settings.text_color
    endif
    if subtext_color == blank
      assign subtext_color = '#FFFFFF'
    endif
  -%}
  #shopify-section-{{ section.id }} .dark-quote-banner__subtext {
    color: {{ subtext_color }};
  }
  {%- if section.settings.subtext_font_size > 0 -%}
    #shopify-section-{{ section.id }} .dark-quote-banner__subtext {
      font-size: {{ section.settings.subtext_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_weight != blank and section.settings.subtext_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .dark-quote-banner__subtext {
      font-weight: {{ section.settings.subtext_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_max_width > 0 -%}
    #shopify-section-{{ section.id }} .dark-quote-banner__subtext {
      max-width: {{ section.settings.subtext_max_width }}px;
      margin-left: auto;
      margin-right: auto;
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#51ADA0' }} !important;
  }
  {%- liquid
    assign legacy_bg_mode = section.settings.background_size | default: 'fit_width'
    if legacy_bg_mode == '100% auto' or legacy_bg_mode == 'contain'
      assign legacy_bg_mode = 'fit_width'
    elsif legacy_bg_mode == '100% 100%'
      assign legacy_bg_mode = 'stretch'
    endif
    assign bg_mode_mobile = section.settings.background_size_mobile | default: 'fit_width'
    assign bg_mode_tablet = section.settings.background_size_tablet | default: 'fit_width'
    assign bg_mode_laptop = section.settings.background_size_laptop | default: legacy_bg_mode
    assign bg_mode_desktop = section.settings.background_size_desktop | default: 'fit_width'
    assign bg_mode_4k = section.settings.background_size_4k | default: 'fit_width'
    assign bg_position = section.settings.background_position | default: 'center center'
  -%}
  {%- capture bg_size_mobile -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_mobile %}{%- endcapture -%}
  {%- capture bg_size_tablet -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_tablet %}{%- endcapture -%}
  {%- capture bg_size_laptop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_laptop %}{%- endcapture -%}
  {%- capture bg_size_desktop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_desktop %}{%- endcapture -%}
  {%- capture bg_size_4k -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_4k %}{%- endcapture -%}
  #shopify-section-{{ section.id }} .dark-quote-banner__bg {
    background-size: {{ bg_size_mobile | strip }};
    background-position: {{ bg_position }};
  }
  #shopify-section-{{ section.id }} .dark-quote-banner__bg--flip-horizontal {
    transform: scaleX(-1);
  }
  #shopify-section-{{ section.id }} .dark-quote-banner__bg--flip-vertical {
    transform: scaleY(-1);
  }
  #shopify-section-{{ section.id }} .dark-quote-banner__bg--flip-both {
    transform: scale(-1, -1);
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .dark-quote-banner__bg {
      background-size: {{ bg_size_tablet | strip }};
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .dark-quote-banner__bg {
      background-size: {{ bg_size_laptop | strip }};
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .dark-quote-banner__bg {
      background-size: {{ bg_size_desktop | strip }};
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .dark-quote-banner__bg {
      background-size: {{ bg_size_4k | strip }};
    }
  }
  {%- if banner_bg_mobile_url != blank and banner_bg_url != blank -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .dark-quote-banner__bg--desktop {
        display: none;
      }
    }
  {%- endif -%}
  {%- if banner_bg_mobile_url != blank -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .dark-quote-banner__bg--mobile {
        display: none;
      }
    }
  {%- endif -%}
  {%- liquid
    assign legacy_min_height = section.settings.section_min_height | default: 320
    assign min_height_mobile = section.settings.section_min_height_mobile | default: 240
    assign min_height_tablet = section.settings.section_min_height_tablet | default: 280
    assign min_height_laptop = section.settings.section_min_height_laptop | default: legacy_min_height
    assign min_height_desktop = section.settings.section_min_height_desktop | default: 400
    assign min_height_4k = section.settings.section_min_height_4k | default: 480
  -%}
  #shopify-section-{{ section.id }} .dark-quote-banner,
  #shopify-section-{{ section.id }} .dark-quote-banner__content {
    min-height: {{ min_height_mobile }}px;
  }
  #shopify-section-{{ section.id }} .dark-quote-banner__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .dark-quote-banner,
    #shopify-section-{{ section.id }} .dark-quote-banner__content {
      min-height: {{ min_height_tablet }}px;
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .dark-quote-banner,
    #shopify-section-{{ section.id }} .dark-quote-banner__content {
      min-height: {{ min_height_laptop }}px;
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .dark-quote-banner,
    #shopify-section-{{ section.id }} .dark-quote-banner__content {
      min-height: {{ min_height_desktop }}px;
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .dark-quote-banner,
    #shopify-section-{{ section.id }} .dark-quote-banner__content {
      min-height: {{ min_height_4k }}px;
    }
  }
  #shopify-section-{{ section.id }} .dark-quote-banner__heading--single .section-heading {
    max-width: {{ section.settings.heading_max_width | default: 720 }}px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

{% schema %}
{
  "name": "Dark Quote Banner",
  "tag": "section",
  "class": "section-dark-quote",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)",
      "info": "Or use split heading fields below"
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "label": "Heading max width (single line)",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 720,
      "info": "Only applies when single line heading is used"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit",
      "info": "Used when “Heading (single line)” is filled in"
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "range",
      "id": "subtext_max_width",
      "label": "Subtext max width",
      "min": 0,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 0,
      "info": "0 = no limit (full container width)."
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "info": "If empty, uses heading text color."
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "subtext_font_weight",
      "label": "Subtext font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
