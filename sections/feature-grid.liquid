{% render 'section-font-vars', section: section %}

{%- liquid
  assign columns = section.settings.columns
  assign bg_color = section.settings.background_color
-%}

<section
  class="feature-grid section-spacing"
  {% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %}
    style="background-color: {{ bg_color }};"
  {% endif %}
  aria-labelledby="feature-grid-heading-{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="feature-grid__header">
        {% render 'section-heading',
          heading: section.settings.heading,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}
        {%- if section.settings.text != blank -%}
          <div class="section-text rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="feature-grid__items" style="--columns: {{ columns }};">
      {%- for block in section.blocks -%}
        <article class="feature-grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="feature-grid__icon">
              {% render 'responsive-image',
                image: block.settings.image,
                alt: block.settings.image_alt,
                class: 'feature-grid__icon-image',
                width: 112
              %}
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="section-heading section-heading--h3">{{ block.settings.title }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="section-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .feature-grid__items {
    grid-template-columns: repeat({{ columns }}, 1fr);
  }
  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .feature-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .feature-grid__items {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Feature Grid",
  "tag": "section",
  "class": "section-feature-grid",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Features"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon / Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text (SEO)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Describe your feature here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Grid",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
