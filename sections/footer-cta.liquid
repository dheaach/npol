{% render 'section-font-vars', section: section %}

<section class="footer-cta section-spacing" style="background-color: {{ section.settings.background_color | default: '#0A1D3C' }};" aria-labelledby="footer-cta-heading-{{ section.id }}">
  <div class="page-width">
    <div class="footer-cta__inner">
      <div class="footer-cta__media">
        {% render 'polaroid-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          tape_color: section.settings.tape_color,
          rotation: section.settings.rotation
        %}
      </div>

      <div class="footer-cta__content">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_after: section.settings.heading_after,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}

        {%- if section.settings.text != blank -%}
          <div class="section-text rte footer-cta__text">{{ section.settings.text }}</div>
        {%- endif -%}

        <div class="footer-cta__actions">
          {%- if section.settings.button_primary_label != blank -%}
            {% render 'button',
              label: section.settings.button_primary_label,
              url: section.settings.button_primary_url,
              style: 'yellow'
            %}
          {%- endif -%}
          {%- if section.settings.button_secondary_label != blank -%}
            {% render 'button',
              label: section.settings.button_secondary_label,
              url: section.settings.button_secondary_url,
              style: 'primary'
            %}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-heading,
  #shopify-section-{{ section.id }} .footer-cta__text {
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
  }
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#1BCDC4' }} !important;
  }
</style>

{% schema %}
{
  "name": "Footer CTA",
  "tag": "section",
  "class": "section-footer-cta",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Are You Ready to Put "
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Student-Centered Math"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)",
      "default": " into Practice?"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Button label",
      "default": "Contact an Expert"
    },
    {
      "type": "url",
      "id": "button_primary_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Button label",
      "default": "Get a Free Sample"
    },
    {
      "type": "url",
      "id": "button_secondary_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image (Polaroid)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text (SEO)"
    },
    {
      "type": "select",
      "id": "tape_color",
      "label": "Tape accent color",
      "options": [
        { "value": "yellow", "label": "Yellow" },
        { "value": "teal", "label": "Teal" },
        { "value": "pink", "label": "Pink" }
      ],
      "default": "yellow"
    },
    {
      "type": "select",
      "id": "rotation",
      "label": "Image rotation",
      "options": [
        { "value": "left", "label": "Tilt left" },
        { "value": "right", "label": "Tilt right" },
        { "value": "none", "label": "No rotation" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0A1D3C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "presets": [{ "name": "Footer CTA" }]
}
{% endschema %}
