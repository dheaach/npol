{%- liquid
  assign footer_bg = section.settings.background_color | default: '#000b1e'
  assign scroll_bg = section.settings.scroll_top_bg_color | default: '#FFCC00'
  assign scroll_icon = section.settings.scroll_top_icon_color | default: '#000000'
  assign scroll_bg_hover = section.settings.scroll_top_bg_hover_color | default: '#E6B800'
  assign scroll_icon_hover = section.settings.scroll_top_icon_hover_color | default: '#000000'
  assign divider_color = section.settings.divider_color | default: 'rgba(255, 255, 255, 0.15)'
  assign logo_width = section.settings.logo_width | default: 200
  assign logo_height = section.settings.logo_height | default: 0
  assign social_icon_color = section.settings.social_icon_color | default: '#000b1e'
  assign social_icon_bg = section.settings.social_icon_bg_color | default: '#ffffff'
  assign content_max_width = section.settings.content_max_width | default: 1440
-%}

<style>
  {% render 'section-spacing-styles', root: '.site-footer', pad_x: '.site-footer__inner', pad_x_fallback: true %}
  #shopify-section-{{ section.id }} .site-footer {
    background-color: {{ footer_bg }};
    --site-footer-scroll-bg: {{ scroll_bg }};
    --site-footer-scroll-icon: {{ scroll_icon }};
    --site-footer-scroll-bg-hover: {{ scroll_bg_hover }};
    --site-footer-scroll-icon-hover: {{ scroll_icon_hover }};
    --site-footer-divider: {{ divider_color }};
  }

  #shopify-section-{{ section.id }} .site-footer__inner {
    width: 100%;
    max-width: {{ content_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
  }

  {%- if section.settings.copyright_text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .site-footer__copyright,
    #shopify-section-{{ section.id }} .site-footer__copyright p {
      font-size: {{ section.settings.copyright_text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.copyright_text_font_weight != blank and section.settings.copyright_text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .site-footer__copyright,
    #shopify-section-{{ section.id }} .site-footer__copyright p {
      font-weight: {{ section.settings.copyright_text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.copyright_text_font_color != blank -%}
    #shopify-section-{{ section.id }} .site-footer__copyright,
    #shopify-section-{{ section.id }} .site-footer__copyright p {
      color: {{ section.settings.copyright_text_font_color }};
    }
  {%- endif -%}

  {%- if section.settings.social_follow_text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .site-footer__social-label,
    #shopify-section-{{ section.id }} .site-footer__social-label p {
      font-size: {{ section.settings.social_follow_text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.social_follow_text_font_weight != blank and section.settings.social_follow_text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .site-footer__social-label,
    #shopify-section-{{ section.id }} .site-footer__social-label p {
      font-weight: {{ section.settings.social_follow_text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.social_follow_text_font_color != blank -%}
    #shopify-section-{{ section.id }} .site-footer__social-label,
    #shopify-section-{{ section.id }} .site-footer__social-label p {
      color: {{ section.settings.social_follow_text_font_color }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .site-footer__logo-image {
    width: {{ logo_width }}px;
    max-width: 100%;
    height: {% if logo_height > 0 %}{{ logo_height }}px{% else %}auto{% endif %};
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .site-footer__social a,
  #shopify-section-{{ section.id }} .site-footer__social .site-footer__social-link {
    background-color: {{ social_icon_bg }};
    color: {{ social_icon_color }};
  }

  #shopify-section-{{ section.id }} .site-footer__social svg {
    width: 25px;
    height: 25px;
    max-width: none;
    max-height: none;
    flex-shrink: 0;
  }
</style>

{% render 'section-column-widths', section: section, grid_class: 'site-footer__main' %}

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    {%- if section.settings.show_scroll_to_top -%}
      <button
        type="button"
        class="site-footer__scroll-top"
        data-scroll-to-top
        aria-label="{{ section.settings.scroll_top_label | default: 'Scroll to top' | escape }}"
      >
        <span class="site-footer__scroll-top-icon" aria-hidden="true">
          {% render 'icon-chevron-up' %}
        </span>
      </button>
    {%- endif -%}
    <div class="site-footer__main">
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="site-footer__logo" aria-label="{{ shop.name | escape }}">
          {%- if section.settings.logo != blank -%}
            {% render 'responsive-image',
              image: section.settings.logo,
              alt: section.settings.logo_alt | default: shop.name,
              class: 'site-footer__logo-image',
              width: logo_width,
              loading: 'lazy'
            %}
          {%- else -%}
            <span class="site-footer__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <div class="site-footer__aside">
        {%- if section.settings.menu != blank -%}
          <nav class="site-footer__row site-footer__row--nav" aria-label="{{ section.settings.menu_title | default: 'Footer navigation' | escape }}">
            <ul class="site-footer__links site-footer__links--menu">
              {%- for link in section.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </nav>
          <hr class="site-footer__divider" aria-hidden="true">
        {%- endif -%}

        {%- if section.settings.show_social -%}
          <div class="site-footer__row site-footer__row--social">
            {%- if section.settings.social_follow_text != blank -%}
              <p class="site-footer__social-label">{{ section.settings.social_follow_text }}</p>
            {%- endif -%}
            <ul class="site-footer__social" aria-label="Social media links">
              <li>
                {%- if section.settings.social_instagram != blank -%}
                  <a href="{{ section.settings.social_instagram }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    {% render 'icon-instagram' %}
                  </a>
                {%- else -%}
                  <span class="site-footer__social-link site-footer__social-link--disabled" aria-hidden="true">
                    {% render 'icon-instagram' %}
                  </span>
                {%- endif -%}
              </li>
              <li>
                {%- if section.settings.social_linkedin != blank -%}
                  <a href="{{ section.settings.social_linkedin }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    {% render 'icon-linkedin' %}
                  </a>
                {%- else -%}
                  <span class="site-footer__social-link site-footer__social-link--disabled" aria-hidden="true">
                    {% render 'icon-linkedin' %}
                  </span>
                {%- endif -%}
              </li>
              <li>
                {%- if section.settings.social_facebook != blank -%}
                  <a href="{{ section.settings.social_facebook }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    {% render 'icon-facebook' %}
                  </a>
                {%- else -%}
                  <span class="site-footer__social-link site-footer__social-link--disabled" aria-hidden="true">
                    {% render 'icon-facebook' %}
                  </span>
                {%- endif -%}
              </li>
              {%- if section.settings.social_twitter != blank -%}
                <li>
                  <a href="{{ section.settings.social_twitter }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                    {% render 'icon-twitter' %}
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
          {%- if section.settings.legal_menu != blank -%}
            <hr class="site-footer__divider" aria-hidden="true">
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.legal_menu != blank -%}
          <nav class="site-footer__row site-footer__row--legal" aria-label="{{ section.settings.legal_menu_title | default: 'Legal links' | escape }}">
            <ul class="site-footer__links site-footer__links--legal">
              {%- for link in section.settings.legal_menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      </div>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        {%- endif -%}
      </p>
    </div>
  </div>
</footer>

