{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'hero-math__inner' %}

<section class="hero-math section-spacing" aria-labelledby="hero-heading-{{ section.id }}">
  <div class="page-width">
    <div class="hero-math__inner{% if section.settings.mobile_stack_order == 'image-first' %} hero-math__inner--mobile-image-first{% endif %}">
      <div class="hero-math__content">
        <div id="hero-heading-{{ section.id }}">
          {%- liquid
            assign hero_heading_before_color = section.settings.heading_before_font_color
            if hero_heading_before_color == blank
              assign hero_heading_before_color = section.settings.heading_before_color
            endif
            if hero_heading_before_color == blank
              assign hero_heading_before_color = section.settings.heading_color
            endif
            assign hero_heading_after_color = section.settings.heading_after_color
            if hero_heading_after_color == blank
              assign hero_heading_after_color = section.settings.heading_color
            endif
          -%}
          {% render 'highlighted-heading',
            heading_before: section.settings.heading_before,
            heading_before_weight: section.settings.heading_before_weight,
            heading_before_font_size: section.settings.heading_before_font_size,
            heading_before_color: hero_heading_before_color,
            heading_highlight: section.settings.heading_highlight,
            heading_highlight_weight: section.settings.heading_highlight_weight,
            heading_highlight_font_size: section.settings.heading_highlight_font_size,
            heading_after: section.settings.heading_after,
            heading_after_weight: section.settings.heading_after_weight,
            heading_after_font_size: section.settings.heading_after_font_size,
            heading_after_color: hero_heading_after_color,
            heading_tag: section.settings.heading_tag,
            heading_size: section.settings.heading_tag,
            highlight_color: section.settings.highlight_color
          %}
        </div>

        {%- if section.settings.text != blank -%}
          <div class="section-text rte hero-math__text">{{ section.settings.text }}</div>
        {%- endif -%}

        <div class="hero-math__actions">
          {%- if section.settings.button_primary_label != blank -%}
            {% render 'button',
              label: section.settings.button_primary_label,
              url: section.settings.button_primary_url,
              style: 'yellow'
            %}
          {%- endif -%}
          {%- if section.settings.button_secondary_label != blank -%}
            <a href="{{ section.settings.button_secondary_url | default: '#' }}" class="btn btn--text-link hero-math__secondary-link">
              {{ section.settings.button_secondary_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.settings.paragraph != blank -%}
          <p class="hero-math__paragraph section-text">{{ section.settings.paragraph }}</p>
        {%- endif -%}
      </div>

      <div class="hero-math__media">
        
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          class: 'hero-math__image',
          loading: 'eager',
          fetchpriority: 'high'
        %}
      </div>
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.hero-math', pad_x: '.page-width' %}
  {%- liquid
    assign hero_heading_before_css_color = section.settings.heading_before_font_color
    if hero_heading_before_css_color == blank
      assign hero_heading_before_css_color = section.settings.heading_before_color
    endif
    if hero_heading_before_css_color == blank
      assign hero_heading_before_css_color = section.settings.heading_color
    endif
  -%}
  {%- if hero_heading_before_css_color != blank -%}
    #shopify-section-{{ section.id }} #hero-heading-{{ section.id }} .section-heading {
      color: {{ hero_heading_before_css_color }};
    }
    #shopify-section-{{ section.id }} #hero-heading-{{ section.id }} .section-heading > span:first-of-type:not(.text-highlight) {
      color: {{ hero_heading_before_css_color }};
    }
    #shopify-section-{{ section.id }} #hero-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#51ADA0' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #hero-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .hero-math__text,
    #shopify-section-{{ section.id }} .hero-math__text p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .hero-math__text,
    #shopify-section-{{ section.id }} .hero-math__text p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .hero-math__text,
    #shopify-section-{{ section.id }} .hero-math__text p,
    #shopify-section-{{ section.id }} .hero-math__text a {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- endif -%}
  {%- if section.settings.paragraph_font_size > 0 -%}
    #shopify-section-{{ section.id }} .hero-math__paragraph {
      font-size: {{ section.settings.paragraph_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.paragraph_font_weight != blank and section.settings.paragraph_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .hero-math__paragraph {
      font-weight: {{ section.settings.paragraph_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.paragraph_font_color != blank -%}
    #shopify-section-{{ section.id }} .hero-math__paragraph {
      color: {{ section.settings.paragraph_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.button_secondary_font_color != blank -%}
    #shopify-section-{{ section.id }} .hero-math__secondary-link {
      color: {{ section.settings.button_secondary_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.button_secondary_font_size > 0 -%}
    #shopify-section-{{ section.id }} .hero-math__secondary-link {
      font-size: {{ section.settings.button_secondary_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.button_secondary_font_weight != blank and section.settings.button_secondary_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .hero-math__secondary-link {
      font-weight: {{ section.settings.button_secondary_font_weight }};
    }
  {%- endif -%}

  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .hero-math__inner--mobile-image-first .hero-math__media {
      order: -1;
    }
  }
  {%- if section.settings.image_width_tablet > 0 -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .hero-math__media .hero-math__image {
      width: {{ section.settings.image_width_tablet }}%;
      max-width: 100%;
      margin-inline: auto;
    }
  }
  {%- endif -%}
  {%- if section.settings.image_width_mobile > 0 -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .hero-math__media .hero-math__image {
      width: {{ section.settings.image_width_mobile }}%;
      max-width: 100%;
      margin-inline: auto;
    }
  }
  {%- endif -%}
</style>

