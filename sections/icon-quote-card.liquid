    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "...and where a thinking partner makes the difference."
    },
    {
      "type": "color",
      "id": "banner_background_color",
      "label": "Banner background color",
      "default": "#A2E5E0"
    },
    {
      "type": "color",
