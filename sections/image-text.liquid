{% render 'section-font-vars', section: section %}

{%- liquid
  assign layout = section.settings.layout
  assign bg_color = section.settings.background_color
  assign image_only = false
  if layout == 'image-only'
    assign image_only = true
  endif
  assign image_max_d = 0
  case section.settings.image_display_size
    when 'small'
      assign image_max_d = 360
    when 'medium'
      assign image_max_d = 560
    when 'large'
      assign image_max_d = 800
  endcase
  if section.settings.image_max_width > 0
    assign image_max_d = section.settings.image_max_width
  endif
  assign image_max_t = section.settings.image_max_width_tablet | default: 0
  if image_max_t == 0
    assign image_max_t = image_max_d
  endif
  assign image_max_m = section.settings.image_max_width_mobile | default: 0
  if image_max_m == 0
    assign image_max_m = image_max_t
  endif
-%}

{%- unless layout == 'stacked' or layout == 'image-only' -%}
{% render 'section-column-widths', section: section, grid_class: 'image-text__inner', gap_fallback_tablet: 32, gap_fallback_mobile: 32 %}
{%- else -%}
{% render 'section-spacing-gap', section: section, selector: '.image-text__inner', stack_breakpoint: '0', standalone: true, gap_fallback_tablet: 32, gap_fallback_mobile: 32 %}
{%- endunless -%}

<section
  class="image-text section-spacing"
  {% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %}
    style="background-color: {{ bg_color }};"
  {% endif %}
>
  <div class="page-width">
    <div class="image-text__inner{% if image_only %} image-text__inner--image-only{% elsif layout == 'stacked' %} image-text__inner--stacked text-center{% endif %}{% if layout == 'side-by-side' and section.settings.image_position == 'right' %} image-text__inner--reverse{% endif %}">
      <div class="image-text__media">
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          class: 'image-text__image',
          loading: section.settings.image_loading
        %}
      </div>

      {%- unless image_only -%}
        <div class="image-text__content">
          {% render 'section-heading',
            heading: section.settings.heading,
            heading_tag: section.settings.heading_tag,
            heading_size: section.settings.heading_tag
          %}

          {%- if section.settings.text != blank -%}
            <div class="section-text rte image-text__text">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            {% render 'button',
              label: section.settings.button_label,
              url: section.settings.button_url,
              style: section.settings.button_style
            %}
          {%- endif -%}
        </div>
      {%- endunless -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.image-text', pad_x: '.page-width' %}
  {%- if layout == 'stacked' -%}
  #shopify-section-{{ section.id }} .image-text__inner--stacked {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__media {
    width: auto;
    max-width: 100%;
  }
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__media img,
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__image {
    width: auto;
    height: auto;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__content {
    align-items: center;
    width: 100%;
    {%- if section.settings.content_max_width > 0 -%}
    max-width: {{ section.settings.content_max_width }}px;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .image-text__inner--stacked .section-heading,
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__text,
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__text p {
    text-align: center;
  }
  {%- endif -%}
  {%- if layout == 'side-by-side' and section.settings.image_position == 'right' -%}
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .image-text__inner--reverse .image-text__media { order: 2; }
    #shopify-section-{{ section.id }} .image-text__inner--reverse .image-text__content { order: 1; }
  }
  {%- endif -%}
  {%- if image_max_d > 0 -%}
  #shopify-section-{{ section.id }} .image-text__media {
    max-width: {{ image_max_d }}px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ section.id }} .image-text__inner--stacked .image-text__media img,
  #shopify-section-{{ section.id }} .image-text__inner--image-only .image-text__media img,
  #shopify-section-{{ section.id }} .image-text__media img,
  #shopify-section-{{ section.id }} .image-text__image {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  {%- endif -%}
  {%- if image_max_t > 0 and image_max_t != image_max_d -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .image-text__media {
      max-width: {{ image_max_t }}px;
    }
  }
  {%- endif -%}
  {%- if image_max_m > 0 and image_max_m != image_max_t -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .image-text__media {
      max-width: {{ image_max_m }}px;
    }
  }
  {%- endif -%}
  {%- if section.settings.content_max_width > 0 and layout != 'stacked' -%}
  #shopify-section-{{ section.id }} .image-text__content {
    max-width: {{ section.settings.content_max_width }}px;
  }
  {%- endif -%}
  {%- if section.settings.heading_font_size > 0 -%}
    #shopify-section-{{ section.id }} .image-text__content .section-heading {
      font-size: {{ section.settings.heading_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.heading_font_weight != blank and section.settings.heading_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .image-text__content .section-heading {
      font-weight: {{ section.settings.heading_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.heading_font_color != blank -%}
    #shopify-section-{{ section.id }} .image-text__content .section-heading {
      color: {{ section.settings.heading_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .image-text__text,
    #shopify-section-{{ section.id }} .image-text__text p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .image-text__text,
    #shopify-section-{{ section.id }} .image-text__text p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .image-text__text,
    #shopify-section-{{ section.id }} .image-text__text p,
    #shopify-section-{{ section.id }} .image-text__text li,
    #shopify-section-{{ section.id }} .image-text__text a {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "Image + Text",
  "tag": "section",
  "class": "section-image-text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Title"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "text_font_color",
      "label": "Description color"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Description font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Description font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" },
        { "value": "yellow", "label": "Yellow" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text (SEO)"
    },
    {
      "type": "select",
      "id": "image_loading",
