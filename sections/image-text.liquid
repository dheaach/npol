    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "side-by-side", "label": "Side by side" },
        { "value": "stacked", "label": "Stacked (centered)" },
        { "value": "image-only", "label": "Image only" }
      ],
      "default": "side-by-side"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "info": "Side-by-side layout on desktop only."
    },
    {
      "type": "range",
