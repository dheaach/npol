      "options": [
        { "value": "lazy", "label": "Lazy" },
        { "value": "eager", "label": "Eager" }
      ],
      "default": "lazy"
    },
    {
      "type": "select",
      "id": "image_display_size",
      "label": "Image display size",
      "options": [
        { "value": "full", "label": "Full column width" },
        { "value": "large", "label": "Large (800px max)" },
        { "value": "medium", "label": "Medium (560px max)" },
        { "value": "small", "label": "Small (360px max)" }
