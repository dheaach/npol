{% render 'section-font-vars', section: section %}

{%- liquid
  assign layout = section.settings.layout
  assign bg_color = section.settings.background_color
-%}

<section
  class="image-text section-spacing"
  {% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %}
    style="background-color: {{ bg_color }};"
  {% endif %}
>
  <div class="page-width">
    <div class="image-text__inner{% if layout == 'stacked' %} image-text__inner--stacked{% endif %}">
      <div class="image-text__media">
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          class: 'image-text__image',
          loading: section.settings.image_loading
        %}
      </div>

      <div class="image-text__content">
        {% render 'section-heading',
          heading: section.settings.heading,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}

        {%- if section.settings.text != blank -%}
          <div class="section-text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          {% render 'button',
            label: section.settings.button_label,
            url: section.settings.button_url,
            style: section.settings.button_style
          %}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + Text",
  "tag": "section",
  "class": "section-image-text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Title"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" },
        { "value": "yellow", "label": "Yellow" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text (SEO)"
    },
    {
      "type": "select",
      "id": "image_loading",
      "label": "Image loading",
      "options": [
        { "value": "lazy", "label": "Lazy" },
        { "value": "eager", "label": "Eager" }
      ],
      "default": "lazy"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "side-by-side", "label": "Side by side" },
        { "value": "stacked", "label": "Stacked (centered)" }
      ],
      "default": "side-by-side"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font for this section",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "presets": [
    {
      "name": "Image + Text"
    }
  ]
}
{% endschema %}
