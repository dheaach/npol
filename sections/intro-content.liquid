{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'intro-content__inner' %}

<section class="intro-content section-spacing" aria-labelledby="intro-heading-{{ section.id }}">
  <div class="page-width">
    <div class="intro-content__inner{% if section.settings.layout == 'reverse' %} intro-content__inner--reverse{% endif %}">
      <div class="intro-content__media">
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          class: 'intro-content__image',
          loading: section.settings.image_loading
        %}
      </div>

      <div class="intro-content__text">
        {% render 'highlighted-heading',
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_after: section.settings.heading_after,
          heading_before_weight: section.settings.heading_before_weight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_after_weight: section.settings.heading_after_weight,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}

        {%- if section.settings.text != blank -%}
          <div class="section-text rte intro-content__description">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.list_items != blank -%}
          <ul class="intro-content__list">
            {%- assign items = section.settings.list_items | newline_to_br | split: '<br />' -%}
            {%- for item in items -%}
              {%- assign trimmed = item | strip -%}
              {%- if trimmed != blank -%}
                <li>{{ trimmed }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.text_after_list != blank -%}
          <div class="section-text rte intro-content__text-after">{{ section.settings.text_after_list }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .intro-content__description,
    #shopify-section-{{ section.id }} .intro-content__description p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .intro-content__description,
    #shopify-section-{{ section.id }} .intro-content__description p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .intro-content__description,
    #shopify-section-{{ section.id }} .intro-content__description p,
    #shopify-section-{{ section.id }} .intro-content__description a {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- endif -%}
  {%- if section.settings.list_font_size > 0 -%}
    #shopify-section-{{ section.id }} .intro-content__list,
    #shopify-section-{{ section.id }} .intro-content__list li {
      font-size: {{ section.settings.list_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.list_font_weight != blank and section.settings.list_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .intro-content__list,
    #shopify-section-{{ section.id }} .intro-content__list li {
      font-weight: {{ section.settings.list_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.list_font_color != blank -%}
    #shopify-section-{{ section.id }} .intro-content__list,
    #shopify-section-{{ section.id }} .intro-content__list li {
      color: {{ section.settings.list_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_size > 0 -%}
    #shopify-section-{{ section.id }} .intro-content__text-after,
    #shopify-section-{{ section.id }} .intro-content__text-after p {
      font-size: {{ section.settings.text_after_list_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_weight != blank and section.settings.text_after_list_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .intro-content__text-after,
    #shopify-section-{{ section.id }} .intro-content__text-after p {
      font-weight: {{ section.settings.text_after_list_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_color != blank -%}
    #shopify-section-{{ section.id }} .intro-content__text-after,
    #shopify-section-{{ section.id }} .intro-content__text-after p,
    #shopify-section-{{ section.id }} .intro-content__text-after a {
      color: {{ section.settings.text_after_list_font_color }} !important;
    }
  {%- endif -%}
</style>

