    display: block;
    object-fit: {{ section.settings.card_image_object_fit | default: 'contain' }};
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-image[style*="--learning-card-image-height"] .learning-cards-banner__card-image-img {
    height: var(--learning-card-image-height);
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-number {
    margin: 0 0 28px;
    font-family: var(--font-heading);
    font-size: {{ section.settings.card_number_font_size | default: 56 }}px;
    font-weight: 700;
    line-height: 1;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-title-group {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: 0;
    margin-bottom: {{ section.settings.card_spacing_title_group_text | default: 20 }}px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-dots--top {
    margin-bottom: {{ section.settings.card_spacing_divider_1_title | default: 12 }}px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-title + .learning-cards-banner__card-subtitle {
    margin-top: {{ section.settings.card_spacing_title_subtitle | default: 12 }}px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-title-group > .learning-cards-banner__card-dots--bottom {
    margin-top: {{ section.settings.card_spacing_before_divider_2 | default: 12 }}px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-dots {
    display: block;
    width: 100%;
    height: 8px;
    background-position: 0 50%;
    opacity: 0.85;
  }
  {%- liquid
    assign card_dots_1_size = section.settings.card_dots_1_size | default: section.settings.card_dots_size | default: 3
    assign card_dots_1_spacing = section.settings.card_dots_1_spacing | default: section.settings.card_dots_spacing | default: 10
    assign card_dots_2_size = section.settings.card_dots_2_size | default: section.settings.card_dots_size | default: 3
    assign card_dots_2_spacing = section.settings.card_dots_2_spacing | default: section.settings.card_dots_spacing | default: 10
  -%}
  #shopify-section-{{ section.id }} .learning-cards-banner__card-dots--top {
    background-image: radial-gradient(
      currentColor calc({{ card_dots_1_size }}px / 2),
      transparent calc({{ card_dots_1_size }}px / 2)
    );
    background-size: {{ card_dots_1_spacing }}px 8px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-dots--bottom {
    background-image: radial-gradient(
      currentColor calc({{ card_dots_2_size }}px / 2),
      transparent calc({{ card_dots_2_size }}px / 2)
    );
    background-size: {{ card_dots_2_spacing }}px 8px;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-title {
    margin: 0;
    color: inherit;
    font-weight: 600;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-subtitle {
    margin: 0;
    color: inherit;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-text {
    margin: 0;
    max-width: 100%;
    color: inherit;
    opacity: 0.95;
    flex: 1;
  }
