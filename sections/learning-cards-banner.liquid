      display: contents;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-mobile-full_width .learning-cards-banner__card {
      flex: 1 1 0;
      min-width: calc((100% - (var(--learning-cards-columns-mobile, 1) - 1) * var(--learning-cards-column-gap-mobile, 16px)) / var(--learning-cards-columns-mobile, 1));
      max-width: 100%;
