        font-size: {{ block.settings.badge_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.badge_width > 0 -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-badge {
        width: {{ block.settings.badge_width }}%;
