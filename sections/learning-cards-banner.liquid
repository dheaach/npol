      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-subtitle {
        font-size: {{ block.settings.subtitle_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.subtitle_font_weight != blank and block.settings.subtitle_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-subtitle {
        font-weight: {{ block.settings.subtitle_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.subtitle_font_color != blank -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-subtitle {
        color: {{ block.settings.subtitle_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-text {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-text {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_color != blank -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-text {
        color: {{ block.settings.text_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.number_font_size > 0 -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-number {
        font-size: {{ block.settings.number_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.number_font_color != blank -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-number {
        color: {{ block.settings.number_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.badge_font_size > 0 -%}
