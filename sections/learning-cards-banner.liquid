  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__cards {
      row-gap: var(--learning-cards-row-gap-tablet, 16px);
      column-gap: var(--learning-cards-column-gap-tablet, 16px);
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--has-badges {
      row-gap: calc(var(--learning-cards-row-gap-tablet, 16px) + var(--learning-card-badge-overhang, 28px) / 2);
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-full_width {
      flex-wrap: wrap;
      flex-direction: row;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-full_width .learning-cards-banner__row {
      display: contents;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-full_width .learning-cards-banner__card {
      flex: 1 1 0;
      min-width: calc((100% - (var(--learning-cards-columns-tablet, 2) - 1) * var(--learning-cards-column-gap-tablet, 16px)) / var(--learning-cards-columns-tablet, 2));
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-same_width {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: {{ card_row_align_tablet }};
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-same_width .learning-cards-banner__row {
      display: contents;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-tablet-same_width .learning-cards-banner__card {
      flex: 0 0 calc((100% - (var(--learning-cards-columns-tablet, 2) - 1) * var(--learning-cards-column-gap-tablet, 16px)) / var(--learning-cards-columns-tablet, 2));
      max-width: calc((100% - (var(--learning-cards-columns-tablet, 2) - 1) * var(--learning-cards-column-gap-tablet, 16px)) / var(--learning-cards-columns-tablet, 2));
      min-width: 0;
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__cards {
      flex-direction: column;
      flex-wrap: nowrap;
      row-gap: var(--learning-cards-row-gap, 16px);
      column-gap: 0;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--has-badges {
      row-gap: calc(var(--learning-cards-row-gap, 16px) + var(--learning-card-badge-overhang, 28px) / 2);
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-desktop-full_width .learning-cards-banner__row {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--learning-cards-column-gap, 16px);
      width: 100%;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-desktop-full_width .learning-cards-banner__row .learning-cards-banner__card {
      flex: 1 1 0;
      min-width: 0;
      max-width: none;
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-desktop-same_width .learning-cards-banner__row {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--learning-cards-column-gap, 16px);
      width: 100%;
      justify-content: {{ card_row_align_desktop }};
    }
    #shopify-section-{{ section.id }} .learning-cards-banner__cards--width-desktop-same_width .learning-cards-banner__card {
      flex: 0 0 calc((100% - (var(--learning-cards-columns) - 1) * var(--learning-cards-column-gap)) / var(--learning-cards-columns));
      max-width: calc((100% - (var(--learning-cards-columns) - 1) * var(--learning-cards-column-gap)) / var(--learning-cards-columns));
      min-width: 0;
    }
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-icon {
    width: var(--learning-card-icon-width, 40%);
    max-width: 100%;
    margin-bottom: {{ section.settings.card_icon_spacing | default: 20 }}px;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-icon[style*="--learning-card-icon-height"] {
    height: var(--learning-card-icon-height);
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-icon-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-icon[style*="--learning-card-icon-height"] .learning-cards-banner__card-icon-image {
    height: 100%;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-image {
    width: 100%;
    max-width: var(--learning-card-image-width, 120px);
    margin-bottom: {{ section.settings.card_icon_spacing | default: 20 }}px;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-image-img {
    width: 100%;
