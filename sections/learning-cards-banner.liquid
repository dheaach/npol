{% render 'section-font-vars', section: section %}

{%- liquid
  assign banner_bg_url = blank
  if section.settings.background_image != blank
    assign banner_bg_url = section.settings.background_image | image_url: width: 2400
  elsif settings.dark_quote_banner_background != blank
    assign banner_bg_url = settings.dark_quote_banner_background | image_url: width: 2400
  endif

  assign banner_bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign banner_bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif

  assign cards_columns = section.settings.cards_per_row | default: 4
  assign cards_columns_tablet = section.settings.cards_per_row_tablet | default: 2
  assign cards_columns_mobile = section.settings.cards_per_row_mobile | default: 1
  assign cards_column_gap = section.settings.column_gap | default: 0
  if cards_column_gap == 0
    assign cards_column_gap = 16
  endif
  assign cards_row_gap = section.settings.row_gap | default: 0
  if cards_row_gap == 0
    assign cards_row_gap = cards_column_gap
  endif
  assign cards_column_gap_tablet = section.settings.column_gap_tablet | default: 0
  if cards_column_gap_tablet == 0
    assign cards_column_gap_tablet = cards_column_gap
  endif
  assign cards_row_gap_tablet = section.settings.row_gap_tablet | default: 0
  if cards_row_gap_tablet == 0
    assign cards_row_gap_tablet = cards_row_gap
  endif
  assign cards_column_gap_mobile = section.settings.column_gap_mobile | default: 0
  if cards_column_gap_mobile == 0
    assign cards_column_gap_mobile = cards_column_gap_tablet
  endif
  assign cards_row_gap_mobile = section.settings.row_gap_mobile | default: 0
  if cards_row_gap_mobile == 0
    assign cards_row_gap_mobile = cards_row_gap_tablet
  endif

  assign card_row_width_desktop = section.settings.card_row_width_mode | default: 'same_width'
  assign card_row_width_tablet = section.settings.card_row_width_mode_tablet | default: 'inherit'
  if card_row_width_tablet == blank or card_row_width_tablet == 'inherit'
    assign card_row_width_tablet = card_row_width_desktop
  endif
  assign card_row_width_mobile = section.settings.card_row_width_mode_mobile | default: 'inherit'
  if card_row_width_mobile == blank or card_row_width_mobile == 'inherit'
    assign card_row_width_mobile = card_row_width_tablet
  endif

  assign card_row_align_desktop = section.settings.card_row_align | default: 'center'
  assign card_row_align_tablet = section.settings.card_row_align_tablet | default: 'inherit'
  if card_row_align_tablet == blank or card_row_align_tablet == 'inherit'
    assign card_row_align_tablet = card_row_align_desktop
  endif
  assign card_row_align_mobile = section.settings.card_row_align_mobile | default: 'inherit'
  if card_row_align_mobile == blank or card_row_align_mobile == 'inherit'
    assign card_row_align_mobile = card_row_align_tablet
  endif

  assign bg_type = section.settings.background_type | default: 'color'
  assign bg_color = section.settings.background_color | default: '#0A1D3C'
  assign grad_start = section.settings.gradient_color_start | default: '#0A1D3C'
  assign grad_end = section.settings.gradient_color_end | default: '#51ADA0'
  assign grad_start_pos = section.settings.gradient_start_position | default: 0
  assign grad_end_pos = section.settings.gradient_end_position | default: 100
  assign grad_type = section.settings.gradient_type | default: 'linear'

  if grad_type == 'radial'
    assign radial_pos = section.settings.gradient_radial_position | default: 'center center'
    assign grad_css = 'radial-gradient(circle at ' | append: radial_pos | append: ', ' | append: grad_start | append: ' ' | append: grad_start_pos | append: '%, ' | append: grad_end | append: ' ' | append: grad_end_pos | append: '%)'
  else
    assign linear_dir = section.settings.gradient_linear_direction | default: 'to bottom'
    if linear_dir == 'custom'
      assign angle = section.settings.gradient_linear_angle | default: 180
      assign grad_css = 'linear-gradient(' | append: angle | append: 'deg, ' | append: grad_start | append: ' ' | append: grad_start_pos | append: '%, ' | append: grad_end | append: ' ' | append: grad_end_pos | append: '%)'
    else
      assign grad_css = 'linear-gradient(' | append: linear_dir | append: ', ' | append: grad_start | append: ' ' | append: grad_start_pos | append: '%, ' | append: grad_end | append: ' ' | append: grad_end_pos | append: '%)'
    endif
  endif
-%}

<section
  class="learning-cards-banner"
  aria-labelledby="learning-cards-heading-{{ section.id }}"
>
  {%- liquid
    assign bg_flip_desktop = section.settings.background_flip | default: 'none'
    assign bg_flip_mobile = section.settings.background_flip_mobile | default: 'none'
  -%}
  {%- if banner_bg_mobile_url != blank -%}
    <div
      class="learning-cards-banner__bg learning-cards-banner__bg--mobile{% if bg_flip_mobile != 'none' %} learning-cards-banner__bg--flip-{{ bg_flip_mobile }}{% endif %}"
      style="background-image: url({{ banner_bg_mobile_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}
  {%- if banner_bg_url != blank -%}
    <div
      class="learning-cards-banner__bg{% if banner_bg_mobile_url != blank %} learning-cards-banner__bg--desktop{% endif %}{% if bg_flip_desktop != 'none' %} learning-cards-banner__bg--flip-{{ bg_flip_desktop }}{% endif %}"
      style="background-image: url({{ banner_bg_url }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="learning-cards-banner__content section-spacing">
    <div class="page-width text-center">
      <div
        class="learning-cards-banner__header{% if section.settings.heading != blank %} learning-cards-banner__header--single{% endif %}"
        id="learning-cards-heading-{{ section.id }}"
      >
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_weight: section.settings.heading_weight,
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_after: section.settings.heading_after,
          heading_before_weight: section.settings.heading_before_weight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_after_weight: section.settings.heading_after_weight,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>

      {%- if section.settings.subtext != blank -%}
        <p class="learning-cards-banner__subtext section-text">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.subtext_2 != blank -%}
        <p class="learning-cards-banner__subtext learning-cards-banner__subtext--secondary section-text">{{ section.settings.subtext_2 }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        {%- liquid
          assign card_count = section.blocks.size
          assign cards_max_cols = cards_columns
          assign any_card_badge = false
          for block in section.blocks
            if block.settings.show_badge and block.settings.badge_text != blank
              assign any_card_badge = true
              break
            endif
          endfor
          if card_count <= cards_max_cols
            assign cards_row_count = 1
            assign cards_row_base = card_count
            assign cards_row_extra = 0
          else
            assign cards_row_count = card_count | plus: cards_max_cols | minus: 1 | divided_by: cards_max_cols
            assign cards_row_base = card_count | divided_by: cards_row_count
            assign cards_row_extra = card_count | modulo: cards_row_count
          endif
        -%}
        <div
          class="learning-cards-banner__cards learning-cards-banner__cards--count-{{ card_count }} learning-cards-banner__cards--width-mobile-{{ card_row_width_mobile }} learning-cards-banner__cards--width-tablet-{{ card_row_width_tablet }} learning-cards-banner__cards--width-desktop-{{ card_row_width_desktop }}{% if any_card_badge %} learning-cards-banner__cards--has-badges{% endif %}"
          style="
            --learning-cards-columns: {{ cards_columns }};
            --learning-cards-columns-tablet: {{ cards_columns_tablet }};
            --learning-cards-columns-mobile: {{ cards_columns_mobile }};
            --learning-cards-column-gap: {{ cards_column_gap }}px;
            --learning-cards-row-gap: {{ cards_row_gap }}px;
            --learning-cards-column-gap-tablet: {{ cards_column_gap_tablet }}px;
            --learning-cards-row-gap-tablet: {{ cards_row_gap_tablet }}px;
            --learning-cards-column-gap-mobile: {{ cards_column_gap_mobile }}px;
            --learning-cards-row-gap-mobile: {{ cards_row_gap_mobile }}px;
            {%- if any_card_badge -%}
            --learning-card-badge-overhang: {{ section.settings.card_badge_overflow_space | default: 28 }}px;
            {%- endif -%}
          "
        >
          {%- assign block_idx = 0 -%}
          {%- for row_num in (1..cards_row_count) -%}
            {%- liquid
              assign row_size = cards_row_base
              if row_num <= cards_row_extra
                assign row_size = cards_row_base | plus: 1
              endif
            -%}
            <div class="learning-cards-banner__row" style="--learning-cards-row-cols: {{ row_size }};">
              {%- for _slot in (1..row_size) -%}
                {%- assign block = section.blocks[block_idx] -%}
            {%- liquid
              assign icon_w = block.settings.icon_width | default: 0
              if icon_w == 0
                assign icon_w = block.settings.icon_size | default: 0
              endif
              if icon_w == 0
                assign icon_w = section.settings.card_icon_width | default: section.settings.card_icon_size | default: 40
              endif
              if icon_w > 100
                assign icon_w = 100
              endif
              assign icon_h = block.settings.icon_height | default: 0
              if icon_h == 0
                assign icon_h = section.settings.card_icon_height | default: 0
              endif
              assign icon_src_w = 400

              assign img_w = block.settings.image_width | default: 0
              if img_w == 0
                assign img_w = section.settings.card_image_width | default: 120
              endif
              assign img_h = block.settings.image_height | default: 0
              if img_h == 0
                assign img_h = section.settings.card_image_height | default: 0
              endif
              assign img_fit = block.settings.image_object_fit | default: 'inherit'
              if img_fit == blank or img_fit == 'inherit'
                assign img_fit = section.settings.card_image_object_fit | default: 'contain'
              endif
            -%}
            <article
              id="learning-card-{{ block.id }}"
              class="learning-cards-banner__card{% if block.settings.show_badge and block.settings.badge_text != blank %} learning-cards-banner__card--has-badge{% endif %}"
              style="background-color: {{ block.settings.card_background_color | default: '#51ADA0' }};"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.show_badge and block.settings.badge_text != blank -%}
                {%- liquid
                  assign badge_bg_type = block.settings.badge_background_type | default: 'color'
                  assign badge_bg_color = block.settings.badge_background_color | default: '#F5D547'
                  assign badge_use_image = false
                  if badge_bg_type == 'image' and block.settings.badge_background_image != blank
                    assign badge_use_image = true
                  endif
                -%}
                <span
                  class="learning-cards-banner__card-badge learning-cards-banner__card-badge--{% if badge_use_image %}image{% else %}color{% endif %}"
                  style="background-color: {{ badge_bg_color }};"
                >
                  {%- if badge_use_image -%}
                    <span class="learning-cards-banner__card-badge-bg" aria-hidden="true">
                      {% render 'responsive-image',
                        image: block.settings.badge_background_image,
                        alt: '',
                        class: 'learning-cards-banner__card-badge-bg-img',
                        width: 600
                      %}
                    </span>
                  {%- endif -%}
                  <span class="learning-cards-banner__card-badge-text">{{ block.settings.badge_text }}</span>
                </span>
              {%- endif -%}

              {%- if block.settings.icon != blank -%}
                <div
                  class="learning-cards-banner__card-icon"
                  style="--learning-card-icon-width: {{ icon_w }}%;{% if icon_h > 0 %} --learning-card-icon-height: {{ icon_h }}px;{% endif %}"
                >
                  {% render 'responsive-image',
                    image: block.settings.icon,
                    alt: block.settings.icon_alt,
                    class: 'learning-cards-banner__card-icon-image',
                    width: icon_src_w
                  %}
                </div>
              {%- endif -%}

              {%- if block.settings.image != blank -%}
                <div
                  class="learning-cards-banner__card-image"
                  style="--learning-card-image-width: {{ img_w }}px;{% if img_h > 0 %} --learning-card-image-height: {{ img_h }}px;{% endif %}"
                >
                  {% render 'responsive-image',
                    image: block.settings.image,
                    alt: block.settings.image_alt,
                    class: 'learning-cards-banner__card-image-img',
                    width: img_w | times: 2
                  %}
                </div>
              {%- endif -%}

              {%- if block.settings.number != blank -%}
                <p class="learning-cards-banner__card-number">{{ block.settings.number }}</p>
              {%- endif -%}

              {%- liquid
                assign show_divider_1 = section.settings.show_divider_1 | default: true
                assign show_divider_2 = section.settings.show_divider_2 | default: true
                if block.settings.show_divider_1 == false
                  assign show_divider_1 = false
                endif
                if block.settings.show_divider_2 == false
                  assign show_divider_2 = false
                endif
              -%}

              {%- if block.settings.title != blank or block.settings.subtitle != blank -%}
                <div class="learning-cards-banner__card-title-group">
                  {%- if show_divider_1 -%}
                    <span class="learning-cards-banner__card-dots learning-cards-banner__card-dots--top" aria-hidden="true"></span>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <h3 class="learning-cards-banner__card-title section-heading section-heading--h3">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <p class="learning-cards-banner__card-subtitle section-text">{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                  {%- if show_divider_2 -%}
                    <span class="learning-cards-banner__card-dots learning-cards-banner__card-dots--bottom" aria-hidden="true"></span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="learning-cards-banner__card-text section-text">{{ block.settings.text }}</p>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <div class="learning-cards-banner__card-cta">
                  {% render 'button',
                    label: block.settings.button_label,
                    url: block.settings.button_url,
                    style: block.settings.button_style | default: 'yellow'
                  %}
                </div>
              {%- endif -%}
            </article>
                {%- assign block_idx = block_idx | plus: 1 -%}
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.learning-cards-banner', pad_y: '.learning-cards-banner__content', pad_x: '.page-width' %}

  {%- if bg_type == 'gradient' -%}
    #shopify-section-{{ section.id }} {
      background: {{ grad_css }};
    }
  {%- else -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ bg_color }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .learning-cards-banner {
    position: relative;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__bg {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__content {
    position: relative;
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .section-heading {
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
  }
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#51ADA0' }} !important;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__header--single .section-heading {
    max-width: {{ section.settings.heading_max_width | default: 900 }}px;
    margin-left: auto;
    margin-right: auto;
  }
  {%- liquid
    assign subtext_color = section.settings.subtext_color
    if subtext_color == blank
      assign subtext_color = section.settings.text_color
    endif
    if subtext_color == blank
      assign subtext_color = '#FFFFFF'
    endif
    assign subtext_2_color = section.settings.subtext_2_color
    if subtext_2_color == blank
      assign subtext_2_color = subtext_color
    endif
  -%}
  #shopify-section-{{ section.id }} .learning-cards-banner__subtext {
    color: {{ subtext_color }};
    margin-top: 16px;
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__subtext--secondary {
    color: {{ subtext_2_color }};
    margin-top: 12px;
  }
  {%- if section.settings.subtext_font_size > 0 -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext:not(.learning-cards-banner__subtext--secondary) {
      font-size: {{ section.settings.subtext_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_weight != blank and section.settings.subtext_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext:not(.learning-cards-banner__subtext--secondary) {
      font-weight: {{ section.settings.subtext_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_max_width > 0 -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext:not(.learning-cards-banner__subtext--secondary) {
      max-width: {{ section.settings.subtext_max_width }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_font_size > 0 -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext--secondary {
      font-size: {{ section.settings.subtext_2_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_font_weight != blank and section.settings.subtext_2_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext--secondary {
      font-weight: {{ section.settings.subtext_2_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_max_width > 0 -%}
    #shopify-section-{{ section.id }} .learning-cards-banner__subtext--secondary {
      max-width: {{ section.settings.subtext_2_max_width }}px;
    }
  {%- endif -%}

  {%- liquid
    assign legacy_bg_mode = section.settings.background_size | default: 'fit_width'
    if legacy_bg_mode == '100% auto' or legacy_bg_mode == 'contain'
      assign legacy_bg_mode = 'fit_width'
    elsif legacy_bg_mode == '100% 100%'
      assign legacy_bg_mode = 'stretch'
    endif
    assign bg_mode_mobile = section.settings.background_size_mobile | default: 'fit_width'
    assign bg_mode_tablet = section.settings.background_size_tablet | default: 'fit_width'
    assign bg_mode_laptop = section.settings.background_size_laptop | default: legacy_bg_mode
    assign bg_mode_desktop = section.settings.background_size_desktop | default: 'fit_width'
    assign bg_mode_4k = section.settings.background_size_4k | default: 'fit_width'
    assign bg_position = section.settings.background_position | default: 'center center'
  -%}
  {%- capture bg_size_mobile -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_mobile %}{%- endcapture -%}
  {%- capture bg_size_tablet -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_tablet %}{%- endcapture -%}
  {%- capture bg_size_laptop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_laptop %}{%- endcapture -%}
  {%- capture bg_size_desktop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_desktop %}{%- endcapture -%}
  {%- capture bg_size_4k -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_4k %}{%- endcapture -%}
  #shopify-section-{{ section.id }} .learning-cards-banner__bg {
    background-size: {{ bg_size_mobile | strip }};
    background-position: {{ bg_position }};
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__bg--flip-horizontal {
    transform: scaleX(-1);
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__bg--flip-vertical {
    transform: scaleY(-1);
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__bg--flip-both {
    transform: scale(-1, -1);
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__bg {
      background-size: {{ bg_size_tablet | strip }};
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__bg {
      background-size: {{ bg_size_laptop | strip }};
    }
  }
  @media screen and (min-width: 1441px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__bg {
      background-size: {{ bg_size_desktop | strip }};
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .learning-cards-banner__bg {
      background-size: {{ bg_size_4k | strip }};
    }
  }
  {%- if banner_bg_mobile_url != blank and banner_bg_url != blank -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .learning-cards-banner__bg--desktop {
        display: none;
      }
    }
  {%- endif -%}
  {%- if banner_bg_mobile_url != blank -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .learning-cards-banner__bg--mobile {
        display: none;
      }
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .learning-cards-banner__cards {
    display: flex;
    row-gap: var(--learning-cards-row-gap-mobile, 16px);
    column-gap: var(--learning-cards-column-gap-mobile, 16px);
    margin-top: {{ section.settings.cards_margin_top | default: 48 }}px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__cards--has-badges {
    padding-top: calc(var(--learning-card-badge-overhang, 28px) / 2);
    overflow: visible;
    row-gap: calc(var(--learning-cards-row-gap-mobile, 16px) + var(--learning-card-badge-overhang, 28px) / 2);
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__cards--has-badges .learning-cards-banner__row {
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card--has-badge {
    padding-top: calc(40px + var(--learning-card-badge-overhang, 28px) / 2);
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card--has-badge .learning-cards-banner__card-badge {
    z-index: 3;
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card {
    position: relative;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 32px;
    min-height: {{ section.settings.card_min_height | default: 280 }}px;
    color: {{ section.settings.card_text_color | default: '#FFFFFF' }};
  }
  #shopify-section-{{ section.id }} .learning-cards-banner__card-badge {
    position: absolute;
    top: 0;
    left: 50%;
    z-index: 2;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    {%- if section.settings.card_badge_width > 0 -%}
      width: {{ section.settings.card_badge_width }}%;
      max-width: {{ section.settings.card_badge_width }}%;
    {%- else -%}
      max-width: calc(100% + 32px);
