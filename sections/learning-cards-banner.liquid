    {%- assign block_img_fit = block.settings.image_object_fit | default: 'inherit' -%}
    {%- if block_img_fit != blank and block_img_fit != 'inherit' -%}
      #shopify-section-{{ section.id }} #learning-card-{{ block.id }} .learning-cards-banner__card-image-img {
        object-fit: {{ block_img_fit }};
      }
    {%- endif -%}
  {%- endfor -%}
