{% render 'section-font-vars', section: section %}

{%- liquid
  assign bar_pad_y = section.settings.bar_padding_y | default: 32
  assign bar_pad_x = section.settings.bar_padding_x | default: 40
  assign icon_w = section.settings.icon_width | default: 80
  assign title_col = section.settings.title_column_width | default: 28
  assign header_gap = section.settings.header_spacing | default: 48
  assign cta_gap = section.settings.cta_spacing_top | default: 48
  assign bar_text_color = section.settings.bar_text_color | default: '#FFFFFF'

  assign has_bg_desktop = false
  assign bg_url = blank
  if section.settings.background_image != blank
    assign has_bg_desktop = true
    assign bg_url = section.settings.background_image | image_url: width: 3840
  endif

  assign has_bg_tablet = false
  assign bg_tablet_url = blank
  if section.settings.background_image_tablet != blank
    assign has_bg_tablet = true
    assign bg_tablet_url = section.settings.background_image_tablet | image_url: width: 2400
  endif

  assign has_bg_mobile = false
  assign bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign has_bg_mobile = true
    assign bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif

  assign has_bg_4k = false
  assign bg_4k_url = blank
  if section.settings.background_image_4k != blank
    assign has_bg_4k = true
    assign bg_4k_url = section.settings.background_image_4k | image_url: width: 5120
  endif

  assign bg_layered = false
  if has_bg_mobile or has_bg_tablet or has_bg_4k
    assign bg_layered = true
  endif
-%}

{%- if has_bg_mobile -%}
  <div
    class="learning-structures__bg learning-structures__bg--mobile"
    style="background-image: url({{ bg_mobile_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}
{%- if has_bg_tablet -%}
  <div
    class="learning-structures__bg learning-structures__bg--tablet"
    style="background-image: url({{ bg_tablet_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}
{%- if has_bg_desktop -%}
  <div
    class="learning-structures__bg{% if bg_layered %} learning-structures__bg--desktop{% endif %}"
    style="background-image: url({{ bg_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}
{%- if has_bg_4k -%}
  <div
    class="learning-structures__bg learning-structures__bg--4k"
    style="background-image: url({{ bg_4k_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}

<section
  class="learning-structures section-spacing"
  aria-labelledby="learning-structures-heading-{{ section.id }}"
>
  <div class="page-width">
    <div class="learning-structures__inner">
      <header class="learning-structures__header text-center">
        <div id="learning-structures-heading-{{ section.id }}">
          {%- liquid
            assign ia_heading_font_color = section.settings.heading_font_color
            if ia_heading_font_color == blank
              assign ia_heading_font_color = section.settings.heading_color
            endif
            assign ia_heading_before_color = section.settings.heading_before_color
            if ia_heading_before_color == blank
              assign ia_heading_before_color = section.settings.heading_color
            endif
          -%}
          {% render 'highlighted-heading',
            heading: section.settings.heading,
            heading_font_size: section.settings.heading_font_size,
            heading_weight: section.settings.heading_weight,
            heading_font_color: ia_heading_font_color,
            heading_before: section.settings.heading_before,
            heading_before_weight: section.settings.heading_before_weight,
            heading_before_font_size: section.settings.heading_before_font_size,
            heading_before_color: ia_heading_before_color,
            heading_highlight: section.settings.heading_highlight,
            heading_highlight_weight: section.settings.heading_highlight_weight,
            heading_highlight_font_size: section.settings.heading_highlight_font_size,
            heading_after: section.settings.heading_after,
            heading_after_weight: section.settings.heading_after_weight,
            heading_after_font_size: section.settings.heading_after_font_size,
            heading_after_color: section.settings.heading_after_color,
            heading_tag: section.settings.heading_tag,
            heading_size: section.settings.heading_tag,
            highlight_color: section.settings.highlight_color
          %}
        </div>
        {%- if section.settings.subtext != blank -%}
          <p class="section-text learning-structures__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
        {%- if section.settings.subtext_2 != blank -%}
          <p class="section-text learning-structures__subtext learning-structures__subtext--secondary">{{ section.settings.subtext_2 }}</p>
        {%- endif -%}
      </header>

      {%- if section.blocks.size > 0 -%}
        <div class="learning-structures__bars">
          {%- for block in section.blocks -%}
            <article
              class="learning-structures__bar"
              id="learning-structures-bar-{{ block.id }}"
              style="background-color: {{ block.settings.bar_color | default: '#51ADA0' }};"
              {{ block.shopify_attributes }}
            >
              <div class="learning-structures__bar-inner">
                <div class="learning-structures__icon">
                  {%- if block.settings.icon != blank -%}
                    {% render 'responsive-image',
                      image: block.settings.icon,
                      alt: block.settings.icon_alt,
                      class: 'learning-structures__icon-image',
                      width: icon_w | times: 2
                    %}
                  {%- else -%}
                    <div class="learning-structures__icon-placeholder" role="img" aria-label="{{ block.settings.icon_alt | default: 'Feature icon' | escape }}">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="section-heading section-heading--h3 learning-structures__bar-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="section-text rte learning-structures__bar-text">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="learning-structures__cta">
          {% render 'button',
            label: section.settings.button_label,
            url: section.settings.button_url,
            style: section.settings.button_style | default: 'yellow'
          %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.learning-structures', pad_x: '.page-width' %}
  {% render 'section-spacing-gap', section: section, selector: '.learning-structures__bars', gap_id: 'bars_gap', stack_breakpoint: '0' %}
  {% render 'section-spacing-gap', section: section, selector: '.learning-structures__bar-inner', gap_id: 'bar_inner_gap', stack_breakpoint: '0' %}

  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#FFFFFF' }};
    position: relative;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .learning-structures__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-repeat: no-repeat;
  }
  #shopify-section-{{ section.id }} .learning-structures {
    position: relative;
    z-index: 1;
  }
  {%- liquid
    assign bg_pos_base = section.settings.background_position | default: 'center center'
    assign bg_pos_4k = section.settings.background_position_4k | default: bg_pos_base
    assign bg_mode_mobile = section.settings.background_size_mobile | default: section.settings.background_size | default: 'fit_width'
    assign bg_mode_tablet = section.settings.background_size_tablet | default: section.settings.background_size | default: 'fit_width'
    assign bg_mode_desktop = section.settings.background_size | default: 'fit_width'
    assign bg_mode_4k = section.settings.background_size_4k | default: section.settings.background_size | default: 'fit_width'
  -%}
  {%- capture bg_size_mobile -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_mobile %}{%- endcapture -%}
  {%- capture bg_size_tablet -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_tablet %}{%- endcapture -%}
  {%- capture bg_size_desktop -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_desktop %}{%- endcapture -%}
  {%- capture bg_size_4k -%}{% render 'dark-quote-banner-bg-size', mode: bg_mode_4k %}{%- endcapture -%}
  #shopify-section-{{ section.id }} .learning-structures__bg {
    background-size: {{ bg_size_mobile | strip }};
    background-position: {{ bg_pos_base }};
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .learning-structures__bg {
      background-size: {{ bg_size_tablet | strip }};
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .learning-structures__bg {
      background-size: {{ bg_size_desktop | strip }};
    }
  }
  @media screen and (min-width: 2560px) {
    #shopify-section-{{ section.id }} .learning-structures__bg {
      background-size: {{ bg_size_4k | strip }};
      background-position: {{ bg_pos_4k }};
    }
  }
  {%- if has_bg_mobile -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--mobile {
        display: none;
      }
    }
  {%- endif -%}
  {%- if has_bg_mobile -%}
    {%- if has_bg_desktop or has_bg_tablet or has_bg_4k -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--desktop,
      #shopify-section-{{ section.id }} .learning-structures__bg--tablet,
      #shopify-section-{{ section.id }} .learning-structures__bg--4k {
        display: none;
      }
    }
    {%- endif -%}
  {%- endif -%}
  {%- if has_bg_tablet and has_bg_desktop -%}
    @media screen and (min-width: 768px) and (max-width: 1023px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--desktop {
        display: none;
      }
    }
    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--tablet {
        display: none;
      }
    }
  {%- endif -%}
  {%- if has_bg_4k -%}
    @media screen and (max-width: 2559px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--4k {
        display: none;
      }
    }
  {%- endif -%}
  {%- if has_bg_4k and has_bg_desktop -%}
    @media screen and (min-width: 2560px) {
      #shopify-section-{{ section.id }} .learning-structures__bg--desktop {
        display: none;
      }
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .learning-structures__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: {{ section.settings.content_max_width | default: 1200 }}px;
    margin-inline: auto;
  }
  #shopify-section-{{ section.id }} .learning-structures__header {
    margin-bottom: {{ header_gap }}px;
  }
  #shopify-section-{{ section.id }} .learning-structures__subtext {
    max-width: {{ section.settings.subtext_max_width | default: 900 }}px;
    margin-inline: auto;
    margin-top: 1rem;
  }
  #shopify-section-{{ section.id }} .learning-structures__subtext--secondary {
    margin-top: 0.75rem;
  }
  #shopify-section-{{ section.id }} .learning-structures__bars {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #shopify-section-{{ section.id }} .learning-structures__bar {
    color: {{ bar_text_color }};
  }
  #shopify-section-{{ section.id }} .learning-structures__bar-inner {
    display: grid;
    grid-template-columns: {{ icon_w }}px minmax(140px, {{ title_col }}%) minmax(0, 1fr);
    align-items: center;
    padding: {{ bar_pad_y }}px {{ bar_pad_x }}px;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .learning-structures__icon-image,
  #shopify-section-{{ section.id }} .learning-structures__icon-placeholder {
    width: {{ icon_w }}px;
    max-width: 100%;
    height: auto;
    display: block;
  }
  #shopify-section-{{ section.id }} .learning-structures__icon-placeholder {
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 4px;
  }
  #shopify-section-{{ section.id }} .learning-structures__icon-placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.5;
  }
  #shopify-section-{{ section.id }} .learning-structures__bar-title {
    margin: 0;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .learning-structures__bar-text,
  #shopify-section-{{ section.id }} .learning-structures__bar-text p {
    color: inherit;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .learning-structures__cta {
    margin-top: {{ cta_gap }}px;
    text-align: center;
  }

  {%- liquid
    assign ia_heading_base_color = section.settings.heading_before_color
    if ia_heading_base_color == blank
      assign ia_heading_base_color = section.settings.heading_color
    endif
  -%}
  {%- if ia_heading_base_color != blank -%}
    #shopify-section-{{ section.id }} #learning-structures-heading-{{ section.id }} .section-heading {
      color: {{ ia_heading_base_color }};
    }
    #shopify-section-{{ section.id }} #learning-structures-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#51ADA0' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #learning-structures-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_size > 0 -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext:not(.learning-structures__subtext--secondary) {
      font-size: {{ section.settings.subtext_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_weight != blank and section.settings.subtext_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext:not(.learning-structures__subtext--secondary) {
      font-weight: {{ section.settings.subtext_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_color != blank -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext:not(.learning-structures__subtext--secondary) {
      color: {{ section.settings.subtext_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_font_size > 0 -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext--secondary {
      font-size: {{ section.settings.subtext_2_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_font_weight != blank and section.settings.subtext_2_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext--secondary {
      font-weight: {{ section.settings.subtext_2_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_font_color != blank -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext--secondary {
      color: {{ section.settings.subtext_2_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_2_max_width > 0 -%}
    #shopify-section-{{ section.id }} .learning-structures__subtext--secondary {
      max-width: {{ section.settings.subtext_2_max_width }}px;
    }
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text,
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text p {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text,
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text p {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_color != blank -%}
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text,
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text p,
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text li,
      #shopify-section-{{ section.id }} #learning-structures-bar-{{ block.id }} .learning-structures__bar-text a {
        color: {{ block.settings.text_font_color }} !important;
      }
    {%- endif -%}
  {%- endfor -%}

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .learning-structures__bar-inner {
      grid-template-columns: 1fr;
      text-align: left;
    }
    #shopify-section-{{ section.id }} .learning-structures__icon-image,
    #shopify-section-{{ section.id }} .learning-structures__icon-placeholder {
      margin-bottom: 4px;
    }
  }
  {%- if section.settings.bar_padding_y_tablet > 0 or section.settings.bar_padding_x_tablet > 0 -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .learning-structures__bar-inner {
      {%- if section.settings.bar_padding_y_tablet > 0 -%}
      padding-top: {{ section.settings.bar_padding_y_tablet }}px;
      padding-bottom: {{ section.settings.bar_padding_y_tablet }}px;
      {%- endif -%}
      {%- if section.settings.bar_padding_x_tablet > 0 -%}
      padding-left: {{ section.settings.bar_padding_x_tablet }}px;
      padding-right: {{ section.settings.bar_padding_x_tablet }}px;
      {%- endif -%}
    }
  }
  {%- endif -%}
  {%- if section.settings.bar_padding_y_mobile > 0 or section.settings.bar_padding_x_mobile > 0 -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .learning-structures__bar-inner {
      {%- if section.settings.bar_padding_y_mobile > 0 -%}
      padding-top: {{ section.settings.bar_padding_y_mobile }}px;
      padding-bottom: {{ section.settings.bar_padding_y_mobile }}px;
      {%- endif -%}
      {%- if section.settings.bar_padding_x_mobile > 0 -%}
      padding-left: {{ section.settings.bar_padding_x_mobile }}px;
      padding-right: {{ section.settings.bar_padding_x_mobile }}px;
      {%- endif -%}
    }
  }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "Learning Structures",
  "tag": "section",
  "class": "section-learning-structures",
  "settings": [
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback color",
      "default": "#FFFFFF",
      "info": "Shown behind the image or when no image is uploaded."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image — desktop (1024px–2559px)",
      "info": "Upload the full section background artwork. Recommended width 2560px or larger."
    },
    {
      "type": "image_picker",
      "id": "background_image_4k",
      "label": "Background image — 4K (2560px and up)",
      "info": "Optional. High-resolution artwork for large displays. If empty, the desktop image is used on 4K screens."
    },
    {
      "type": "image_picker",
      "id": "background_image_tablet",
      "label": "Background image — tablet (768px–1023px)",
      "info": "Optional. If empty, the desktop image is used on tablet when set."
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image — mobile (767px and below)",
      "info": "Optional. If empty, the tablet or desktop image is used on phones."
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top center" },
        { "value": "left top", "label": "Top left" },
        { "value": "right top", "label": "Top right" },
        { "value": "left center", "label": "Center left" },
        { "value": "right center", "label": "Center right" },
        { "value": "center bottom", "label": "Bottom center" },
        { "value": "left bottom", "label": "Bottom left" },
        { "value": "right bottom", "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background fit — desktop (1024px–2559px)",
      "options": [
        { "value": "fit_width", "label": "Fit width (squeeze)" },
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (fit in box)" },
        { "value": "stretch", "label": "Stretch" }
      ],
      "default": "fit_width"
    },
    {
      "type": "select",
      "id": "background_size_tablet",
      "label": "Background fit — tablet (768px–1023px)",
      "options": [
        { "value": "fit_width", "label": "Fit width (squeeze)" },
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (fit in box)" },
        { "value": "stretch", "label": "Stretch" }
      ],
      "default": "fit_width"
    },
    {
      "type": "select",
      "id": "background_size_mobile",
      "label": "Background fit — mobile (767px and below)",
      "options": [
        { "value": "fit_width", "label": "Fit width (squeeze)" },
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (fit in box)" },
        { "value": "stretch", "label": "Stretch" }
      ],
      "default": "fit_width"
    },
    {
      "type": "select",
      "id": "background_size_4k",
      "label": "Background fit — 4K (2560px and up)",
      "options": [
        { "value": "fit_width", "label": "Fit width (squeeze)" },
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (fit in box)" },
        { "value": "stretch", "label": "Stretch" }
      ],
      "default": "fit_width"
    },
    {
      "type": "select",
      "id": "background_position_4k",
      "label": "Background position — 4K (2560px and up)",
      "options": [
        { "value": "", "label": "Use default" },
