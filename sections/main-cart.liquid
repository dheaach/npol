<section class="main-cart section-spacing">
  <div class="page-width">
    <h1 class="section-heading section-heading--h1">{{ 'cart.general.title' | t | default: 'Cart' }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" style="margin-top: 32px;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid rgba(10,29,60,0.1);">
              <th style="text-align: left; padding: 12px 0;">Product</th>
              <th style="text-align: center; padding: 12px 0;">Qty</th>
              <th style="text-align: right; padding: 12px 0;">Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr style="border-bottom: 1px solid rgba(10,29,60,0.08);">
                <td style="padding: 16px 0;">
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                </td>
                <td style="text-align: center; padding: 16px 0;">
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-index="{{ forloop.index }}" style="width: 64px; padding: 8px; text-align: center;">
                </td>
                <td style="text-align: right; padding: 16px 0;">{{ item.line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
        <p class="section-text" style="margin: 24px 0; text-align: right; font-weight: 700;">
          Subtotal: {{ cart.total_price | money }}
        </p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <button type="submit" name="update" class="btn btn--outline">Update cart</button>
          <button type="submit" name="checkout" class="btn btn--yellow">Checkout</button>
        </div>
      </form>
    {%- else -%}
      <p class="section-text" style="margin: 24px 0;">Your cart is empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue shopping</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart",
  "settings": []
}
{% endschema %}
