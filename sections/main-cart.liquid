<section class="main-cart section-spacing">
  <div
    class="page-width"
    data-section-id="{{ section.id }}"
    data-section-type="main-cart"
    data-ajax-enabled="{{ section.settings.cart_ajax_enable }}"
  >
    <div{% if cart.item_count == 0 %} class="hide"{% endif %} data-cart-wrapper>
      <div class="main-cart__header" style="display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 16px;">
        <h1 class="section-heading section-heading--h1">{{ 'cart.general.title' | t | default: 'Cart' }}</h1>
        <a href="{{ routes.all_products_collection_url }}" class="section-text" style="text-decoration: underline;">
          {{ 'cart.general.continue_shopping' | t | default: 'Continue shopping' }}
        </a>
      </div>

      <form action="{{ routes.cart_url }}" method="post" novalidate class="main-cart__form" style="margin-top: 32px;">
        <table class="main-cart__table" style="width: 100%; border-collapse: collapse;">
          <colgroup>
            <col class="main-cart__col-product">
            <col class="main-cart__col-price">
            <col class="main-cart__col-qty main-cart__col-qty-desktop">
            <col class="main-cart__col-total main-cart__col-total-desktop">
          </colgroup>
          <thead>
            <tr style="border-bottom: 2px solid rgba(10,29,60,0.1);">
              <th scope="col" class="main-cart__col-product" style="text-align: left; padding: 12px 0;">{{ 'cart.label.product' | t | default: 'Product' }}</th>
              <th scope="col" class="main-cart__col-price" style="text-align: right; padding: 12px 0;">{{ 'cart.label.price' | t | default: 'Price' }}</th>
              <th scope="col" class="main-cart__col-qty main-cart__col-qty-desktop" style="text-align: center; padding: 12px 0;">{{ 'cart.label.quantity' | t | default: 'Qty' }}</th>
              <th scope="col" class="main-cart__col-total main-cart__col-total-desktop" style="text-align: right; padding: 12px 0;">{{ 'cart.label.total' | t | default: 'Total' }}</th>
            </tr>
          </thead>
          <tbody data-cart-line-items>
            {%- for item in cart.items -%}
              {%- liquid
                assign has_discount = false
                if item.original_price != item.final_price
                  assign has_discount = true
                endif

                assign variant_options = 'template ' | split: ' '
                if item.product.has_only_default_variant != true
                  assign variant_options = item.options_with_values
                endif

                assign property_size = item.properties | size
                assign properties = 'template ' | split: ' '
                if property_size > 0
                  assign properties = item.properties
                endif

                assign item_discounts = 'template ' | split: ' '
                if item.line_level_discount_allocations != blank
                  assign item_discounts = item.line_level_discount_allocations
                endif
              -%}
              <tr
                class="main-cart__row"
                style="border-bottom: 1px solid rgba(10,29,60,0.08);"
                data-cart-item
                data-cart-item-key="{{ item.key }}"
                data-cart-item-url="{{ item.url }}"
                data-cart-item-title="{{ item.title }}"
                data-cart-item-index="{{ forloop.index }}"
                data-cart-item-quantity="{{ item.quantity }}"
              >
                <td class="main-cart__col-product" style="padding: 16px 0;">
                  <div class="main-cart__product" style="display: flex; gap: 16px; align-items: flex-start;">
                    <div class="main-cart__image-wrap" style="flex-shrink: 0; width: 80px;">
                      {%- if item.image != blank -%}
                        <img
                          class="main-cart__image"
                          src="{{ item.image | image_url: width: 190 }}"
                          alt="{{ item.image.alt | escape }}"
                          width="80"
                          height="80"
                          loading="lazy"
                          style="width: 80px; height: 80px; object-fit: cover; display: block;"
                          data-cart-item-image
                        >
                      {%- endif -%}
                    </div>
                    <div>
                      <a href="{{ item.url }}" class="section-text" data-cart-item-title data-role="product-title">
                        {{ item.product.title }}
                      </a>

                      <ul
                        class="main-cart__details section-text{% if item.product.has_only_default_variant and property_size == 0 and item.selling_plan_allocation == nil %} hide{% endif %}"
                        style="margin: 8px 0 0; padding: 0; list-style: none; font-size: 0.875rem; opacity: 0.85;"
                        data-cart-item-details
                        aria-label="{{ 'cart.label.product_details' | t }}"
                      >
                        {%- for option in variant_options -%}
                          <li
                            class="main-cart__details-item{% if item.product.has_only_default_variant %} hide{% endif %}"
                            data-cart-item-option
                          >
                            {{ option.name }}: {{ option.value }}
                          </li>
                        {%- endfor -%}

                        <li
                          class="main-cart__details-item{% if item.selling_plan_allocation == empty %} hide{% endif %}"
                          data-cart-item-selling-plan-name
                        >
                          {{ item.selling_plan_allocation.selling_plan.name }}
                        </li>

                        {%- for p in properties -%}
                          {%- assign property_first_char = p.first | slice: 0 -%}
                          <li
                            class="main-cart__details-item{% if property_size == 0 or p.last == blank or property_first_char == '_' %} hide{% endif %}"
                            data-cart-item-property
                          >
                            <span data-cart-item-property-name>{{ p.first }}: </span>
                            <span data-cart-item-property-value>
                              {%- if p.last contains '/uploads/' -%}
                                <a href="{{ p.last }}" data-role="product-upload">{{ p.last | split: '/' | last }}</a>
                              {%- else -%}
                                {{ p.last }}
                              {%- endif -%}
                            </span>
                          </li>
                        {%- endfor -%}
                      </ul>

                      <p style="margin: 8px 0 0;">
                        <a
                          href="{{ routes.cart_change_url }}?line={{ forloop.index }}&amp;quantity=0"
                          class="section-text"
                          style="font-size: 0.875rem; text-decoration: underline;"
                          aria-label="{{ 'cart.label.remove' | t: product: item.title }}"
                          data-cart-remove
                          data-role="product-remove"
                          data-removed-message="{{ 'cart.general.remove' | t }}: {{ item.title | escape }}"
                        >
                          {{ 'cart.general.remove' | t | default: 'Remove' }}
                        </a>
                      </p>
                    </div>
                  </div>
                </td>

                <td class="main-cart__col-price" style="text-align: right; padding: 16px 0; vertical-align: top;">
                  <div data-cart-item-price>
                    <div{% unless has_discount %} class="hide"{% endunless %} data-cart-item-discounted-price-group>
                      <span class="visually-hidden">{{ 'products.product.regular_price' | t }}</span>
                      <s data-cart-item-original-price style="opacity: 0.5;">{{ item.original_price | money }}</s>
                      <span class="visually-hidden">{{ 'products.product.sale_price' | t }}</span>
                      <span data-cart-item-final-price>{{ item.final_price | money }}</span>
                    </div>

                    <div{% if has_discount %} class="hide"{% endif %} data-cart-item-regular-price-group>
                      <span data-cart-item-regular-price>{{ item.original_price | money }}</span>
                    </div>

                    <div
                      class="section-text{% unless item.unit_price_measurement %} hide{% endunless %}"
                      style="margin-top: 4px; font-size: 0.8125rem; opacity: 0.75;"
                      data-unit-price-group
                    >
                      <span class="visually-hidden">{{ 'products.product.unit_price_label' | t }}</span>
                      {%- capture unit_price_separator -%}
                        <span aria-hidden="true">/</span><span class="visually-hidden">{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
                      {%- endcapture -%}
                      {%- capture unit_price_base_unit -%}
                        {%- if item.unit_price_measurement.reference_value != 1 -%}
                          {{- item.unit_price_measurement.reference_value -}}
                        {%- endif -%}
                        {{ item.unit_price_measurement.reference_unit }}
                      {%- endcapture -%}
                      <span data-unit-price>{{ item.unit_price | money }}</span>{{ unit_price_separator }}<span data-unit-price-base-unit>{{ unit_price_base_unit }}</span>
                    </div>
                  </div>

                  <ul
                    class="main-cart__discounts section-text{% if item.line_level_discount_allocations == blank %} hide{% endif %}"
                    style="margin: 8px 0 0; padding: 0; list-style: none; font-size: 0.8125rem;"
                    aria-label="{{ 'customer.order.discount' | t }}"
                    data-cart-item-discount-list
                  >
                    {%- for discount_allocation in item_discounts -%}
                      <li data-cart-item-discount>
                        <span data-cart-item-discount-title>{{ discount_allocation.discount_application.title }}</span>
                        (-<span data-cart-item-discount-amount>{{ discount_allocation.amount | money }}</span>)
                      </li>
                    {%- endfor -%}
                  </ul>

                  <div class="main-cart__col-qty-mobile" style="margin-top: 12px; text-align: right;">
                    <label for="updates_mobile_{{ item.key }}" class="section-text" style="display: block; margin-bottom: 4px; font-size: 0.875rem;">
                      {{ 'cart.label.qty' | t | default: 'Qty' }}
                    </label>
                    <input
                      id="updates_mobile_{{ item.key }}"
                      class="main-cart__qty-input"
                      type="number"
                      value="{{ item.quantity }}"
                      min="0"
                      pattern="[0-9]*"
                      data-quantity-input
                      data-quantity-item="{{ forloop.index }}"
                      data-quantity-input-mobile
                      data-quantity-error-message="{{ 'products.product.quantity_minimum_message' | t }}"
                      data-role="product-quantity-mobile"
                      style="width: 64px; padding: 8px; text-align: center;"
                    >
                    <div class="main-cart__qty-error hide" role="alert" data-cart-quantity-error-message-wrapper style="margin-top: 8px; font-size: 0.8125rem; color: #b00020;">
                      <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
                      <span data-cart-quantity-error-message></span>
                    </div>
                  </div>
                </td>

                <td class="main-cart__col-qty main-cart__col-qty-desktop" style="text-align: center; padding: 16px 0; vertical-align: top;">
                  <label for="updates_desktop_{{ item.key }}" class="visually-hidden">{{ 'cart.label.quantity' | t }}</label>
                  <input
                    id="updates_desktop_{{ item.key }}"
                    class="main-cart__qty-input"
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    pattern="[0-9]*"
                    data-quantity-input
                    data-quantity-item="{{ forloop.index }}"
                    data-quantity-input-desktop
                    data-quantity-error-message="{{ 'products.product.quantity_minimum_message' | t }}"
                    data-role="product-quantity-desktop"
                    style="width: 64px; padding: 8px; text-align: center;"
                  >
                  <div class="main-cart__qty-error hide" role="alert" data-cart-quantity-error-message-wrapper style="margin-top: 8px; font-size: 0.8125rem; color: #b00020;">
                    <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
                    <span data-cart-quantity-error-message></span>
                  </div>
                </td>

                <td class="main-cart__col-total main-cart__col-total-desktop" style="text-align: right; padding: 16px 0; vertical-align: top;" data-cart-item-line-price>
                  <div{% unless item.original_line_price != item.final_line_price %} class="hide"{% endunless %} data-cart-item-discounted-price-group>
                    <span class="visually-hidden">{{ 'cart.label.regular_total' | t }}</span>
                    <s data-cart-item-original-price style="opacity: 0.5;">{{ item.original_line_price | money }}</s>
                    <span class="visually-hidden">{{ 'cart.label.discounted_total' | t }}</span>
                    <span data-cart-item-final-price>{{ item.final_line_price | money }}</span>
                  </div>
                  <div{% if item.original_line_price != item.final_line_price %} class="hide"{% endif %} data-cart-item-regular-price-group>
                    <span data-cart-item-regular-price>{{ item.original_line_price | money }}</span>
                  </div>
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div class="main-cart__footer" style="margin-top: 24px;">
          <div class="main-cart__footer-grid" style="display: flex; flex-wrap: wrap; gap: 32px; justify-content: space-between;">
            {%- if section.settings.cart_notes_enable -%}
              <div class="main-cart__note" style="flex: 1 1 280px; max-width: 100%;">
                <label for="CartSpecialInstructions-{{ section.id }}" class="section-text" style="display: block; margin-bottom: 8px;">
                  {{ 'cart.general.note' | t | default: 'Order note' }}
                </label>
                <textarea
                  name="note"
                  id="CartSpecialInstructions-{{ section.id }}"
                  class="main-cart__note-input section-text"
                  data-cart-notes
                  style="width: 100%; min-height: 96px; padding: 12px; border: 1px solid rgba(10,29,60,0.15); resize: vertical;"
                >{{ cart.note }}</textarea>
              </div>
            {%- endif -%}

            <div class="main-cart__summary" style="flex: 1 1 280px; max-width: 100%; text-align: right;">
              {%- assign cart_discounts = 'template ' | split: ' ' -%}
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- assign cart_discounts = cart.cart_level_discount_applications -%}
              {%- endif -%}

              <div{% if cart.cart_level_discount_applications.size == 0 %} class="hide"{% endif %} data-cart-discount-wrapper style="margin-bottom: 12px;">
                {%- for discount_application in cart_discounts -%}
                  <p class="section-text" style="margin: 0 0 4px; font-size: 0.875rem;" data-cart-discount>
                    <span class="visually-hidden">{{ 'customer.order.discount' | t }}:</span>
                    <span data-cart-discount-title>{{ discount_application.title }}</span>
                    <span data-cart-discount-amount>-{{ discount_application.total_allocated_amount | money }}</span>
                  </p>
                {%- endfor -%}
              </div>

              <p class="section-text" style="margin: 0 0 12px; font-weight: 700;" data-cart-subtotal-wrap>
                {{ 'cart.general.subtotal' | t | default: 'Subtotal' }}:
                <span data-cart-subtotal>{{ cart.total_price | money_with_currency }}</span>
              </p>

              {%- capture taxes_shipping_checkout -%}
                {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                  {{ 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- elsif cart.taxes_included -%}
                  {{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                {%- else -%}
                  {{ 'cart.general.taxes_and_shipping_at_checkout' | t }}
                {%- endif -%}
              {%- endcapture -%}
              <div class="section-text rte main-cart__shipping" style="margin: 0 0 24px; font-size: 0.875rem; opacity: 0.85;">
                {{ taxes_shipping_checkout }}
              </div>

              <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: flex-end;">
                {%- unless section.settings.cart_ajax_enable -%}
                  <button type="submit" name="update" class="btn btn--outline">
                    {{ 'cart.general.update' | t | default: 'Update cart' }}
                  </button>
                {%- endunless -%}
                <button type="submit" name="checkout" class="btn btn--yellow">
                  {{ 'cart.general.checkout' | t | default: 'Checkout' }}
                </button>
              </div>

              <div class="main-cart__error hide" role="alert" data-cart-error-message-wrapper style="margin-top: 16px; font-size: 0.875rem; color: #b00020; text-align: right;">
                <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
                <span data-cart-error-message></span>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="main-cart__additional-checkout" style="margin-top: 16px;">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </form>

      <p class="visually-hidden" data-cart-status aria-live="polite" role="status"></p>
    </div>

    <div class="main-cart__empty{% if cart.item_count > 0 %} hide{% endif %}" data-empty-page-content>
      <p class="section-text" style="margin: 24px 0;">{{ 'cart.general.empty' | t | default: 'Your cart is empty.' }}</p>
      <p class="section-text" style="margin: 0 0 24px; font-size: 0.875rem; opacity: 0.85;">
        {{ 'cart.general.cookies_required' | t }}
      </p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
        {{ 'cart.general.continue_shopping' | t | default: 'Continue shopping' }}
      </a>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .main-cart__table {
    table-layout: fixed;
  }

  #shopify-section-{{ section.id }} .main-cart__col-product {
    width: 65%;
  }

  #shopify-section-{{ section.id }} .main-cart__col-price,
  #shopify-section-{{ section.id }} .main-cart__col-qty,
  #shopify-section-{{ section.id }} .main-cart__col-total {
    width: 15%;
  }

  #shopify-section-{{ section.id }} .hide {
    display: none !important;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .main-cart__col-qty-desktop,
    #shopify-section-{{ section.id }} .main-cart__col-total-desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .main-cart__col-price {
      width: 35%;
    }
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .main-cart__col-qty-mobile {
      display: none;
    }
  }
</style>

<script src="{{ 'cart.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "cart_ajax_enable",
      "label": "Enable automatic cart updates",
      "info": "Updates the cart as soon as customer changes are made. Hides the Update cart button.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "cart_notes_enable",
      "label": "Enable cart notes",
      "default": false
    }
  ]
}
{% endschema %}
