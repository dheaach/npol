<section class="main-collection section-spacing">
  <div class="page-width">
    <h1 class="section-heading section-heading--h1">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="section-text rte" style="margin: 16px 0 32px;">{{ collection.description }}</div>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="main-collection__grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px;">
        {%- for product in collection.products -%}
          <article>
            <a href="{{ product.url }}">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 400 | image_tag: alt: product.title, loading: 'lazy' }}
              {%- endif -%}
              <h2 class="section-heading section-heading--h5" style="margin-top: 12px;">{{ product.title }}</h2>
              <p class="section-text">{{ product.price | money }}</p>
            </a>
          </article>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="main-collection__pagination" style="margin-top: 32px; text-align: center;" aria-label="Pagination">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ]
}
{% endschema %}
