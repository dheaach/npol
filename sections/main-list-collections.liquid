<section class="main-list-collections section-spacing">
  <div class="page-width">
    <h1 class="section-heading section-heading--h1">{{ section.settings.heading | default: 'Collections' }}</h1>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; margin-top: 32px;">
      {%- for coll in collections -%}
        <a href="{{ coll.url }}" style="text-decoration: none;">
          {%- if coll.featured_image -%}
            {{ coll.featured_image | image_url: width: 500 | image_tag: alt: coll.title, loading: 'lazy' }}
          {%- endif -%}
          <h2 class="section-heading section-heading--h4" style="margin-top: 12px;">{{ coll.title }}</h2>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "class": "section-main-list-collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    }
  ]
}
{% endschema %}
