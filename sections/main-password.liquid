<div class="page-width text-center" style="max-width: 480px;">
  {%- if section.settings.logo != blank -%}
    <div style="margin-bottom: 24px;">
      {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
    </div>
  {%- else -%}
    <h1 class="section-heading section-heading--h3" style="margin-bottom: 24px;">{{ shop.name }}</h1>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="section-heading section-heading--h4" style="margin-bottom: 12px;">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.text != blank -%}
    <p class="section-text" style="margin-bottom: 24px;">{{ section.settings.text }}</p>
  {%- endif -%}

  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <label for="password" class="visually-hidden">Password</label>
    <input
      type="password"
      name="password"
      id="password"
      placeholder="{{ section.settings.password_placeholder | default: 'Password' }}"
      style="width: 100%; padding: 12px 16px; margin-bottom: 16px; border: 1px solid rgba(10,29,60,0.2); border-radius: 8px; font-family: var(--font-body);"
    >
    <button type="submit" class="btn btn--primary" style="width: 100%;">{{ section.settings.button_label | default: 'Enter' }}</button>
  {% endform %}
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password field placeholder",
      "default": "Password"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter"
    }
  ]
}
{% endschema %}
