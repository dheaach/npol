<section class="main-search section-spacing">
  <div class="page-width">
    <h1 class="section-heading section-heading--h1">Search</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" style="margin: 24px 0 32px; display: flex; gap: 12px; flex-wrap: wrap;">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search..."
        style="flex: 1; min-width: 200px; padding: 12px 16px; border: 1px solid rgba(10,29,60,0.2); border-radius: 8px; font-family: var(--font-body);"
      >
      <button type="submit" class="btn btn--primary">Search</button>
    </form>

    {%- if search.performed -%}
      <p class="section-text" style="margin-bottom: 24px;">{{ search.results_count }} results for "{{ search.terms }}"</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px;">
        {%- for item in search.results -%}
          <article>
            <a href="{{ item.url }}">
              {%- if item.featured_image -%}
                {{ item.featured_image | image_url: width: 400 | image_tag: alt: item.title, loading: 'lazy' }}
              {%- endif -%}
              <h2 class="section-heading section-heading--h5" style="margin-top: 12px;">{{ item.title }}</h2>
            </a>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search",
  "settings": []
}
{% endschema %}
