{% render 'section-font-vars', section: section %}

{%- liquid
  assign grid_gap = section.settings.column_gap | default: 24
  assign grid_gap_tablet = section.settings.column_gap_tablet | default: 0
  if grid_gap_tablet == 0
    assign grid_gap_tablet = grid_gap
  endif
  assign grid_gap_mobile = section.settings.column_gap_mobile | default: 0
  if grid_gap_mobile == 0
    assign grid_gap_mobile = grid_gap_tablet
  endif
  assign cols_desktop = section.settings.cards_per_row | default: 2
  assign cols_tablet = section.settings.cards_per_row_tablet | default: 2
  assign cols_mobile = section.settings.cards_per_row_mobile | default: 1
  assign content_max = section.settings.content_max_width | default: 1100
  assign grad_top = section.settings.card_bg_gradient_top | default: '#F5F5F5'
  assign grad_bottom = section.settings.card_bg_gradient_bottom | default: '#F5F5F5'
  assign grad_center = section.settings.card_bg_gradient_center | default: '#E8956A'
  assign grad_center_pos = section.settings.card_bg_gradient_center_position | default: 50
  assign enable_center_grad = section.settings.enable_center_gradient
  if enable_center_grad == nil
    assign enable_center_grad = true
  endif
  assign default_border = section.settings.card_border_color | default: '#51ADA0'
-%}

<section
  class="podcast section-spacing"
  aria-labelledby="podcast-heading-{{ section.id }}"
>
  <div class="page-width">
    <div class="podcast__inner" style="max-width: {{ content_max }}px;">
      <header class="podcast__header text-center">
        <div id="podcast-heading-{{ section.id }}">
          {%- if section.settings.heading_before != blank or section.settings.heading_highlight != blank or section.settings.heading_after != blank -%}
            {% render 'highlighted-heading',
              heading: section.settings.heading,
              heading_weight: section.settings.heading_weight,
              heading_before: section.settings.heading_before,
              heading_highlight: section.settings.heading_highlight,
              heading_after: section.settings.heading_after,
              heading_before_weight: section.settings.heading_before_weight,
              heading_highlight_weight: section.settings.heading_highlight_weight,
              heading_after_weight: section.settings.heading_after_weight,
              heading_tag: section.settings.heading_tag,
              heading_size: section.settings.heading_tag,
              highlight_color: section.settings.highlight_color
            %}
          {%- elsif section.settings.heading != blank -%}
            <h2 class="podcast__heading section-heading section-heading--h2">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
      </header>

      {%- if section.blocks.size > 0 -%}
        {%- liquid
          assign card_count = section.blocks.size
          assign cards_max_cols = cols_desktop
          if card_count <= cards_max_cols
            assign cards_row_count = 1
            assign cards_row_base = card_count
            assign cards_row_extra = 0
          else
            assign cards_row_count = card_count | plus: cards_max_cols | minus: 1 | divided_by: cards_max_cols
            assign cards_row_base = card_count | divided_by: cards_row_count
            assign cards_row_extra = card_count | modulo: cards_row_count
          endif
        -%}
        <div
          class="podcast__grid-wrap"
          style="margin-top: {{ section.settings.cards_margin_top | default: 40 }}px;"
        >
          <div
            class="podcast__grid podcast__grid--count-{{ card_count }}"
            style="
              --podcast-columns: {{ cols_desktop }};
              --podcast-columns-tablet: {{ cols_tablet }};
              --podcast-columns-mobile: {{ cols_mobile }};
              --podcast-gap: {{ grid_gap }}px;
              --podcast-gap-tablet: {{ grid_gap_tablet }}px;
              --podcast-gap-mobile: {{ grid_gap_mobile }}px;
            "
          >
            {%- assign block_idx = 0 -%}
            {%- for row_num in (1..cards_row_count) -%}
              {%- liquid
                assign row_size = cards_row_base
                if row_num <= cards_row_extra
                  assign row_size = cards_row_base | plus: 1
                endif
              -%}
              <div class="podcast__row">
                {%- for _slot in (1..row_size) -%}
                  {%- assign block = section.blocks[block_idx] -%}
                  {%- liquid
                    assign card_border = block.settings.border_color
                    if card_border == blank
                      assign card_border = default_border
                    endif

                    assign card_grad_center = block.settings.gradient_center_color
                    if card_grad_center == blank
                      assign card_grad_center = grad_center
                    endif

                    if enable_center_grad and card_grad_center != blank
                      assign card_bg = 'linear-gradient(180deg, ' | append: grad_top | append: ' 0%, ' | append: card_grad_center | append: ' ' | append: grad_center_pos | append: '%, ' | append: grad_bottom | append: ' 100%)'
                    else
                      assign card_bg = 'linear-gradient(180deg, ' | append: grad_top | append: ' 0%, ' | append: grad_bottom | append: ' 100%)'
                    endif
                  -%}
                  {%- if block.settings.card_url != blank -%}
                    <a
                      id="podcast-card-{{ block.id }}"
                      href="{{ block.settings.card_url }}"
                      class="podcast__card podcast__card--linked"
                      style="
                        border-color: {{ card_border }};
                        background: {{ card_bg }};
                      "
                      {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                      {{ block.shopify_attributes }}
                    >
                      <div class="podcast__card-body">
                        {%- if block.settings.title != blank -%}
                          <h3 class="podcast__card-title section-heading section-heading--h3">{{ block.settings.title }}</h3>
                        {%- endif -%}
                        {%- if block.settings.subtitle != blank -%}
                          <p class="podcast__card-subtitle section-text">{{ block.settings.subtitle }}</p>
                        {%- endif -%}
                        {%- if block.settings.subtext != blank -%}
                          <p class="podcast__card-subtext section-text">{{ block.settings.subtext }}</p>
                        {%- endif -%}
                      </div>
                    </a>
                  {%- else -%}
                    <article
                      id="podcast-card-{{ block.id }}"
                      class="podcast__card"
                      style="
                        border-color: {{ card_border }};
                        background: {{ card_bg }};
                      "
                      {{ block.shopify_attributes }}
                    >
                      <div class="podcast__card-body">
                        {%- if block.settings.title != blank -%}
                          <h3 class="podcast__card-title section-heading section-heading--h3">{{ block.settings.title }}</h3>
                        {%- endif -%}
                        {%- if block.settings.subtitle != blank -%}
                          <p class="podcast__card-subtitle section-text">{{ block.settings.subtitle }}</p>
                        {%- endif -%}
                        {%- if block.settings.subtext != blank -%}
                          <p class="podcast__card-subtext section-text">{{ block.settings.subtext }}</p>
                        {%- endif -%}
                      </div>
                    </article>
                  {%- endif -%}
                  {%- assign block_idx = block_idx | plus: 1 -%}
                {%- endfor -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {%- if section.settings.background_color != blank -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}

  {% render 'section-spacing-styles', root: '.podcast', pad_x: '.page-width' %}

  #shopify-section-{{ section.id }} .podcast__inner {
    margin-inline: auto;
  }
  #shopify-section-{{ section.id }} .podcast__header {
    margin-bottom: 0;
  }
  #shopify-section-{{ section.id }} .podcast__heading,
  #shopify-section-{{ section.id }} #podcast-heading-{{ section.id }} .section-heading {
    display: inline-block;
    margin: 0;
    color: {{ section.settings.heading_color | default: '#2E6BAA' }};
  }
  {%- if section.settings.heading_font_size > 0 -%}
    #shopify-section-{{ section.id }} .podcast__heading,
    #shopify-section-{{ section.id }} #podcast-heading-{{ section.id }} .section-heading {
      font-size: {{ section.settings.heading_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.heading_font_weight != blank and section.settings.heading_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .podcast__heading,
    #shopify-section-{{ section.id }} #podcast-heading-{{ section.id }} .section-heading {
      font-weight: {{ section.settings.heading_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.heading_font_color != blank -%}
    #shopify-section-{{ section.id }} .podcast__heading,
    #shopify-section-{{ section.id }} #podcast-heading-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#2E6BAA' }} !important;
  }

  #shopify-section-{{ section.id }} .podcast__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--podcast-gap-mobile, 24px);
  }
  #shopify-section-{{ section.id }} .podcast__row {
    display: contents;
  }
  #shopify-section-{{ section.id }} .podcast__card {
    flex: 1 1 0;
    min-width: calc((100% - (var(--podcast-columns-mobile, 1) - 1) * var(--podcast-gap-mobile, 24px)) / var(--podcast-columns-mobile, 1));
    max-width: 100%;
    box-sizing: border-box;
    border-style: solid;
    border-width: {{ section.settings.card_border_width | default: 8 }}px;
    min-height: {{ section.settings.card_min_height | default: 160 }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .podcast__grid {
      gap: var(--podcast-gap-tablet, 24px);
    }
    #shopify-section-{{ section.id }} .podcast__card {
      min-width: calc((100% - (var(--podcast-columns-tablet, 2) - 1) * var(--podcast-gap-tablet, 24px)) / var(--podcast-columns-tablet, 2));
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .podcast__grid {
      flex-direction: column;
      flex-wrap: nowrap;
      gap: var(--podcast-gap, 24px);
    }
    #shopify-section-{{ section.id }} .podcast__row {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--podcast-gap, 24px);
      width: 100%;
    }
    #shopify-section-{{ section.id }} .podcast__row .podcast__card {
      flex: 1 1 0;
      min-width: 0;
      max-width: none;
    }
  }

  #shopify-section-{{ section.id }} .podcast__card--linked {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  #shopify-section-{{ section.id }} .podcast__card--linked:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(10, 29, 60, 0.12);
  }
  #shopify-section-{{ section.id }} .podcast__card--linked:focus-visible {
    outline: 2px solid {{ section.settings.heading_color | default: '#2E6BAA' }};
    outline-offset: 4px;
  }
  #shopify-section-{{ section.id }} .podcast__card-body {
    padding: {{ section.settings.card_padding | default: 32 }}px {{ section.settings.card_padding_horizontal | default: 24 }}px;
    width: 100%;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .podcast__card-title {
    margin: 0;
    color: {{ section.settings.card_title_color | default: '#0A1D3C' }};
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .podcast__card-subtitle {
    margin: {{ section.settings.card_title_subtitle_gap | default: 8 }}px 0 0;
    color: {{ section.settings.card_subtitle_color | default: '#0A1D3C' }};
    font-style: italic;
  }
  #shopify-section-{{ section.id }} .podcast__card-subtext {
    margin: {{ section.settings.card_subtitle_subtext_gap | default: 6 }}px 0 0;
    color: {{ section.settings.card_subtext_color | default: '#0A1D3C' }};
    line-height: 1.3;
    opacity: 0.85;
  }
  {%- if section.settings.card_font_size > 0 -%}
    #shopify-section-{{ section.id }} .podcast__card-title,
    #shopify-section-{{ section.id }} .podcast__card-subtitle,
    #shopify-section-{{ section.id }} .podcast__card-subtext {
      font-size: {{ section.settings.card_font_size }}px;
    }
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.subtitle_font_weight != blank and block.settings.subtitle_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-subtitle {
        font-weight: {{ block.settings.subtitle_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.subtitle_font_color != blank -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-subtitle {
        color: {{ block.settings.subtitle_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.subtext_font_weight != blank and block.settings.subtext_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-subtext {
        font-weight: {{ block.settings.subtext_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.subtext_font_color != blank -%}
      #shopify-section-{{ section.id }} #podcast-card-{{ block.id }} .podcast__card-subtext {
        color: {{ block.settings.subtext_font_color }};
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% schema %}
{
  "name": "Podcast",
  "tag": "section",
  "class": "section-podcast",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Minilessons and Number Strings Series"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color",
      "info": "Empty = theme default below."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (fallback)",
      "default": "#2E6BAA"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = heading scale only."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Split heading (before highlight)",
      "info": "Used only when single heading field above is empty."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Split heading highlight"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Split heading (after highlight)"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Split heading font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Split heading — before weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Split heading — highlight weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Split heading — after weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Split heading HTML tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Split heading highlight color",
      "default": "#2E6BAA"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Default card border color",
      "default": "#51ADA0",
      "info": "Used when a card has no border color set."
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card border width",
      "min": 2,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "card_bg_gradient_top",
      "label": "Card background gradient — top",
      "default": "#F5F5F5",
      "info": "Edge color at the top of the card."
    },
    {
      "type": "checkbox",
      "id": "enable_center_gradient",
      "label": "Enable center gradient glow",
      "default": true,
      "info": "Adds a colored glow in the middle of each card (like the orange band in the design)."
    },
    {
      "type": "color",
      "id": "card_bg_gradient_center",
      "label": "Card background gradient — center",
      "default": "#E8956A",
      "info": "Center glow color. Used when center gradient is enabled."
    },
    {
      "type": "range",
      "id": "card_bg_gradient_center_position",
      "label": "Center gradient position",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Vertical position of the center color peak."
    },
    {
      "type": "color",
      "id": "card_bg_gradient_bottom",
      "label": "Card background gradient — bottom",
      "default": "#F5F5F5",
      "info": "Edge color at the bottom of the card."
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Default card title color",
      "default": "#0A1D3C"
    },
    {
      "type": "color",
      "id": "card_subtitle_color",
      "label": "Default card subtitle color",
      "default": "#0A1D3C"
    },
    {
      "type": "color",
      "id": "card_subtext_color",
      "label": "Default card subtext color",
      "default": "#0A1D3C",
      "info": "Small line below subtitle (e.g. date, Coming soon)."
    },
    {
      "type": "range",
      "id": "card_font_size",
      "label": "Card font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Applies to title, subtitle, and subtext. 0 = theme default sizes."
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding — vertical",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding_horizontal",
      "label": "Card padding — horizontal",
      "min": 12,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_title_subtitle_gap",
      "label": "Space between title and subtitle",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_subtitle_subtext_gap",
      "label": "Space between subtitle and subtext",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards per row (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "Max per row. Extra cards split evenly (e.g. 5 → 3+2, 6 → 3+3)."
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "label": "Cards per row (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "cards_margin_top",
      "label": "Space above cards",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Column spacing"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between cards (desktop)",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "column_gap_tablet",
      "label": "Gap between cards (tablet)",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = use desktop value."
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
