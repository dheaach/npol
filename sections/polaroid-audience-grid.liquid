{% render 'section-font-vars', section: section %}
{% render 'section-column-widths',
  section: section,
  grid_class: 'polaroid-audience-grid__columns',
  gap_fallback_tablet: 48,
  gap_fallback_mobile: 32
%}

{%- liquid
  assign pag_gap_d = section.settings.box_grid_gap | default: 0
  if pag_gap_d == 0
    assign pag_gap_d = 16
  endif
  assign pag_gap_t = section.settings.box_grid_gap_tablet | default: 0
  if pag_gap_t == 0
    assign pag_gap_t = pag_gap_d
  endif
  assign pag_gap_m = section.settings.box_grid_gap_mobile | default: 0
  if pag_gap_m == 0
    assign pag_gap_m = pag_gap_t
  endif

  assign box_pad_y = section.settings.box_padding_y | default: 32
  assign box_pad_x = section.settings.box_padding_x | default: 24
  assign header_gap = section.settings.header_spacing | default: 48

  assign has_bg_desktop = false
  assign bg_url = blank
  if section.settings.background_image != blank
    assign has_bg_desktop = true
    assign bg_url = section.settings.background_image | image_url: width: 3840
  endif

  assign has_bg_tablet = false
  assign bg_tablet_url = blank
  if section.settings.background_image_tablet != blank
    assign has_bg_tablet = true
    assign bg_tablet_url = section.settings.background_image_tablet | image_url: width: 2400
  endif

  assign has_bg_mobile = false
  assign bg_mobile_url = blank
  if section.settings.background_image_mobile != blank
    assign has_bg_mobile = true
    assign bg_mobile_url = section.settings.background_image_mobile | image_url: width: 1200
  endif

  assign bg_layered = false
  if has_bg_mobile or has_bg_tablet
    assign bg_layered = true
  endif

  assign bg_size = section.settings.background_size | default: 'cover'
  assign bg_position = section.settings.background_position | default: 'center center'
-%}

{%- if has_bg_mobile -%}
  <div
    class="polaroid-audience-grid__bg polaroid-audience-grid__bg--mobile"
    style="background-image: url({{ bg_mobile_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}
{%- if has_bg_tablet -%}
  <div
    class="polaroid-audience-grid__bg polaroid-audience-grid__bg--tablet"
    style="background-image: url({{ bg_tablet_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}
{%- if has_bg_desktop -%}
  <div
    class="polaroid-audience-grid__bg{% if bg_layered %} polaroid-audience-grid__bg--desktop{% endif %}"
    style="background-image: url({{ bg_url }});"
    aria-hidden="true"
  ></div>
{%- endif -%}

<section
  class="polaroid-audience-grid section-spacing"
  aria-labelledby="polaroid-audience-grid-heading-{{ section.id }}"
>
  <div class="page-width">
    <header
      class="polaroid-audience-grid__header text-center"
      style="--pag-header-gap: {{ header_gap }}px;"
    >
      <div id="polaroid-audience-grid-heading-{{ section.id }}">
        {%- liquid
          assign pag_heading_before_color = section.settings.heading_before_color
          if pag_heading_before_color == blank
            assign pag_heading_before_color = section.settings.heading_color
          endif
          assign pag_heading_after_color = section.settings.heading_after_color
          if pag_heading_after_color == blank
            assign pag_heading_after_color = section.settings.heading_color
          endif
        -%}
        {% render 'highlighted-heading',
          heading_before: section.settings.heading_before,
          heading_before_weight: section.settings.heading_before_weight,
          heading_before_font_size: section.settings.heading_before_font_size,
          heading_before_color: pag_heading_before_color,
          heading_highlight: section.settings.heading_highlight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_highlight_font_size: section.settings.heading_highlight_font_size,
          heading_after: section.settings.heading_after,
          heading_after_weight: section.settings.heading_after_weight,
          heading_after_font_size: section.settings.heading_after_font_size,
          heading_after_color: pag_heading_after_color,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>
    </header>

    <div class="polaroid-audience-grid__columns{% if section.settings.layout == 'reverse' %} polaroid-audience-grid__columns--reverse{% endif %}{% if section.settings.mobile_stack_order == 'grid-first' %} polaroid-audience-grid__columns--mobile-grid-first{% endif %}">
      <div class="polaroid-audience-grid__media">
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          class: 'polaroid-audience-grid__image',
          loading: section.settings.image_loading
        %}
      </div>

      <div
        class="polaroid-audience-grid__grid"
        style="
          --pag-box-gap-desktop: {{ pag_gap_d }}px;
          --pag-box-gap-tablet: {{ pag_gap_t }}px;
          --pag-box-gap-mobile: {{ pag_gap_m }}px;
        "
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign box_bg = block.settings.box_background_color | default: '#0E3458'
            assign box_hover_bg = block.settings.box_hover_background_color | default: '#1BCDC4'
            assign hover_text = block.settings.hover_text_color | default: '#0E3458'
            assign box_heading_color = block.settings.heading_font_color | default: '#FFFFFF'
            assign box_paragraph_color = block.settings.paragraph_font_color | default: '#FFFFFF'
            assign radius_tl = block.settings.border_radius_top_left | default: 12
            assign radius_tr = block.settings.border_radius_top_right | default: 12
            assign radius_br = block.settings.border_radius_bottom_right | default: 12
            assign radius_bl = block.settings.border_radius_bottom_left | default: 12
            assign block_pad_top = block.settings.padding_top
            if block_pad_top == 0
              assign block_pad_top = box_pad_y
            endif
            assign block_pad_bottom = block.settings.padding_bottom
            if block_pad_bottom == 0
              assign block_pad_bottom = box_pad_y
            endif
            assign block_pad_left = block.settings.padding_left
            if block_pad_left == 0
              assign block_pad_left = box_pad_x
            endif
            assign block_pad_right = block.settings.padding_right
            if block_pad_right == 0
              assign block_pad_right = box_pad_x
            endif
          -%}
          <article
            id="pag-box-{{ block.id }}"
            class="polaroid-audience-grid__box"
            {{ block.shopify_attributes }}
            style="
              background-color: {{ box_bg }};
              border-radius: {{ radius_tl }}px {{ radius_tr }}px {{ radius_br }}px {{ radius_bl }}px;
              --pag-box-hover-bg: {{ box_hover_bg }};
              --pag-box-hover-text: {{ hover_text }};
              --pag-box-heading-color: {{ box_heading_color }};
              --pag-box-paragraph-color: {{ box_paragraph_color }};
              --pag-box-pad-top: {{ block_pad_top }}px;
              --pag-box-pad-bottom: {{ block_pad_bottom }}px;
              --pag-box-pad-left: {{ block_pad_left }}px;
              --pag-box-pad-right: {{ block_pad_right }}px;
            "
          >
            {%- if block.settings.heading != blank -%}
              <h3 class="polaroid-audience-grid__box-heading section-heading section-heading--h4">
                {{ block.settings.heading }}
              </h3>
            {%- endif -%}

            {%- if block.settings.paragraph != blank -%}
              <div class="polaroid-audience-grid__box-text section-text rte">{{ block.settings.paragraph }}</div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }
  {%- if section.settings.background_color != blank -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .polaroid-audience-grid__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-size: {{ bg_size }};
    background-position: {{ bg_position }};
    background-repeat: no-repeat;
  }
  #shopify-section-{{ section.id }} .polaroid-audience-grid {
    position: relative;
    z-index: 1;
  }

  {%- if has_bg_mobile -%}
    @media screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .polaroid-audience-grid__bg--mobile {
        display: none;
      }
    }
    {%- if has_bg_desktop or has_bg_tablet -%}
      @media screen and (max-width: 767px) {
        #shopify-section-{{ section.id }} .polaroid-audience-grid__bg--desktop,
        #shopify-section-{{ section.id }} .polaroid-audience-grid__bg--tablet {
          display: none;
        }
      }
    {%- endif -%}
  {%- endif -%}
  {%- if has_bg_tablet and has_bg_desktop -%}
    @media screen and (min-width: 768px) and (max-width: 1023px) {
      #shopify-section-{{ section.id }} .polaroid-audience-grid__bg--desktop {
        display: none;
      }
    }
    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} .polaroid-audience-grid__bg--tablet {
        display: none;
      }
    }
  {%- endif -%}

  {% render 'section-spacing-styles', root: '.polaroid-audience-grid', pad_x: '.page-width' %}

  {%- liquid
    assign pag_heading_base_color = section.settings.heading_before_color
    if pag_heading_base_color == blank
      assign pag_heading_base_color = section.settings.heading_color
    endif
  -%}
  {%- if pag_heading_base_color != blank -%}
    #shopify-section-{{ section.id }} #polaroid-audience-grid-heading-{{ section.id }} .section-heading {
      color: {{ pag_heading_base_color }};
    }
    #shopify-section-{{ section.id }} #polaroid-audience-grid-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#1BCDC4' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #polaroid-audience-grid-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .polaroid-audience-grid__header {
    display: flex;
    flex-direction: column;
    gap: var(--pag-header-gap, 48px);
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__columns {
    display: grid;
    align-items: center;
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .polaroid-audience-grid__columns--reverse .polaroid-audience-grid__media {
      order: 2;
    }
    #shopify-section-{{ section.id }} .polaroid-audience-grid__columns--reverse .polaroid-audience-grid__grid {
      order: 1;
    }
  }

  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .polaroid-audience-grid__columns--mobile-grid-first .polaroid-audience-grid__media {
      order: 2;
    }
    #shopify-section-{{ section.id }} .polaroid-audience-grid__columns--mobile-grid-first .polaroid-audience-grid__grid {
      order: 1;
    }
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pag-box-gap-desktop, 16px);
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding:
      var(--pag-box-pad-top, 32px)
      var(--pag-box-pad-right, 24px)
      var(--pag-box-pad-bottom, 32px)
      var(--pag-box-pad-left, 24px);
    transition: background-color 0.25s ease, color 0.25s ease;
    cursor: default;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:hover,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:focus-within {
    background-color: var(--pag-box-hover-bg, #1BCDC4) !important;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box-heading {
    margin: 0 0 12px;
    color: var(--pag-box-heading-color, #FFFFFF);
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box-text {
    margin: 0;
    color: var(--pag-box-paragraph-color, #FFFFFF);
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box-text p,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box-text a,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box-text li {
    margin: 0;
    color: var(--pag-box-paragraph-color, #FFFFFF);
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:hover .polaroid-audience-grid__box-heading,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:focus-within .polaroid-audience-grid__box-heading,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:hover .polaroid-audience-grid__box-text,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:focus-within .polaroid-audience-grid__box-text,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:hover .polaroid-audience-grid__box-text p,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:focus-within .polaroid-audience-grid__box-text p,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:hover .polaroid-audience-grid__box-text a,
  #shopify-section-{{ section.id }} .polaroid-audience-grid__box:focus-within .polaroid-audience-grid__box-text a {
    color: var(--pag-box-hover-text, #0E3458) !important;
  }

  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .polaroid-audience-grid__grid {
      gap: var(--pag-box-gap-tablet, 16px);
    }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .polaroid-audience-grid__grid {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--pag-box-gap-mobile, 16px);
    }
  }

  {%- for block in section.blocks -%}
    {%- if block.settings.heading_font_size > 0 -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-heading {
        font-size: {{ block.settings.heading_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.heading_font_weight != blank and block.settings.heading_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-heading {
        font-weight: {{ block.settings.heading_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.heading_font_color != blank -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-heading {
        color: {{ block.settings.heading_font_color }} !important;
      }
    {%- endif -%}
    {%- if block.settings.paragraph_font_size > 0 -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text,
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text p {
        font-size: {{ block.settings.paragraph_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.paragraph_font_weight != blank and block.settings.paragraph_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text,
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text p {
        font-weight: {{ block.settings.paragraph_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.paragraph_font_color != blank -%}
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text,
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text p,
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text a,
      #shopify-section-{{ section.id }} #pag-box-{{ block.id }} .polaroid-audience-grid__box-text li {
        color: {{ block.settings.paragraph_font_color }} !important;
      }
    {%- endif -%}
    {%- liquid
      assign block_hover_text = block.settings.hover_text_color | default: '#0E3458'
    -%}
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:hover .polaroid-audience-grid__box-heading,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:focus-within .polaroid-audience-grid__box-heading,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:hover .polaroid-audience-grid__box-text,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:focus-within .polaroid-audience-grid__box-text,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:hover .polaroid-audience-grid__box-text p,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:focus-within .polaroid-audience-grid__box-text p,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:hover .polaroid-audience-grid__box-text a,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:focus-within .polaroid-audience-grid__box-text a,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:hover .polaroid-audience-grid__box-text li,
    #shopify-section-{{ section.id }} #pag-box-{{ block.id }}:focus-within .polaroid-audience-grid__box-text li {
      color: {{ block_hover_text }} !important;
    }
  {%- endfor -%}
</style>

{% schema %}
{
  "name": "Polaroid audience grid",
  "tag": "section",
  "class": "section-polaroid-audience-grid",
  "settings": [
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#0E3458",
      "info": "Applies to the outer section only, not inner cards or boxes. Shown behind the background image."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Section background image (desktop)",
      "info": "Applies to the outer section only, not inner cards or boxes."
    },
    {
      "type": "image_picker",
      "id": "background_image_tablet",
      "label": "Section background image (tablet)",
      "info": "Optional. 768px–1023px. Falls back to desktop image when empty."
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Section background image (mobile)",
      "info": "Optional. 767px and below. Falls back to tablet or desktop when empty."
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background image size",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "auto", "label": "Auto" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top center" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "left center", "label": "Left center" },
        { "value": "right center", "label": "Right center" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Built for Teachers and Leaders Supporting"
    },
    {
      "type": "color",
      "id": "heading_before_color",
      "label": "Color (before highlight)",
      "default": "#FFFFFF",
      "info": "Empty = theme heading color."
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Mathematical Thinking"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)"
    },
    {
      "type": "color",
      "id": "heading_after_color",
      "label": "Color (after highlight)",
      "info": "Empty = same as color before highlight."
    },
    {
      "type": "range",
      "id": "heading_after_font_size",
      "label": "Font size (after highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
