{% render 'section-font-vars', section: section %}

{%- liquid
  assign dots_size = section.settings.dots_size | default: 4
  assign dots_spacing = section.settings.dots_spacing | default: 24
  if dots_spacing < dots_size
    assign dots_spacing = dots_size | plus: 2
  endif
  assign content_col = section.settings.column_1_width | default: 50
  assign image_col_setting = section.settings.column_2_width | default: 0
  if image_col_setting > 0
    assign image_col = image_col_setting
  else
    assign image_col = 100 | minus: content_col
  endif
  assign gap_d = section.settings.column_gap | default: 48
  assign gap_t = section.settings.column_gap_tablet
  if gap_t == 0
    if section.settings.stack_on_tablet
      assign gap_t = 32
    else
      assign gap_t = gap_d
    endif
  endif
  assign gap_m = section.settings.column_gap_mobile
  if gap_m == 0
    if section.settings.stack_on_mobile
      assign gap_m = 32
    else
      assign gap_m = gap_d
    endif
  endif
  assign divider_enabled = true
  if section.settings.divider_style == 'none'
    assign divider_enabled = false
  endif
  assign steps_gap_d = section.settings.steps_gap | default: 0
  assign steps_gap_t = section.settings.steps_gap_tablet | default: 0
  if steps_gap_t == 0
    assign steps_gap_t = steps_gap_d
  endif
  assign steps_gap_m = section.settings.steps_gap_mobile | default: 0
  if steps_gap_m == 0
    assign steps_gap_m = steps_gap_t
  endif
-%}

<section class="process-steps section-spacing" aria-labelledby="process-heading-{{ section.id }}">
  <div class="process-steps__inner">
    <div class="process-steps__header text-center">
      <div id="process-heading-{{ section.id }}">
        {%- liquid
          assign process_heading_font_color = section.settings.heading_font_color
          if process_heading_font_color == blank
            assign process_heading_font_color = section.settings.heading_color
          endif
          assign process_heading_before_color = section.settings.heading_before_color
          if process_heading_before_color == blank
            assign process_heading_before_color = section.settings.heading_color
          endif
        -%}
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_font_size: section.settings.heading_font_size,
          heading_weight: section.settings.heading_weight,
          heading_font_color: process_heading_font_color,
          heading_before: section.settings.heading_before,
          heading_before_weight: section.settings.heading_before_weight,
          heading_before_font_size: section.settings.heading_before_font_size,
          heading_before_color: process_heading_before_color,
          heading_highlight: section.settings.heading_highlight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_highlight_font_size: section.settings.heading_highlight_font_size,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>
      {%- if section.settings.subtext != blank -%}
        <p class="section-text process-steps__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="process-steps__list">
      {%- for block in section.blocks -%}
        <div class="process-step{% if forloop.index0 == 1 or forloop.index0 == 3 or forloop.index0 == 5 %} process-step--reverse{% endif %}" {{ block.shopify_attributes }} id="process-step-{{ block.id }}">
          {%- liquid
            assign show_dots_top = false
            assign show_dots_bottom = false
            assign step_divider = block.settings.divider_position | default: ''
            if step_divider == blank
              if block.settings.show_dots_top
                assign show_dots_top = true
              endif
              if block.settings.show_dots_bottom
                assign show_dots_bottom = true
              endif
            elsif step_divider == 'top'
              assign show_dots_top = true
            elsif step_divider == 'bottom'
              assign show_dots_bottom = true
            elsif step_divider == 'both'
              assign show_dots_top = true
              assign show_dots_bottom = true
            endif
          -%}
          {%- if divider_enabled and show_dots_top -%}
            {% render 'process-step-dots', section: section, position: 'top', dots_size: dots_size, dots_spacing: dots_spacing %}
          {%- endif -%}
          <div class="process-step__body{% if section.settings.mobile_stack_order == 'content-first' %} process-step__body--stack-content-first{% endif %}">
            <div class="process-step__content">
              {%- if block.settings.step_label != blank -%}
                <span class="process-step__label">{{ block.settings.step_label }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="section-heading section-heading--h3 process-step__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="section-text rte process-step__text">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="process-step__cta">
                  {% render 'button',
                    label: block.settings.button_label,
                    url: block.settings.button_url,
                    style: block.settings.button_style | default: 'primary'
                  %}
                </div>
              {%- endif -%}
            </div>
            <div class="process-step__media">
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign step_img_width = block.settings.image_width | default: 800
                  if block.settings.image_src_width_tablet > 0 and block.settings.image_src_width_tablet < step_img_width
                    assign step_img_width = block.settings.image_src_width_tablet
                  endif
                  if block.settings.image_src_width_mobile > 0 and block.settings.image_src_width_mobile < step_img_width
                    assign step_img_width = block.settings.image_src_width_mobile
                  endif
                -%}
                {% render 'responsive-image',
                  image: block.settings.image,
                  alt: block.settings.image_alt,
                  class: 'process-step__image',
                  loading: block.settings.image_loading,
                  width: step_img_width
                %}
              {%- else -%}
                <div class="process-step__image process-step__image--placeholder" role="img" aria-label="{{ block.settings.image_alt | default: 'Step image' | escape }}">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
          </div>
          {%- if divider_enabled and show_dots_bottom -%}
            {% render 'process-step-dots', section: section, position: 'bottom', dots_size: dots_size, dots_spacing: dots_spacing %}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.text_after_list != blank -%}
      <div class="section-text rte process-steps__text-after text-center">{{ section.settings.text_after_list }}</div>
    {%- endif -%}
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.process-steps', pad_x: '.process-steps__inner', pad_x_fallback: true %}
  #shopify-section-{{ section.id }} .process-steps__inner {
    width: 100%;
    max-width: 1240px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
  }
  {%- comment -%}
    Desktop-only two-column grid. Reverse rows use a more specific selector than base.css;
    without a min-width wrapper that rule wins on tablet and blocks stacking for steps 2, 4, 6.
  {%- endcomment -%}
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .process-step__body {
      grid-template-columns: minmax(0, {{ content_col }}fr) minmax(0, {{ image_col }}fr);
      gap: {{ gap_d }}px;
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: minmax(0, {{ image_col }}fr) minmax(0, {{ content_col }}fr);
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__content { order: 2; }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__media { order: 1; }
  }
  {%- if section.settings.stack_on_tablet -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .process-step__body,
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: 1fr;
      gap: {{ gap_t }}px;
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__content,
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__media {
      order: unset;
    }
  }
  {%- else -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .process-step__body {
      grid-template-columns: minmax(0, {{ content_col }}fr) minmax(0, {{ image_col }}fr);
      gap: {{ gap_t }}px;
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: minmax(0, {{ image_col }}fr) minmax(0, {{ content_col }}fr);
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__content { order: 2; }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__media { order: 1; }
  }
  {%- endif -%}
  {%- if section.settings.stack_on_mobile -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .process-step__body,
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: 1fr;
      gap: {{ gap_m }}px;
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__content,
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__media {
      order: unset;
    }
  }
  {%- else -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .process-step__body {
      grid-template-columns: minmax(0, {{ content_col }}fr) minmax(0, {{ image_col }}fr);
      gap: {{ gap_m }}px;
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: minmax(0, {{ image_col }}fr) minmax(0, {{ content_col }}fr);
    }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__content { order: 2; }
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__media { order: 1; }
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} .process-steps__list {
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .process-step {
    position: relative;
    overflow: visible;
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .process-step + .process-step {
      margin-top: {{ steps_gap_d }}px;
    }
    {%- if steps_gap_d < 0 -%}
    {%- for block in section.blocks -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} {
        z-index: {{ forloop.index }};
      }
    {%- endfor -%}
    {%- endif -%}
  }
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .process-step + .process-step {
      margin-top: {{ steps_gap_t }}px;
    }
    {%- if steps_gap_t < 0 -%}
    {%- for block in section.blocks -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} {
        z-index: {{ forloop.index }};
      }
    {%- endfor -%}
    {%- endif -%}
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .process-step + .process-step {
      margin-top: {{ steps_gap_m }}px;
    }
    {%- if steps_gap_m < 0 -%}
    {%- for block in section.blocks -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} {
        z-index: {{ forloop.index }};
      }
    {%- endfor -%}
    {%- endif -%}
  }
  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .process-step__body--stack-content-first .process-step__content {
      order: -1;
    }
    #shopify-section-{{ section.id }} .process-step__body--stack-content-first .process-step__media {
      order: 0;
    }
  }
  #shopify-section-{{ section.id }} .process-step__dots {
      width: calc((100vw - 80px) * (var(--dots-width, 100) / 100));
      height: var(--dots-spacing, 24px);
      margin-left: calc(50% - 50vw + 40px);
      margin-right: 0;
      min-height: var(--dots-size, 4px);
      background-position: 0 50%;
      flex-shrink: 0;
      transform: translateX(var(--dots-offset-left, 0%));
    }
    #shopify-section-{{ section.id }} .process-step__dots--top {
      margin-bottom: {{ section.settings.dots_divider_spacing_top | default: 32 }}px;
    }
    #shopify-section-{{ section.id }} .process-step__dots--bottom {
      margin-top: {{ section.settings.dots_divider_spacing_bottom | default: 32 }}px;
    }
    #shopify-section-{{ section.id }} .process-step__dots--circle {
      background-image: radial-gradient(
        var(--dots-color) calc(var(--dots-size) / 2),
        transparent calc(var(--dots-size) / 2)
      );
      background-size: var(--dots-spacing) var(--dots-spacing);
    }
    #shopify-section-{{ section.id }} .process-step__dots--square {
      background-image:
        linear-gradient(var(--dots-color) var(--dots-size), transparent var(--dots-size)),
        linear-gradient(90deg, var(--dots-color) var(--dots-size), transparent var(--dots-size));
      background-size: var(--dots-spacing) var(--dots-spacing);
    }
  {%- liquid
    assign process_heading_base_color = section.settings.heading_before_color
    if process_heading_base_color == blank
      assign process_heading_base_color = section.settings.heading_color
    endif
  -%}
  {%- if process_heading_base_color != blank -%}
    #shopify-section-{{ section.id }} #process-heading-{{ section.id }} .section-heading {
      color: {{ process_heading_base_color }};
    }
    #shopify-section-{{ section.id }} #process-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#51ADA0' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #process-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_size > 0 -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      font-size: {{ section.settings.subtext_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_weight != blank and section.settings.subtext_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      font-weight: {{ section.settings.subtext_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_color != blank -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      color: {{ section.settings.subtext_font_color }};
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_size > 0 -%}
    #shopify-section-{{ section.id }} .process-steps__text-after,
    #shopify-section-{{ section.id }} .process-steps__text-after p {
      font-size: {{ section.settings.text_after_list_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_weight != blank and section.settings.text_after_list_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .process-steps__text-after,
    #shopify-section-{{ section.id }} .process-steps__text-after p {
      font-weight: {{ section.settings.text_after_list_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_after_list_font_color != blank -%}
    #shopify-section-{{ section.id }} .process-steps__text-after,
    #shopify-section-{{ section.id }} .process-steps__text-after p,
    #shopify-section-{{ section.id }} .process-steps__text-after li,
    #shopify-section-{{ section.id }} .process-steps__text-after a {
      color: {{ section.settings.text_after_list_font_color }} !important;
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .process-step__image {
    width: 100%;
    height: auto;
    display: block;
  }
  #shopify-section-{{ section.id }} .process-step__image--placeholder {
    aspect-ratio: 16 / 9;
    background: rgba(10, 29, 60, 0.06);
  }
  #shopify-section-{{ section.id }} .process-step__image--placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  {%- for block in section.blocks -%}
    {%- if block.settings.step_label_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        font-size: {{ block.settings.step_label_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.step_label_font_weight != blank and block.settings.step_label_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        font-weight: {{ block.settings.step_label_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.step_label_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        color: {{ block.settings.step_label_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text li,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text a {
        color: {{ block.settings.text_font_color }} !important;
      }
    {%- endif -%}
    #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
      object-fit: {{ block.settings.image_object_fit | default: 'cover' }};
      {%- if block.settings.image_border_radius > 0 -%}
      border-radius: {{ block.settings.image_border_radius }}px;
      {%- endif -%}
      {%- if block.settings.image_max_width > 0 -%}
      max-width: {{ block.settings.image_max_width }}px;
      margin-left: auto;
      margin-right: auto;
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__media {
      {%- if block.settings.image_align == 'center' -%}
      display: flex;
      justify-content: center;
      {%- elsif block.settings.image_align == 'right' -%}
      display: flex;
      justify-content: flex-end;
      {%- endif -%}
    }
    {%- if block.settings.image_display_width_tablet > 0 -%}
    @media screen and (min-width: 768px) and (max-width: 1023px) {
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
        width: {{ block.settings.image_display_width_tablet }}%;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
    }
    {%- endif -%}
    {%- if block.settings.image_display_width_mobile > 0 -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
        width: {{ block.settings.image_display_width_mobile }}%;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
    }
    {%- endif -%}
    {%- if block.settings.image_max_width_tablet > 0 -%}
    @media screen and (min-width: 768px) and (max-width: 1023px) {
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
        max-width: {{ block.settings.image_max_width_tablet }}px;
      }
    }
    {%- endif -%}
    {%- if block.settings.image_max_width_mobile > 0 -%}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
        max-width: {{ block.settings.image_max_width_mobile }}px;
      }
    }
    {%- endif -%}
  {%- endfor -%}
</style>

{% schema %}
{
  "name": "Process Steps",
  "tag": "section",
  "class": "section-process-steps",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Press Enter for a line break."
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color",
      "info": "Empty = theme heading color. Used when the single heading field is filled."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size (single line heading)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "How It "
    },
    {
      "type": "color",
      "id": "heading_before_color",
      "label": "Color (before highlight)",
      "info": "Empty = theme heading color."
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
