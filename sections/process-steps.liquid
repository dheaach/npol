{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'process-step__body' %}

{%- liquid
  assign dots_size = section.settings.dots_size | default: 4
  assign dots_spacing = section.settings.dots_spacing | default: 24
  if dots_spacing < dots_size
    assign dots_spacing = dots_size | plus: 2
  endif
  assign content_col = section.settings.column_1_width | default: 50
  assign image_col_setting = section.settings.column_2_width | default: 0
  if image_col_setting > 0
    assign image_col = image_col_setting
  else
    assign image_col = 100 | minus: content_col
  endif
-%}

<section class="process-steps section-spacing" aria-labelledby="process-heading-{{ section.id }}">
  <div class="process-steps__inner">
    <div class="process-steps__header text-center">
      <div id="process-heading-{{ section.id }}">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_font_size: section.settings.heading_font_size,
          heading_weight: section.settings.heading_weight,
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_before_weight: section.settings.heading_before_weight,
          heading_before_font_size: section.settings.heading_before_font_size,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_highlight_font_size: section.settings.heading_highlight_font_size,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>
      {%- if section.settings.subtext != blank -%}
        <p class="section-text process-steps__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="process-steps__list">
      {%- for block in section.blocks -%}
        <div class="process-step{% if forloop.index0 == 1 or forloop.index0 == 3 or forloop.index0 == 5 %} process-step--reverse{% endif %}" {{ block.shopify_attributes }} id="process-step-{{ block.id }}">
          {%- if block.settings.show_dots_top -%}
            {% render 'process-step-dots', section: section, position: 'top', dots_size: dots_size, dots_spacing: dots_spacing %}
          {%- endif -%}
          <div class="process-step__body">
            <div class="process-step__content">
              {%- if block.settings.step_label != blank -%}
                <span class="process-step__label">{{ block.settings.step_label }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="section-heading section-heading--h3 process-step__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="section-text rte process-step__text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
            <div class="process-step__media">
              {%- if block.settings.image != blank -%}
                {% render 'responsive-image',
                  image: block.settings.image,
                  alt: block.settings.image_alt,
                  class: 'process-step__image',
                  loading: block.settings.image_loading,
                  width: block.settings.image_width | default: 800
                %}
              {%- else -%}
                <div class="process-step__image process-step__image--placeholder" role="img" aria-label="{{ block.settings.image_alt | default: 'Step image' | escape }}">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
          </div>
          {%- if block.settings.show_dots_bottom -%}
            {% render 'process-step-dots', section: section, position: 'bottom', dots_size: dots_size, dots_spacing: dots_spacing %}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .process-steps__inner {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--section-padding-x, 40px);
    padding-right: var(--section-padding-x, 40px);
    box-sizing: border-box;
  }
  {%- comment -%} Reverse rows: swap column tracks so image keeps image width and content keeps content width {%- endcomment -%}
  #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
    grid-template-columns: minmax(0, {{ image_col }}fr) minmax(0, {{ content_col }}fr);
  }
  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .process-step--reverse .process-step__body {
      grid-template-columns: 1fr;
    }
  }
  #shopify-section-{{ section.id }} .process-step__dots {
      width: var(--dots-width, 100%);
      height: var(--dots-spacing, 24px);
      margin-left: var(--dots-offset-left, 0%);
      margin-right: auto;
      min-height: var(--dots-size, 4px);
      background-position: 0 50%;
      flex-shrink: 0;
    }
    #shopify-section-{{ section.id }} .process-step__dots--top {
      margin-bottom: {{ section.settings.dots_divider_spacing_top | default: 32 }}px;
    }
    #shopify-section-{{ section.id }} .process-step__dots--bottom {
      margin-top: {{ section.settings.dots_divider_spacing_bottom | default: 32 }}px;
    }
    #shopify-section-{{ section.id }} .process-step__dots--circle {
      background-image: radial-gradient(
        var(--dots-color) calc(var(--dots-size) / 2),
        transparent calc(var(--dots-size) / 2)
      );
      background-size: var(--dots-spacing) var(--dots-spacing);
    }
    #shopify-section-{{ section.id }} .process-step__dots--square {
      background-image:
        linear-gradient(var(--dots-color) var(--dots-size), transparent var(--dots-size)),
        linear-gradient(90deg, var(--dots-color) var(--dots-size), transparent var(--dots-size));
      background-size: var(--dots-spacing) var(--dots-spacing);
    }
  {%- if section.settings.subtext_font_size > 0 -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      font-size: {{ section.settings.subtext_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_weight != blank and section.settings.subtext_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      font-weight: {{ section.settings.subtext_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.subtext_font_color != blank -%}
    #shopify-section-{{ section.id }} .process-steps__subtext {
      color: {{ section.settings.subtext_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .process-step__image {
    width: 100%;
    height: auto;
    display: block;
  }
  #shopify-section-{{ section.id }} .process-step__image--placeholder {
    aspect-ratio: 16 / 9;
    background: rgba(10, 29, 60, 0.06);
  }
  #shopify-section-{{ section.id }} .process-step__image--placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  {%- for block in section.blocks -%}
    {%- if block.settings.step_label_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        font-size: {{ block.settings.step_label_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.step_label_font_weight != blank and block.settings.step_label_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        font-weight: {{ block.settings.step_label_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.step_label_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__label {
        color: {{ block.settings.step_label_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_color != blank -%}
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text p,
      #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__text a {
        color: {{ block.settings.text_font_color }} !important;
      }
    {%- endif -%}
    #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__image {
      object-fit: {{ block.settings.image_object_fit | default: 'cover' }};
      {%- if block.settings.image_border_radius > 0 -%}
      border-radius: {{ block.settings.image_border_radius }}px;
      {%- endif -%}
      {%- if block.settings.image_max_width > 0 -%}
      max-width: {{ block.settings.image_max_width }}px;
      margin-left: auto;
      margin-right: auto;
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} #process-step-{{ block.id }} .process-step__media {
      {%- if block.settings.image_align == 'center' -%}
      display: flex;
      justify-content: center;
      {%- elsif block.settings.image_align == 'right' -%}
      display: flex;
      justify-content: flex-end;
      {%- endif -%}
    }
  {%- endfor -%}
</style>

{% schema %}
