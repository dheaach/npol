{% render 'section-font-vars', section: section %}
{% render 'section-column-widths', section: section, grid_class: 'program-cards__header' %}

{%- liquid
  assign program_cards_bg_url = blank
  if section.settings.background_image != blank
    assign program_cards_bg_url = section.settings.background_image | image_url: width: 2400
  endif
-%}

{%- if program_cards_bg_url != blank -%}
  <div class="program-cards__bg" aria-hidden="true">
    <img
      class="program-cards__bg-image"
      src="{{ program_cards_bg_url }}"
      alt=""
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
      loading="lazy"
    >
  </div>
{%- endif -%}

<section class="program-cards section-spacing" aria-labelledby="program-heading-{{ section.id }}">
  <div class="page-width">
    <div class="program-cards__header">
      <div class="program-cards__header-left text-{{ section.settings.heading_text_alignment | default: 'left' }}" id="program-heading-{{ section.id }}">
        {%- liquid
          assign program_heading_font_color = section.settings.heading_font_color
          if program_heading_font_color == blank
            assign program_heading_font_color = section.settings.heading_color
          endif
          assign program_heading_before_color = section.settings.heading_before_color
          if program_heading_before_color == blank
            assign program_heading_before_color = section.settings.heading_color
          endif
        -%}
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_weight: section.settings.heading_weight,
          heading_font_size: section.settings.heading_font_size,
          heading_font_color: program_heading_font_color,
          heading_before: section.settings.heading_before,
          heading_before_weight: section.settings.heading_before_weight,
          heading_before_font_size: section.settings.heading_before_font_size,
          heading_before_color: program_heading_before_color,
          heading_highlight: section.settings.heading_highlight,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_highlight_font_size: section.settings.heading_highlight_font_size,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_size,
          highlight_color: section.settings.highlight_color
        %}
      </div>
      {%- if section.settings.description != blank -%}
        <div class="program-cards__header-right section-text rte text-{{ section.settings.description_text_alignment | default: 'left' }}">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    {%- liquid
      assign pc_gap_d = section.settings.cards_grid_gap | default: 0
      if pc_gap_d == 0
        assign pc_gap_d = 24
      endif
      assign pc_gap_t = section.settings.cards_grid_gap_tablet | default: 0
      if pc_gap_t == 0
        assign pc_gap_t = pc_gap_d
      endif
      assign pc_gap_m = section.settings.cards_grid_gap_mobile | default: 0
      if pc_gap_m == 0
        assign pc_gap_m = pc_gap_t
      endif
      assign pc_grid_justify = section.settings.grid_alignment | default: 'center'
      if pc_grid_justify == 'stretch' or pc_grid_justify == 'start'
        assign pc_grid_justify = 'flex-start'
      endif
    -%}
    <div
      class="program-cards__grid"
      style="
        --program-cards-columns: {{ section.settings.cards_per_row | default: 3 }};
        --program-cards-columns-tablet: {{ section.settings.cards_per_row_tablet | default: 2 }};
        --program-cards-gap: {{ pc_gap_d }}px;
        --program-cards-gap-tablet: {{ pc_gap_t }}px;
        --program-cards-gap-mobile: {{ pc_gap_m }}px;
        --program-cards-justify: {{ pc_grid_justify }};
      "
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign text_align = block.settings.text_alignment | default: 'left'
          assign icon_size = block.settings.icon_size | default: 48
          assign element_spacing = block.settings.element_spacing | default: 16
          assign spacing_icon_title = block.settings.spacing_icon_title | default: element_spacing
          assign spacing_title_text = block.settings.spacing_title_text | default: element_spacing
          assign dots_size = block.settings.dots_size | default: 6
          assign dots_spacing = block.settings.dots_spacing | default: 12
          if dots_spacing < dots_size
            assign dots_spacing = dots_size | plus: 2
          endif
          assign dots_line_spacing = block.settings.dots_line_spacing | default: 12
          assign padding_top = block.settings.padding_top | default: 28
          assign padding_bottom = block.settings.padding_bottom | default: 28
          assign padding_left = block.settings.padding_left | default: 24
          assign padding_right = block.settings.padding_right | default: 24
          assign body_padding_top = padding_top
          if block.settings.tag_label != blank
            assign body_padding_top = padding_top | plus: 20
          endif

          case block.settings.card_alignment
            when 'center'
              assign card_align_items = 'center'
            when 'right'
              assign card_align_items = 'flex-end'
            else
              assign card_align_items = 'flex-start'
          endcase

        -%}
        <article
          id="program-card-{{ block.id }}"
          class="program-card{% if block.settings.tag_label != blank %} program-card--has-tag{% endif %}"
          {{ block.shopify_attributes }}
          style="
            --tag-fallback-bg: {{ block.settings.tag_color }};
            --dots-color: {{ block.settings.dots_color | default: '#0A1D3C' }};
            --dots-size: {{ dots_size }}px;
            --dots-spacing: {{ dots_spacing }}px;
            --dots-line-spacing: {{ dots_line_spacing }}px;
            --icon-size: {{ icon_size }}px;
            --spacing-icon-title: {{ spacing_icon_title }}px;
            --spacing-title-text: {{ spacing_title_text }}px;
          "
        >
          {%- if block.settings.tag_label != blank -%}
            <div
              class="program-card__tag"
              style="{% if block.settings.tag_bg_image != blank %}background-image: url('{{ block.settings.tag_bg_image | image_url: width: 1200 }}');{% endif %} background-color: {{ block.settings.tag_color }};"
            >
              <span class="program-card__tag-label">{{ block.settings.tag_label }}</span>
            </div>
          {%- endif -%}

          <div
            class="program-card__body text-{{ text_align }}"
            style="
              background-color: {{ block.settings.card_bg_color }};
              align-items: {{ card_align_items }};
              padding: {{ body_padding_top }}px {{ padding_right }}px {{ padding_bottom }}px {{ padding_left }}px;
            "
          >
            {%- if block.settings.icon != blank -%}
              <div class="program-card__icon">
                {% render 'responsive-image',
                  image: block.settings.icon,
                  alt: block.settings.icon_alt,
                  class: 'program-card__icon-image',
                  width: icon_size
                %}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <div class="program-card__title-group">
                <span class="program-card__dots program-card__dots--top" aria-hidden="true"></span>
                <h3 class="section-heading section-heading--h3 program-card__title">{{ block.settings.title }}</h3>
                <span class="program-card__dots program-card__dots--bottom" aria-hidden="true"></span>
              </div>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="section-text rte program-card__text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <p class="program-cards__footer section-text text-center">{{ section.settings.footer_text }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }
  {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .program-cards__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .program-cards__bg-image {
    width: 100%;
    height: 100%;
    display: block;
  }
  {%- if program_cards_bg_url != blank -%}
    #shopify-section-{{ section.id }} .program-cards__bg-image {
      object-fit: {{ section.settings.background_object_fit | default: 'cover' }};
      object-position: {{ section.settings.background_position | default: 'center center' }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .program-cards {
    position: relative;
    z-index: 1;
  }
  {% render 'section-spacing-styles', root: '.program-cards', pad_x: '.page-width' %}
  {% render 'section-spacing-gap', section: section, selector: '.program-cards__grid', gap_id: 'cards_grid_gap', stack_breakpoint: '0' %}
  {%- if section.settings.column_1_width <= 0 -%}
    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} .program-cards__header-left {
        display: none;
      }
    }
  {%- endif -%}
  {%- liquid
    assign program_heading_color = section.settings.heading_font_color
    if program_heading_color == blank
      assign program_heading_color = section.settings.heading_before_color
    endif
    if program_heading_color == blank
      assign program_heading_color = section.settings.heading_color
    endif
  -%}
  {%- if program_heading_color != blank -%}
    #shopify-section-{{ section.id }} #program-heading-{{ section.id }} .section-heading {
      color: {{ program_heading_color }};
    }
    #shopify-section-{{ section.id }} #program-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#51ADA0' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #program-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}
  {%- if section.settings.description_font_size > 0 -%}
    #shopify-section-{{ section.id }} .program-cards__header-right,
    #shopify-section-{{ section.id }} .program-cards__header-right p {
      font-size: {{ section.settings.description_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.description_font_weight != blank and section.settings.description_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .program-cards__header-right,
    #shopify-section-{{ section.id }} .program-cards__header-right p {
      font-weight: {{ section.settings.description_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.description_font_color != blank -%}
    #shopify-section-{{ section.id }} .program-cards__header-right,
    #shopify-section-{{ section.id }} .program-cards__header-right p,
    #shopify-section-{{ section.id }} .program-cards__header-right li,
    #shopify-section-{{ section.id }} .program-cards__header-right a {
      color: {{ section.settings.description_font_color }} !important;
    }
  {%- endif -%}
  {%- if section.settings.footer_font_size > 0 -%}
    #shopify-section-{{ section.id }} .program-cards__footer {
      font-size: {{ section.settings.footer_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.footer_font_weight != blank and section.settings.footer_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .program-cards__footer {
      font-weight: {{ section.settings.footer_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.footer_font_color != blank -%}
    #shopify-section-{{ section.id }} .program-cards__footer {
      color: {{ section.settings.footer_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .program-card__title,
  #shopify-section-{{ section.id }} .program-card__text,
  #shopify-section-{{ section.id }} .program-card__title-group {
    width: 100%;
  }
  #shopify-section-{{ section.id }} .program-cards__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: var(--program-cards-justify, center);
  }
  #shopify-section-{{ section.id }} .program-card {
    flex: 0 0 calc((100% - (var(--program-cards-columns, 3) - 1) * var(--program-cards-gap, 24px)) / var(--program-cards-columns, 3));
    max-width: calc((100% - (var(--program-cards-columns, 3) - 1) * var(--program-cards-gap, 24px)) / var(--program-cards-columns, 3));
    min-width: 0;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .program-card__icon {
    width: var(--icon-size, 48px);
    height: var(--icon-size, 48px);
  }
  #shopify-section-{{ section.id }} .program-card__icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .program-card__tag {
    width: max-content;
    max-width: 100%;
    padding: 10px 20px;
    background-color: var(--tag-fallback-bg, var(--color-yellow));
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
  }
  #shopify-section-{{ section.id }} .program-card__body > .program-card__icon {
    margin-bottom: var(--spacing-icon-title, 16px);
  }
  #shopify-section-{{ section.id }} .program-card__body > .program-card__title-group {
    margin-bottom: var(--spacing-title-text, 16px);
  }
  #shopify-section-{{ section.id }} .program-card__body > .program-card__icon:last-child,
  #shopify-section-{{ section.id }} .program-card__body > .program-card__title-group:last-child {
    margin-bottom: 0;
  }
  #shopify-section-{{ section.id }} .program-card__dots {
    height: var(--dots-spacing, 12px);
    background-image: radial-gradient(
      var(--dots-color, #0A1D3C) calc(var(--dots-size, 6px) / 2),
      transparent calc(var(--dots-size, 6px) / 2)
    );
    background-size: var(--dots-spacing, 12px) var(--dots-spacing, 12px);
    background-position: 0 50%;
  }
  #shopify-section-{{ section.id }} .program-card__title-group {
    gap: var(--dots-line-spacing, 12px);
  }
  {%- for block in section.blocks -%}
    {%- liquid
      assign card_title_color = block.settings.title_font_color
      if card_title_color == blank
        assign card_title_color = block.settings.text_color
      endif
      assign card_text_color = block.settings.text_font_color
      if card_text_color == blank
        assign card_text_color = block.settings.text_color
      endif
      assign card_tag_color = block.settings.tag_font_color
    -%}
    {%- if card_title_color != blank -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__title {
        color: {{ card_title_color }};
      }
    {%- endif -%}
    {%- if card_text_color != blank -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text p,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text li,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text a {
        color: {{ card_text_color }} !important;
      }
    {%- endif -%}
    {%- if card_tag_color != blank -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__tag-label {
        color: {{ card_tag_color }};
      }
    {%- endif -%}
    {%- if block.settings.tag_font_weight != blank and block.settings.tag_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__tag-label {
        font-weight: {{ block.settings.tag_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text p {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text p,
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__text li {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.tag_font_size > 0 -%}
      #shopify-section-{{ section.id }} #program-card-{{ block.id }} .program-card__tag-label {
        font-size: {{ block.settings.tag_font_size }}px;
      }
    {%- endif -%}
  {%- endfor -%}
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .program-card {
      flex-basis: calc((100% - (var(--program-cards-columns-tablet, 2) - 1) * var(--program-cards-gap-tablet, 24px)) / var(--program-cards-columns-tablet, 2));
      max-width: calc((100% - (var(--program-cards-columns-tablet, 2) - 1) * var(--program-cards-gap-tablet, 24px)) / var(--program-cards-columns-tablet, 2));
    }
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .program-card {
      flex: 0 0 100%;
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Program Feature Cards",
  "tag": "section",
  "class": "section-program-cards",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color",
      "info": "Empty = theme heading color. Used when the single Heading field is filled."
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Not Another "
    },
    {
      "type": "color",
      "id": "heading_before_color",
      "label": "Color (before highlight)",
      "info": "Empty = theme heading color."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Program"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#51ADA0"
    },
    {
      "type": "header",
      "content": "Heading font size"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading scale (theme)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2",
      "info": "Theme typography scale. Custom sizes below override when set above 0."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size (single line heading)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only. Used when the single Heading field is filled."
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit",
      "info": "Used when single line heading is filled in"
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (legacy fallback)",
      "default": "#0A1D3C",
      "info": "Used when per-segment heading colors above are empty."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description (right side)"
    },
    {
      "type": "color",
      "id": "description_font_color",
      "label": "Description color"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "description_font_weight",
      "label": "Description font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
