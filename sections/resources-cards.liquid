{% render 'section-font-vars', section: section %}

<section class="resources-cards section-spacing" style="background-color: {{ section.settings.background_color | default: '#ADE8F6' }};" aria-labelledby="resources-heading-{{ section.id }}">
  <div class="page-width">
    <div class="resources-cards__inner">
      <div class="resources-cards__header">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_before: section.settings.heading_before,
          heading_highlight: section.settings.heading_highlight,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
        {%- if section.settings.description != blank -%}
          <div class="section-text rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>

      <div class="resources-cards__grid">
        {%- for block in section.blocks -%}
          <article class="resource-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="resource-card__image">
                {% render 'responsive-image', image: block.settings.image, alt: block.settings.image_alt, width: 400 %}
              </div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="section-heading section-heading--h3 resource-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="section-text rte resource-card__text">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              {% render 'button',
                label: block.settings.button_label,
                url: block.settings.button_url,
                style: block.settings.button_style | default: 'yellow'
              %}
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Resources Cards",
  "tag": "section",
  "class": "section-resources-cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Additional "
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Resources"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ADE8F6"
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text (SEO)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Resource Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "yellow", "label": "Yellow" },
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "yellow"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Resources Cards",
    "blocks": [
      { "type": "resource" },
      { "type": "resource" }
    ]
  }]
}
{% endschema %}
