{% render 'section-font-vars', section: section %}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#ADE8F6'
  assign bg_opacity = section.settings.background_opacity | default: 100
  assign bg_alpha = bg_opacity | times: 1.0 | divided_by: 100.0
  assign bg_color_rgba = bg_color | color_modify: 'alpha', bg_alpha
-%}

<section
  class="resources-cards section-spacing"
  aria-labelledby="resources-heading-{{ section.id }}"
>
  <div class="resources-cards__inner">
    <div class="resources-cards__header text-center">
      <div id="resources-heading-{{ section.id }}">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_font_size: section.settings.heading_font_size,
          heading_weight: section.settings.heading_weight,
          heading_before: section.settings.heading_before,
          heading_before_font_size: section.settings.heading_before_font_size,
          heading_before_weight: section.settings.heading_before_weight,
          heading_highlight: section.settings.heading_highlight,
          heading_highlight_font_size: section.settings.heading_highlight_font_size,
          heading_highlight_weight: section.settings.heading_highlight_weight,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag,
          highlight_color: section.settings.highlight_color
        %}
      </div>
      {%- if section.settings.description != blank -%}
        <div class="section-text rte resources-cards__description">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="resources-cards__grid">
      {%- for block in section.blocks -%}
        <article class="resource-card" {{ block.shopify_attributes }} id="resource-card-{{ block.id }}">
          {%- if block.settings.image != blank -%}
            <div class="resource-card__media">
              {% render 'responsive-image',
                image: block.settings.image,
                alt: block.settings.image_alt,
                class: 'resource-card__image',
                width: 800
              %}
              {%- if block.settings.title != blank -%}
                <div class="resource-card__overlay">
                  <h3 class="section-heading section-heading--h3 resource-card__title">{{ block.settings.title }}</h3>
                </div>
              {%- endif -%}
            </div>
          {%- elsif block.settings.title != blank -%}
            <h3 class="section-heading section-heading--h3 resource-card__title resource-card__title--plain">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="section-text rte resource-card__text">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <div class="resource-card__cta">
              {% render 'button',
                label: block.settings.button_label,
                url: block.settings.button_url,
                style: block.settings.button_style | default: 'yellow',
                class: 'resource-card__btn'
              %}
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .resources-cards {
    width: 100%;
    background-color: {{ bg_color_rgba }};
  }
  #shopify-section-{{ section.id }} .resources-cards__inner {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
    {%- if section.settings.padding_left > 0 -%}
    padding-left: {{ section.settings.padding_left }}px;
    {%- else -%}
    padding-left: var(--section-padding-x, 40px);
    {%- endif -%}
    {%- if section.settings.padding_right > 0 -%}
    padding-right: {{ section.settings.padding_right }}px;
    {%- else -%}
    padding-right: var(--section-padding-x, 40px);
    {%- endif -%}
  }
  {%- if section.settings.padding_top > 0 -%}
    #shopify-section-{{ section.id }} .resources-cards {
      padding-top: {{ section.settings.padding_top }}px;
    }
  {%- endif -%}
  {%- if section.settings.padding_bottom > 0 -%}
    #shopify-section-{{ section.id }} .resources-cards {
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  {%- endif -%}
  {%- if section.settings.heading_before_color != blank -%}
    #shopify-section-{{ section.id }} #resources-heading-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_before_color }};
    }
    #shopify-section-{{ section.id }} #resources-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#1BCDC4' }};
    }
  {%- endif -%}
  {%- if section.settings.description_font_size > 0 -%}
    #shopify-section-{{ section.id }} .resources-cards__description,
    #shopify-section-{{ section.id }} .resources-cards__description p {
      font-size: {{ section.settings.description_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.description_font_weight != blank and section.settings.description_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .resources-cards__description,
    #shopify-section-{{ section.id }} .resources-cards__description p {
      font-weight: {{ section.settings.description_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.description_font_color != blank -%}
    #shopify-section-{{ section.id }} .resources-cards__description,
    #shopify-section-{{ section.id }} .resources-cards__description p {
      color: {{ section.settings.description_font_color }};
    }
  {%- endif -%}
  {%- for block in section.blocks -%}
    {%- liquid
      assign card_shadow_alpha = block.settings.card_shadow_opacity | default: 10 | times: 1.0 | divided_by: 100.0
      assign card_shadow_rgba = block.settings.card_shadow_color | default: '#0A1D3C' | color_modify: 'alpha', card_shadow_alpha
    -%}
    #shopify-section-{{ section.id }} #resource-card-{{ block.id }} {
      background-color: {{ block.settings.card_bg_color | default: '#ffffff' }};
      {%- if block.settings.card_show_shadow == false -%}
      box-shadow: none;
      {%- else -%}
      box-shadow: {{ block.settings.card_shadow_offset_x | default: 0 }}px {{ block.settings.card_shadow_offset_y | default: 4 }}px {{ block.settings.card_shadow_blur | default: 24 }}px {{ card_shadow_rgba }};
      {%- endif -%}
    }
  {%- endfor -%}
</style>

{% schema %}
{
  "name": "Resources Cards",
  "tag": "section",
  "class": "section-resources-cards",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)",
      "info": "Single line. Or use split heading fields below."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size (single line heading)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Additional "
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "color",
      "id": "heading_before_color",
      "label": "Color (before highlight)",
      "info": "Empty = theme heading color."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Resources"
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_font_color",
      "label": "Description color"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "description_font_weight",
      "label": "Description font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ADE8F6"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100,
      "info": "100 = solid. Lower values make the background more transparent."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default section spacing."
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default section spacing."
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = 40px (20px on mobile)."
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = 40px (20px on mobile)."
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource Card",
      "settings": [
        {
          "type": "header",
          "content": "Card appearance"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card background color",
          "default": "#ffffff"
        },
        {
          "type": "checkbox",
          "id": "card_show_shadow",
          "label": "Show box shadow",
          "default": true
        },
        {
          "type": "range",
          "id": "card_shadow_offset_x",
          "label": "Shadow horizontal offset",
          "min": -24,
          "max": 24,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "card_shadow_offset_y",
          "label": "Shadow vertical offset",
          "min": 0,
          "max": 32,
          "step": 2,
          "unit": "px",
          "default": 4
        },
        {
          "type": "range",
          "id": "card_shadow_blur",
          "label": "Shadow blur",
          "min": 0,
          "max": 48,
          "step": 2,
          "unit": "px",
          "default": 24
        },
        {
          "type": "color",
          "id": "card_shadow_color",
          "label": "Shadow color",
          "default": "#0A1D3C"
        },
        {
          "type": "range",
          "id": "card_shadow_opacity",
          "label": "Shadow opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 10
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text (SEO)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (shown on image)",
          "default": "Resource Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description (optional, below image)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Download Your Guide"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "yellow", "label": "Yellow" },
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "yellow"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Resources Cards",
    "blocks": [
      { "type": "resource" },
      { "type": "resource" }
    ]
  }]
}
{% endschema %}
