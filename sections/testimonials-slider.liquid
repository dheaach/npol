{% render 'section-font-vars', section: section %}

{%- liquid
  assign overlap_desktop = section.settings.overlap_margin | default: 100
  assign overlap_mobile = section.settings.overlap_margin_mobile | default: 60
  if overlap_mobile == blank
    assign overlap_mobile = overlap_desktop
  endif
  assign card_gap = section.settings.column_gap | default: 0
  if card_gap == 0
    assign card_gap = section.settings.card_gap | default: 24
  endif
  assign card_gap_mobile = section.settings.column_gap_mobile | default: 0
  if card_gap_mobile == 0
    assign card_gap_mobile = section.settings.column_gap_tablet | default: 0
  endif
  if card_gap_mobile == 0
    assign card_gap_mobile = section.settings.card_gap_mobile | default: 0
  endif
  if card_gap_mobile == 0
    assign card_gap_mobile = card_gap
  endif
-%}

<section
  class="testimonials section-spacing{% if overlap_desktop > 0 %} testimonials--overlap{% endif %}"
  aria-labelledby="testimonials-heading-{{ section.id }}"
>
  <div class="testimonials__inner">
    {%- if section.settings.heading != blank -%}
      <div class="testimonials__header text-center">
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}
      </div>
    {%- endif -%}
  </div>

  <div
    class="testimonials__slider testimonials__slider--bleed"
    data-testimonials-slider
    style="
      --testimonials-card-gap: {{ card_gap }}px;
      --testimonials-card-gap-mobile: {{ card_gap_mobile }}px;
      --testimonials-overlap: {{ overlap_desktop }}px;
      --testimonials-overlap-mobile: {{ overlap_mobile }}px;
    "
  >
    <div class="testimonials__track" data-testimonials-track>
      {%- for block in section.blocks -%}
        <blockquote class="testimonial-card" {{ block.shopify_attributes }} data-testimonial-slide>
            <img
              class="testimonial-card__quote-mark testimonial-card__quote-mark--open"
              src="{{ 'quote-icon-open.png' | asset_url }}"
              alt=""
              width="46"
              height="40"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            >
            <img
              class="testimonial-card__quote-mark testimonial-card__quote-mark--close"
              src="{{ 'quote-icon-close.png' | asset_url }}"
              alt=""
              width="46"
              height="40"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            >
            <div class="testimonial-card__inner">
            {%- if block.settings.quote != blank -%}
              <div class="testimonial-card__quote section-text rte">{{ block.settings.quote }}</div>
            {%- endif -%}
            <footer class="testimonial-card__author">
              {%- if block.settings.author_image != blank -%}
                <div class="testimonial-card__avatar">
                  {% render 'responsive-image', image: block.settings.author_image, alt: block.settings.author_name, width: 48 %}
                </div>
              {%- endif -%}
              <cite>
                {%- if block.settings.author_name != blank -%}
                  <span>{{ block.settings.author_name }}</span>
                {%- endif -%}
                {%- if block.settings.author_role != blank -%}
                  <span>{{ block.settings.author_role }}</span>
                {%- endif -%}
              </cite>
            </footer>
            </div>
          </blockquote>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="testimonials__controls">
        <button class="testimonials__arrow testimonials__arrow--prev" data-testimonials-prev aria-label="Previous testimonial" type="button">
          <svg class="testimonials__arrow-icon" width="17" height="22" viewBox="0 0 17 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M15.5 1L1.5 11L15.5 21V1Z" fill="currentColor"/>
          </svg>
        </button>
        <div class="testimonials__dots" data-testimonials-dots role="tablist" aria-label="Testimonial navigation"></div>
        <button class="testimonials__arrow testimonials__arrow--next" data-testimonials-next aria-label="Next testimonial" type="button">
          <svg class="testimonials__arrow-icon" width="17" height="22" viewBox="0 0 17 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1.5 1L15.5 11L1.5 21V1Z" fill="currentColor"/>
        </svg>
        </button>
      </div>
    {%- endif -%}
  </div>

  <div class="testimonials__inner">
    {%- if section.settings.button_label != blank -%}
      <div class="testimonials__cta text-center">
        {% render 'button',
          label: section.settings.button_label,
          url: section.settings.button_url,
          style: 'yellow',
          class: 'testimonials__cta-btn'
        %}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.testimonials', pad_x: '.testimonials__inner', pad_x_fallback: true %}
  #shopify-section-{{ section.id }} {
    overflow-x: clip;
    overflow-y: visible;
    position: relative;
    z-index: 2;
    max-width: 100%;
  }
  #shopify-section-{{ section.id }} .testimonials {
    max-width: 100%;
    overflow-x: clip;
  }
  #shopify-section-{{ section.id }} .testimonials__inner {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--section-padding-x, 40px);
    padding-right: var(--section-padding-x, 40px);
  }
  #shopify-section-{{ section.id }} .testimonials__slider--bleed {
    width: 100%;
    max-width: 100%;
    margin-left: 0;
    margin-right: 0;
    padding-left: 0;
    padding-right: 0;
    overflow-x: clip;
    overflow-y: visible;
    {%- if overlap_desktop > 0 -%}
    margin-top: -{{ overlap_desktop }}px;
    padding-top: {{ overlap_desktop }}px;
    {%- else -%}
    margin-top: 40px;
    padding-top: 0;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .testimonials__track {
    gap: var(--testimonials-card-gap, 0);
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .testimonials__slider--bleed {
      {%- if overlap_mobile > 0 -%}
      margin-top: -{{ overlap_mobile }}px;
      padding-top: {{ overlap_mobile }}px;
      {%- else -%}
      margin-top: 32px;
      padding-top: 0;
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .testimonials__track {
      gap: var(--testimonials-card-gap-mobile, var(--testimonials-card-gap, 0));
    }
  }
</style>

