{% render 'section-font-vars', section: section %}

{%- liquid
  assign text_align = section.settings.text_alignment | default: 'left'
  assign content_align = section.settings.content_alignment | default: 'left'
  assign content_gap = section.settings.content_gap | default: 24
  assign content_max_width = section.settings.content_max_width | default: 0
-%}

<section
  class="text-content section-spacing"
  aria-labelledby="text-content-heading-{{ section.id }}"
>
  <div class="page-width">
    <div
      class="text-content__inner text-{{ text_align }} text-content__inner--align-{{ content_align }}"
      style="--text-content-gap: {{ content_gap }}px;{% if content_max_width > 0 %} max-width: {{ content_max_width }}px;{% endif %}"
    >
      <div id="text-content-heading-{{ section.id }}">
        {%- liquid
          assign tc_heading_font_color = section.settings.heading_font_color
          if tc_heading_font_color == blank
            assign tc_heading_font_color = section.settings.heading_color
          endif
        -%}
        {% render 'highlighted-heading',
          heading: section.settings.heading,
          heading_font_size: section.settings.heading_font_size,
          heading_weight: section.settings.heading_weight,
          heading_font_color: tc_heading_font_color,
          heading_tag: section.settings.heading_tag,
          heading_size: section.settings.heading_tag
        %}
      </div>

      {%- if section.settings.text != blank -%}
        <div class="section-text rte text-content__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="text-content__actions">
          {% render 'button',
            label: section.settings.button_label,
            url: section.settings.button_url,
            style: section.settings.button_style
          %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.text-content', pad_x: '.page-width' %}
  {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' -%}
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .text-content__inner {
    display: flex;
    flex-direction: column;
    gap: var(--text-content-gap, 24px);
    width: 100%;
  }
  {%- if content_align == 'center' -%}
    #shopify-section-{{ section.id }} .text-content__inner--align-center {
      margin-left: auto;
      margin-right: auto;
    }
  {%- elsif content_align == 'right' -%}
    #shopify-section-{{ section.id }} .text-content__inner--align-right {
      margin-left: auto;
      margin-right: 0;
    }
  {%- endif -%}
  {%- if section.settings.heading_font_color != blank -%}
    #shopify-section-{{ section.id }} #text-content-heading-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_font_color }};
    }
  {%- elsif section.settings.heading_color != blank -%}
    #shopify-section-{{ section.id }} #text-content-heading-{{ section.id }} .section-heading {
      color: {{ section.settings.heading_color }};
    }
  {%- endif -%}
  {%- if section.settings.heading_font_size > 0 -%}
    #shopify-section-{{ section.id }} #text-content-heading-{{ section.id }} .section-heading {
      font-size: {{ section.settings.heading_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.heading_weight != blank and section.settings.heading_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} #text-content-heading-{{ section.id }} .section-heading {
      font-weight: {{ section.settings.heading_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_size > 0 -%}
    #shopify-section-{{ section.id }} .text-content__text,
    #shopify-section-{{ section.id }} .text-content__text p {
      font-size: {{ section.settings.text_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.text_font_weight != blank and section.settings.text_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .text-content__text,
    #shopify-section-{{ section.id }} .text-content__text p {
      font-weight: {{ section.settings.text_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.text_font_color != blank -%}
    #shopify-section-{{ section.id }} .text-content__text,
    #shopify-section-{{ section.id }} .text-content__text p,
    #shopify-section-{{ section.id }} .text-content__text a,
    #shopify-section-{{ section.id }} .text-content__text li {
      color: {{ section.settings.text_font_color }} !important;
    }
  {%- endif -%}
  {%- if text_align == 'center' -%}
    #shopify-section-{{ section.id }} .text-content__actions {
      display: flex;
      justify-content: center;
    }
  {%- elsif text_align == 'right' -%}
    #shopify-section-{{ section.id }} .text-content__actions {
      display: flex;
      justify-content: flex-end;
    }
  {%- endif -%}
</style>

