        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (legacy fallback)",
      "default": "#0A1D3C",
      "info": "Used when per-segment heading colors above are empty."
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "select",
      "id": "video_source",
      "label": "Video source",
      "options": [
        { "value": "external", "label": "YouTube or Vimeo" },
        { "value": "hosted", "label": "Uploaded video (Shopify)" }
      ],
      "default": "external"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "Used when Video source is YouTube or Vimeo."
    },
    {
      "type": "video",
      "id": "hosted_video",
      "label": "Uploaded video",
      "info": "MP4 or WebM from Shopify Files. Used when Video source is Uploaded video."
    },
    {
      "type": "checkbox",
      "id": "hosted_video_loop",
      "label": "Loop uploaded video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hosted_video_muted",
      "label": "Mute uploaded video",
      "default": false,
      "info": "Some browsers require mute for autoplay after click."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image / thumbnail"
    },
    {
      "type": "text",
      "id": "cover_alt",
      "label": "Cover alt text (SEO)",
      "info": "Accessibility only; not shown on the page."
    },
    {
      "type": "text",
      "id": "play_label",
      "label": "Play button aria label",
      "default": "Play video",
      "info": "Screen readers only; not shown on the page."
    },
    {
      "type": "range",
      "id": "media_border_radius",
      "label": "Video corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12,
      "info": "Rounds the cover thumbnail and embedded player."
    },
    {
      "type": "range",
      "id": "media_border_radius_mobile",
      "label": "Video corner radius on mobile",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use the desktop value."
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption below video"
    },
    {
      "type": "color",
      "id": "caption_font_color",
      "label": "Caption color",
      "default": "#0A1D3C",
      "info": "Empty = theme body color."
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Font size (caption)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use theme body size."
    },
    {
      "type": "select",
      "id": "caption_font_weight",
      "label": "Font weight (caption)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "background_object_fit",
      "label": "Background object fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" },
        { "value": "none", "label": "None (natural size)" }
      ],
      "default": "cover"
    },
    {
