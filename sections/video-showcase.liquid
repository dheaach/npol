{% render 'section-font-vars', section: section %}

{%- liquid
  assign section_bg_url = blank
  if section.settings.background_image != blank
    assign section_bg_url = section.settings.background_image | image_url: width: 2400
  endif
  assign media_radius = section.settings.media_border_radius | default: 12
  assign media_radius_mobile = section.settings.media_border_radius_mobile | default: 0
-%}

<section
  class="video-showcase section-spacing"
  style="background-color: {{ section.settings.background_color | default: '#ADE8F6' }};"
  aria-labelledby="video-heading-{{ section.id }}"
>
  {%- if section_bg_url != blank -%}
    <div class="video-showcase__bg" aria-hidden="true">
      <img
        class="video-showcase__bg-image"
        src="{{ section_bg_url }}"
        alt=""
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="page-width text-center video-showcase__inner">
    {% render 'highlighted-heading',
      heading: section.settings.heading,
      heading_weight: section.settings.heading_weight,
      heading_font_size: section.settings.heading_font_size,
      heading_before: section.settings.heading_before,
      heading_highlight: section.settings.heading_highlight,
      heading_after: section.settings.heading_after,
      heading_before_weight: section.settings.heading_before_weight,
      heading_before_font_size: section.settings.heading_before_font_size,
      heading_highlight_weight: section.settings.heading_highlight_weight,
      heading_highlight_font_size: section.settings.heading_highlight_font_size,
      heading_after_weight: section.settings.heading_after_weight,
      heading_after_font_size: section.settings.heading_after_font_size,
      heading_tag: section.settings.heading_tag,
      heading_size: section.settings.heading_tag,
      highlight_color: section.settings.highlight_color
    %}

    <div
      class="video-showcase__player"
      style="--video-showcase-media-radius: {{ media_radius }}px;"
    >
      {%- if section.settings.video_url != blank -%}
        <deferred-media class="video-showcase__media" data-video-url="{{ section.settings.video_url | escape }}">
          <button class="video-showcase__poster" type="button" aria-label="{{ section.settings.play_label | default: 'Play video' | escape }}">
            {% render 'responsive-image',
              image: section.settings.cover_image,
              alt: section.settings.cover_alt,
              class: 'video-showcase__cover',
              loading: 'lazy'
            %}
            <span class="video-showcase__play-btn" aria-hidden="true">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="32" fill="#FF0000"/><path d="M26 20l22 12-22 12V20z" fill="#fff"/></svg>
            </span>
          </button>
          <template>
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}"></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}"></iframe>
            {%- endif -%}
          </template>
        </deferred-media>
      {%- else -%}
        <div class="video-showcase__placeholder">
          {% render 'responsive-image',
            image: section.settings.cover_image,
            alt: section.settings.cover_alt,
            class: 'video-showcase__cover'
          %}
          <span class="video-showcase__play-btn" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="32" fill="#FF0000"/><path d="M26 20l22 12-22 12V20z" fill="#fff"/></svg>
          </span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.caption != blank -%}
      <p class="video-showcase__caption section-text">{{ section.settings.caption }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .video-showcase {
    min-height: {{ section.settings.section_min_height | default: 0 }}px;
    {%- if section.settings.padding_top > 0 -%}
      padding-top: {{ section.settings.padding_top }}px;
    {%- endif -%}
    {%- if section.settings.padding_bottom > 0 -%}
      padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- endif -%}
    {%- if section.settings.padding_left > 0 -%}
      padding-left: {{ section.settings.padding_left }}px;
    {%- endif -%}
    {%- if section.settings.padding_right > 0 -%}
      padding-right: {{ section.settings.padding_right }}px;
    {%- endif -%}
  }
  {%- if section_bg_url != blank -%}
    #shopify-section-{{ section.id }} .video-showcase__bg-image {
      object-fit: {{ section.settings.background_object_fit | default: 'cover' }};
      object-position: {{ section.settings.background_position | default: 'center center' }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_size > 0 -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      font-size: {{ section.settings.caption_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.caption_font_weight != blank and section.settings.caption_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      font-weight: {{ section.settings.caption_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_color != blank -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      color: {{ section.settings.caption_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .video-showcase__player {
    border-radius: var(--video-showcase-media-radius, {{ media_radius }}px);
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .video-showcase__media,
  #shopify-section-{{ section.id }} .video-showcase__poster,
  #shopify-section-{{ section.id }} .video-showcase__placeholder,
  #shopify-section-{{ section.id }} .video-showcase__cover,
  #shopify-section-{{ section.id }} .video-showcase__media iframe {
    border-radius: var(--video-showcase-media-radius, {{ media_radius }}px);
  }
  #shopify-section-{{ section.id }} .video-showcase__poster,
  #shopify-section-{{ section.id }} .video-showcase__placeholder {
    overflow: hidden;
  }
  @media screen and (max-width: 767px) {
    {%- if media_radius_mobile > 0 -%}
    #shopify-section-{{ section.id }} .video-showcase__player {
      --video-showcase-media-radius: {{ media_radius_mobile }}px;
    }
    {%- endif -%}
  }
</style>

{% schema %}
{
  "name": "Video Showcase",
  "tag": "section",
  "class": "section-video-showcase",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Single line. Or use split heading fields below."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size (single line heading)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "See How Our "
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Activity Units"
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)",
      "default": " Look in Action"
    },
    {
      "type": "range",
      "id": "heading_after_font_size",
      "label": "Font size (after highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "Paste a YouTube or Vimeo link"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image / thumbnail"
    },
    {
      "type": "text",
      "id": "cover_alt",
      "label": "Cover alt text (SEO)",
      "info": "Accessibility only; not shown on the page."
    },
    {
      "type": "text",
      "id": "play_label",
      "label": "Play button aria label",
      "default": "Play video",
      "info": "Screen readers only; not shown on the page."
    },
    {
      "type": "range",
      "id": "media_border_radius",
      "label": "Video corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12,
      "info": "Rounds the cover thumbnail and embedded player."
    },
    {
      "type": "range",
      "id": "media_border_radius_mobile",
      "label": "Video corner radius on mobile",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use the desktop value."
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption below video"
    },
    {
      "type": "color",
      "id": "caption_font_color",
      "label": "Caption color"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Font size (caption)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use theme body size."
    },
    {
      "type": "select",
      "id": "caption_font_weight",
      "label": "Font weight (caption)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "background_object_fit",
      "label": "Background object fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" },
        { "value": "none", "label": "None (natural size)" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Section minimum height",
      "min": 0,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 0,
      "info": "0 = height follows content. Image fills this area when set above 0."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color (fallback)",
      "default": "#ADE8F6",
      "info": "Shows behind the image and when no background image is set."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default section spacing."
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default section spacing."
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = no extra padding (page-width still applies)."
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = no extra padding (page-width still applies)."
    },
    {
      "type": "header",
      "content": "Typography Override"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_font",
      "label": "Override heading font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_font",
      "label": "Custom heading font",
      "default": "poppins_n4"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_body_font",
      "label": "Override body font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "custom_body_font",
      "label": "Custom body font",
      "default": "montserrat_n4"
    }
  ],
  "presets": [{ "name": "Video Showcase" }]
}
