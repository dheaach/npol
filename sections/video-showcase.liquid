{% render 'section-font-vars', section: section %}

{%- liquid
  assign section_bg_url = blank
  if section.settings.background_image != blank
    assign section_bg_url = section.settings.background_image | image_url: width: 2400
  endif
  assign media_radius = section.settings.media_border_radius | default: 12
  assign media_radius_mobile = section.settings.media_border_radius_mobile | default: 0

  assign video_use_hosted = false
  assign video_use_external = false
  if section.settings.video_source == 'hosted' and section.settings.hosted_video != blank
    assign video_use_hosted = true
  elsif section.settings.video_source == 'external' and section.settings.video_url != blank
    assign video_use_external = true
  elsif section.settings.hosted_video != blank
    assign video_use_hosted = true
  elsif section.settings.video_url != blank
    assign video_use_external = true
  endif

  assign video_poster_image = section.settings.cover_image
  if video_poster_image == blank and section.settings.hosted_video != blank
    assign video_poster_image = section.settings.hosted_video.preview_image
  endif

  assign video_player_title = section.settings.heading | newline_to_br | strip_html | replace: '<br />', ' ' | replace: '<br>', ' ' | strip
  if video_player_title == blank and section.settings.hosted_video != blank
    assign video_player_title = section.settings.hosted_video.alt
  endif
  if video_player_title == blank
    assign video_player_title = 'Video'
  endif
-%}

<section
  class="video-showcase section-spacing"
  style="background-color: {{ section.settings.background_color | default: '#ADE8F6' }};"
  aria-labelledby="video-heading-{{ section.id }}"
>
  {%- if section_bg_url != blank -%}
    <div class="video-showcase__bg" aria-hidden="true">
      <img
        class="video-showcase__bg-image"
        src="{{ section_bg_url }}"
        alt=""
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="page-width text-center video-showcase__inner">
    <div id="video-heading-{{ section.id }}">
      {%- liquid
        assign video_heading_font_color = section.settings.heading_font_color
        if video_heading_font_color == blank
          assign video_heading_font_color = section.settings.heading_color
        endif
        assign video_heading_before_color = section.settings.heading_before_color
        if video_heading_before_color == blank
          assign video_heading_before_color = section.settings.heading_color
        endif
        assign video_heading_after_color = section.settings.heading_after_color
        if video_heading_after_color == blank
          assign video_heading_after_color = section.settings.heading_color
        endif
      -%}
      {% render 'highlighted-heading',
        heading: section.settings.heading,
        heading_weight: section.settings.heading_weight,
        heading_font_size: section.settings.heading_font_size,
        heading_font_color: video_heading_font_color,
        heading_before: section.settings.heading_before,
        heading_before_weight: section.settings.heading_before_weight,
        heading_before_font_size: section.settings.heading_before_font_size,
        heading_before_color: video_heading_before_color,
        heading_highlight: section.settings.heading_highlight,
        heading_highlight_weight: section.settings.heading_highlight_weight,
        heading_highlight_font_size: section.settings.heading_highlight_font_size,
        heading_after: section.settings.heading_after,
        heading_after_weight: section.settings.heading_after_weight,
        heading_after_font_size: section.settings.heading_after_font_size,
        heading_after_color: video_heading_after_color,
        heading_tag: section.settings.heading_tag,
        heading_size: section.settings.heading_tag,
        highlight_color: section.settings.highlight_color
      %}
    </div>

    <div
      class="video-showcase__player"
      style="--video-showcase-media-radius: {{ media_radius }}px;"
    >
      {%- if video_use_hosted or video_use_external -%}
        <deferred-media
          class="video-showcase__media"
          {% if video_use_external %}data-video-url="{{ section.settings.video_url | escape }}"{% endif %}
          {% if video_use_hosted %}data-video-type="hosted"{% endif %}
        >
          <button class="video-showcase__poster" type="button" aria-label="{{ section.settings.play_label | default: 'Play video' | escape }}">
            {% render 'responsive-image',
              image: video_poster_image,
              alt: section.settings.cover_alt,
              class: 'video-showcase__cover',
              loading: 'lazy'
            %}
            <span class="video-showcase__play-btn" aria-hidden="true">
              <svg width="111" height="111" viewBox="0 0 111 111" fill="none"><circle cx="55.5" cy="55.5" r="55.5" fill="#FF0000"/><path d="M47 37L75 55.5L47 74V37Z" fill="#fff"/></svg>
            </span>
          </button>
          <template>
            {%- if video_use_hosted -%}
              {{
                section.settings.hosted_video
                | video_tag:
                  class: 'video-showcase__video',
                  autoplay: true,
                  controls: true,
                  playsinline: true,
                  loop: section.settings.hosted_video_loop,
                  muted: section.settings.hosted_video_muted,
                  preload: 'none',
                  image_size: '1920x'
              }}
            {%- elsif section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ video_player_title | escape }}"></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ video_player_title | escape }}"></iframe>
            {%- endif -%}
          </template>
        </deferred-media>
      {%- else -%}
        <div class="video-showcase__placeholder">
          {% render 'responsive-image',
            image: video_poster_image,
            alt: section.settings.cover_alt,
            class: 'video-showcase__cover'
          %}
          <span class="video-showcase__play-btn" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="32" fill="#FF0000"/><path d="M26 20l22 12-22 12V20z" fill="#fff"/></svg>
          </span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.caption != blank -%}
      <p class="video-showcase__caption section-text">{{ section.settings.caption }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.video-showcase', pad_x: '.page-width' %}
  #shopify-section-{{ section.id }} .video-showcase {
    min-height: {{ section.settings.section_min_height | default: 0 }}px;
  }
  {%- if section_bg_url != blank -%}
    #shopify-section-{{ section.id }} .video-showcase__bg-image {
      object-fit: {{ section.settings.background_object_fit | default: 'cover' }};
      object-position: {{ section.settings.background_position | default: 'center center' }};
    }
  {%- endif -%}
  {%- liquid
    assign video_heading_base_color = section.settings.heading_before_color
    if video_heading_base_color == blank
      assign video_heading_base_color = section.settings.heading_color
    endif
  -%}
  {%- if video_heading_base_color != blank -%}
    #shopify-section-{{ section.id }} #video-heading-{{ section.id }} .section-heading {
      color: {{ video_heading_base_color }};
    }
    #shopify-section-{{ section.id }} #video-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color | default: '#1BCDC4' }};
    }
  {%- elsif section.settings.highlight_color != blank -%}
    #shopify-section-{{ section.id }} #video-heading-{{ section.id }} .section-heading .text-highlight {
      color: {{ section.settings.highlight_color }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_size > 0 -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      font-size: {{ section.settings.caption_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.caption_font_weight != blank and section.settings.caption_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      font-weight: {{ section.settings.caption_font_weight }};
    }
  {%- endif -%}
  {%- if section.settings.caption_font_color != blank -%}
    #shopify-section-{{ section.id }} .video-showcase__caption {
      color: {{ section.settings.caption_font_color }};
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .video-showcase__player {
    border-radius: var(--video-showcase-media-radius, {{ media_radius }}px);
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .video-showcase__media,
  #shopify-section-{{ section.id }} .video-showcase__poster,
  #shopify-section-{{ section.id }} .video-showcase__placeholder,
  #shopify-section-{{ section.id }} .video-showcase__cover,
  #shopify-section-{{ section.id }} .video-showcase__media iframe,
  #shopify-section-{{ section.id }} .video-showcase__media .video-showcase__video {
    border-radius: var(--video-showcase-media-radius, {{ media_radius }}px);
  }
  #shopify-section-{{ section.id }} .video-showcase__video {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    object-fit: cover;
    background: #000;
  }
  #shopify-section-{{ section.id }} .video-showcase__poster,
  #shopify-section-{{ section.id }} .video-showcase__placeholder {
    overflow: hidden;
  }
  @media screen and (max-width: 767px) {
    {%- if media_radius_mobile > 0 -%}
    #shopify-section-{{ section.id }} .video-showcase__player {
      --video-showcase-media-radius: {{ media_radius_mobile }}px;
    }
    {%- endif -%}
  }
</style>

{% schema %}
{
  "name": "Video Showcase",
  "tag": "section",
  "class": "section-video-showcase",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Press Enter for a line break. Or use split heading fields below."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Heading color",
      "info": "Empty = theme heading color. Used when the heading field above is filled."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size (heading)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "See How Our "
    },
    {
      "type": "color",
      "id": "heading_before_color",
      "label": "Color (before highlight)",
      "default": "#0A1D3C",
      "info": "Empty = theme heading color."
    },
    {
      "type": "range",
      "id": "heading_before_font_size",
      "label": "Font size (before highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Activity Units"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#1BCDC4"
    },
    {
      "type": "range",
      "id": "heading_highlight_font_size",
      "label": "Font size (highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)",
      "default": " Look in Action"
    },
    {
      "type": "color",
      "id": "heading_after_color",
      "label": "Color (after highlight)",
      "info": "Empty = same as color before highlight."
    },
    {
      "type": "range",
      "id": "heading_after_font_size",
      "label": "Font size (after highlight)",
      "min": 0,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = use heading scale only."
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
