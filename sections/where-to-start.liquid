{% render 'section-font-vars', section: section %}

{%- liquid
  assign grid_gap = section.settings.column_gap | default: 0
  assign grid_gap_tablet = section.settings.column_gap_tablet | default: 0
  if grid_gap_tablet == 0
    assign grid_gap_tablet = grid_gap
  endif
  assign grid_gap_mobile = section.settings.column_gap_mobile | default: 0
  if grid_gap_mobile == 0
    assign grid_gap_mobile = grid_gap_tablet
  endif
  assign cols_desktop = section.settings.cards_per_row | default: 2
  assign cols_tablet = section.settings.cards_per_row_tablet | default: 2
  assign cols_mobile = section.settings.cards_per_row_mobile | default: 1
  assign hub_size = section.settings.center_hub_size | default: 48
  assign hub_size_tablet = section.settings.center_hub_size_tablet | default: 0
  if hub_size_tablet == 0
    assign hub_size_tablet = hub_size
  endif
  assign hub_offset_x = section.settings.center_hub_offset_x | default: 0
  assign hub_offset_y = section.settings.center_hub_offset_y | default: 0
  assign hub_offset_x_tablet = section.settings.center_hub_offset_x_tablet | default: 0
  assign hub_offset_y_tablet = section.settings.center_hub_offset_y_tablet | default: 0
  assign show_hub_desktop = section.settings.show_center_hub
  if section.settings.show_center_hub_tablet == true
    assign show_hub_tablet = true
  elsif section.settings.show_center_hub_tablet == false
    assign show_hub_tablet = false
  else
    assign show_hub_tablet = show_hub_desktop
  endif
  assign hub_visible_desktop = false
  if show_hub_desktop and section.blocks.size >= 4 and grid_gap > 0
    assign hub_visible_desktop = true
  endif
  assign hub_visible_tablet = false
  if show_hub_tablet and section.blocks.size >= 4 and grid_gap_tablet > 0
    assign hub_visible_tablet = true
  endif
  assign card_text_color = section.settings.card_text_color | default: '#FFFFFF'
  assign content_max = section.settings.content_max_width | default: 1200
  assign grid_margin_top = section.settings.cards_margin_top | default: 48
  assign section_bg = section.settings.background_color | default: '#F0F1F3'
-%}

<section
  class="where-to-start section-spacing"
  aria-labelledby="where-to-start-heading-{{ section.id }}"
>
  <div class="page-width">
    <div class="where-to-start__inner" style="max-width: {{ content_max }}px;">
      <header class="where-to-start__header text-center">
        <div id="where-to-start-heading-{{ section.id }}">
          {% render 'highlighted-heading',
            heading: section.settings.heading,
            heading_weight: section.settings.heading_weight,
            heading_before: section.settings.heading_before,
            heading_highlight: section.settings.heading_highlight,
            heading_after: section.settings.heading_after,
            heading_before_weight: section.settings.heading_before_weight,
            heading_highlight_weight: section.settings.heading_highlight_weight,
            heading_after_weight: section.settings.heading_after_weight,
            heading_tag: section.settings.heading_tag,
            heading_size: section.settings.heading_tag,
            highlight_color: section.settings.highlight_color
          %}
        </div>
        {%- if section.settings.caption != blank -%}
          <p class="where-to-start__caption section-text">{{ section.settings.caption }}</p>
        {%- endif -%}
      </header>

      {%- if section.blocks.size > 0 -%}
        <div
          class="where-to-start__grid-wrap"
          style="margin-top: {{ grid_margin_top }}px;"
        >
          <div
            class="where-to-start__grid"
            style="
              --where-to-start-columns: {{ cols_desktop }};
              --where-to-start-columns-tablet: {{ cols_tablet }};
              --where-to-start-columns-mobile: {{ cols_mobile }};
              --where-to-start-gap: {{ grid_gap }}px;
              --where-to-start-gap-tablet: {{ grid_gap_tablet }}px;
              --where-to-start-gap-mobile: {{ grid_gap_mobile }}px;
              --where-to-start-hub: {{ hub_size }}px;
              --where-to-start-hub-tablet: {{ hub_size_tablet }}px;
              --where-to-start-hub-offset-x: {{ hub_offset_x }}px;
              --where-to-start-hub-offset-y: {{ hub_offset_y }}px;
              --where-to-start-hub-offset-x-tablet: {{ hub_offset_x_tablet }}px;
              --where-to-start-hub-offset-y-tablet: {{ hub_offset_y_tablet }}px;
            "
          >
            {%- if hub_visible_desktop or hub_visible_tablet -%}
              <span class="where-to-start__hub" aria-hidden="true"></span>
            {%- endif -%}

            {%- for block in section.blocks -%}
              <article
                id="where-to-start-card-{{ block.id }}"
                class="where-to-start__card"
                style="background-color: {{ block.settings.card_background_color | default: '#51ADA0' }};"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.title != blank -%}
                  <h3 class="where-to-start__card-title section-heading section-heading--h3">{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <div class="where-to-start__card-text section-text rte">{{ block.settings.text }}</div>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <div class="where-to-start__card-cta">
                    {% render 'button',
                      label: block.settings.button_label,
                      url: block.settings.button_url,
                      style: block.settings.button_style | default: 'yellow'
                    %}
                  </div>
                {%- endif -%}
              </article>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  {% render 'section-spacing-styles', root: '.where-to-start', pad_x: '.page-width' %}

  #shopify-section-{{ section.id }} {
    background-color: {{ section_bg }};
  }
  #shopify-section-{{ section.id }} .where-to-start__inner {
    margin-inline: auto;
  }
  #shopify-section-{{ section.id }} #where-to-start-heading-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color | default: '#0A1D3C' }};
  }
  #shopify-section-{{ section.id }} .text-highlight {
    color: {{ section.settings.highlight_color | default: '#51ADA0' }} !important;
  }
  #shopify-section-{{ section.id }} .where-to-start__caption {
    margin: 16px auto 0;
    max-width: {{ section.settings.caption_max_width | default: 720 }}px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: {{ section.settings.caption_font_color | default: '#0A1D3C' }};
  }
  {%- if section.settings.caption_font_size > 0 -%}
    #shopify-section-{{ section.id }} .where-to-start__caption {
      font-size: {{ section.settings.caption_font_size }}px;
    }
  {%- endif -%}
  {%- if section.settings.caption_font_weight != blank and section.settings.caption_font_weight != 'inherit' -%}
    #shopify-section-{{ section.id }} .where-to-start__caption {
      font-weight: {{ section.settings.caption_font_weight }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .where-to-start__grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--where-to-start-columns-mobile, 1), minmax(0, 1fr));
    gap: var(--where-to-start-gap-mobile, 0px);
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .where-to-start__grid {
      grid-template-columns: repeat(var(--where-to-start-columns-tablet, 2), minmax(0, 1fr));
      gap: var(--where-to-start-gap-tablet, 0px);
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .where-to-start__grid {
      grid-template-columns: repeat(var(--where-to-start-columns, 2), minmax(0, 1fr));
      gap: var(--where-to-start-gap, 0px);
    }
  }
  #shopify-section-{{ section.id }} .where-to-start__hub {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2;
    border-radius: 50%;
    background-color: {{ section_bg }};
    pointer-events: none;
  }
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .where-to-start__hub {
      width: var(--where-to-start-hub-tablet, 48px);
      height: var(--where-to-start-hub-tablet, 48px);
      transform: translate(
        calc(-50% + var(--where-to-start-hub-offset-x-tablet, 0px)),
        calc(-50% + var(--where-to-start-hub-offset-y-tablet, 0px))
      );
      {%- unless hub_visible_tablet -%}
      display: none;
      {%- endunless -%}
    }
  }
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .where-to-start__hub {
      width: var(--where-to-start-hub, 48px);
      height: var(--where-to-start-hub, 48px);
      transform: translate(
        calc(-50% + var(--where-to-start-hub-offset-x, 0px)),
        calc(-50% + var(--where-to-start-hub-offset-y, 0px))
      );
      {%- unless hub_visible_desktop -%}
      display: none;
      {%- endunless -%}
    }
  }
  #shopify-section-{{ section.id }} .where-to-start__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-height: {{ section.settings.card_min_height | default: 320 }}px;
    padding: {{ section.settings.card_padding_y | default: 40 }}px {{ section.settings.card_padding_x | default: 36 }}px;
    color: {{ card_text_color }};
    text-align: left;
  }
  #shopify-section-{{ section.id }} .where-to-start__card-title {
    margin: 0 0 16px;
    color: inherit;
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .where-to-start__card-text,
  #shopify-section-{{ section.id }} .where-to-start__card-text p {
    margin: 0;
    color: inherit;
    flex: 1;
  }
  #shopify-section-{{ section.id }} .where-to-start__card-cta {
    margin-top: {{ section.settings.card_button_spacing | default: 24 }}px;
  }

  {%- for block in section.blocks -%}
    {%- if block.settings.title_font_size > 0 -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-title {
        font-size: {{ block.settings.title_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.title_font_weight != blank and block.settings.title_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-title {
        font-weight: {{ block.settings.title_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.title_font_color != blank -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-title {
        color: {{ block.settings.title_font_color }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_size > 0 -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text,
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text p {
        font-size: {{ block.settings.text_font_size }}px;
      }
    {%- endif -%}
    {%- if block.settings.text_font_weight != blank and block.settings.text_font_weight != 'inherit' -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text,
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text p {
        font-weight: {{ block.settings.text_font_weight }};
      }
    {%- endif -%}
    {%- if block.settings.text_font_color != blank -%}
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text,
      #shopify-section-{{ section.id }} #where-to-start-card-{{ block.id }} .where-to-start__card-text p {
        color: {{ block.settings.text_font_color }};
      }
    {%- endif -%}
  {%- endfor -%}

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .where-to-start__hub {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Where to Start",
  "tag": "section",
  "class": "section-where-to-start",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (single line)",
      "info": "Or use split heading fields below"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before highlight)",
      "default": "Not Sure Where to "
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "Start?"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight (single line heading)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_before_weight",
      "label": "Font weight (before highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_highlight_weight",
      "label": "Font weight (highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_after_weight",
      "label": "Font weight (after highlight)",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-bold (800)" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0A1D3C"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#51ADA0"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Where Is Your Team Right Now?"
    },
    {
      "type": "color",
      "id": "caption_font_color",
      "label": "Caption color",
      "default": "#0A1D3C"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = theme body size."
    },
    {
      "type": "select",
      "id": "caption_font_weight",
      "label": "Caption font weight",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "caption_max_width",
      "label": "Caption max width",
      "min": 0,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 720,
      "info": "0 = no limit."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#F0F1F3",
      "info": "Applies to the outer section only, not inner cards."
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards per row (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "label": "Cards per row (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "show_center_hub",
      "label": "Show center circle (desktop)",
      "default": true,
      "info": "Circle where four cards meet. Requires gap > 0 and 4 cards on desktop (1024px+)."
    },
    {
      "type": "range",
      "id": "center_hub_size",
      "label": "Center circle size (desktop)",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "center_hub_offset_x",
      "label": "Center circle offset — left / right (desktop)",
      "min": -80,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "Negative = left. Positive = right."
    },
    {
      "type": "range",
      "id": "center_hub_offset_y",
      "label": "Center circle offset — up / down (desktop)",
      "min": -80,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "Negative = up. Positive = down."
    },
    {
      "type": "checkbox",
      "id": "show_center_hub_tablet",
      "label": "Show center circle (tablet)",
      "default": true,
      "info": "Circle where four cards meet. Requires gap > 0 and 4 cards on tablet (768px–1023px)."
    },
    {
      "type": "range",
      "id": "center_hub_size_tablet",
      "label": "Center circle size (tablet)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = desktop size."
    },
    {
      "type": "range",
      "id": "center_hub_offset_x_tablet",
      "label": "Center circle offset — left / right (tablet)",
      "min": -80,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "Negative = left. Positive = right."
    },
    {
      "type": "range",
      "id": "center_hub_offset_y_tablet",
      "label": "Center circle offset — up / down (tablet)",
      "min": -80,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "Negative = up. Positive = down."
    },
    {
      "type": "range",
      "id": "cards_margin_top",
      "label": "Space above cards",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height",
      "min": 200,
      "max": 560,
      "step": 20,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "label": "Card padding vertical",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "label": "Card padding horizontal",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "card_button_spacing",
      "label": "Space above card button",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Column spacing"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between cards (desktop)",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16,
      "info": "0 = no gap. Center circle needs gap > 0."
    },
    {
      "type": "range",
      "id": "column_gap_tablet",
      "label": "Gap between cards (tablet)",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = use desktop value."
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "Gap between cards (mobile)",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 0,
      "info": "0 = use tablet or desktop value."
    },
    {
      "type": "header",
      "content": "Section padding \u2014 Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "px",
      "default": 0,
      "info": "0 = theme default section spacing."
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 500,
      "step": 5,
