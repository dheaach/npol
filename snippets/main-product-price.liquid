{%- comment -%}
  Product price for main-product section. Pass variant: current_variant.
{%- endcomment -%}
{%- liquid
  assign price_variant = variant | default: product.selected_or_first_available_variant
  assign compare_at = price_variant.compare_at_price
  assign price = price_variant.price
-%}

<p
  class="main-product__price"
  style="font-family: var(--font-heading); font-size: var(--font-size-h3); font-weight: 700; margin: 16px 0;"
  data-product-price
>
  <span data-product-price-regular>{{ price | money }}</span>
  {%- if compare_at > price -%}
    <s data-product-price-compare style="opacity: 0.5; font-size: var(--font-size-body); margin-left: 8px;">
      {{ compare_at | money }}
    </s>
  {%- else -%}
    <s data-product-price-compare style="opacity: 0.5; font-size: var(--font-size-body); margin-left: 8px; display: none;"></s>
  {%- endif -%}
</p>
