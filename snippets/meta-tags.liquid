{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: settings.seo_default_description | default: shop.description
  assign og_url = canonical_url | default: shop.url
  assign og_type = 'website'

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  endif

  if settings.seo_default_og_image != blank
    assign og_image = settings.seo_default_og_image | image_url: width: 1200
  endif

  if page_image
    assign og_image = page_image | image_url: width: 1200
  endif
-%}

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="{{ settings.color_primary }}">

{%- if settings.seo_default_description != blank and page_description == blank -%}
  <meta name="description" content="{{ settings.seo_default_description | escape }}">
{%- endif -%}

<link rel="canonical" href="{{ canonical_url }}">

{%- if settings.favicon != blank -%}
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
{%- if og_description != blank -%}
  <meta property="og:description" content="{{ og_description | escape }}">
{%- endif -%}
{%- if og_image -%}
  <meta property="og:image" content="https:{{ og_image }}">
  <meta property="og:image:secure_url" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
{%- if og_description != blank -%}
  <meta name="twitter:description" content="{{ og_description | escape }}">
{%- endif -%}
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}
