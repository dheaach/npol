{%- comment -%}
  Responsive image snippet with SEO-friendly alt text and lazy loading.
  Usage: {% render 'responsive-image', image: section.settings.image, alt: section.settings.image_alt, class: 'hero-banner__image', loading: 'eager' %}
{%- endcomment -%}

{%- if image != blank -%}
  {%- liquid
    assign img_alt = alt | default: image.alt | default: shop.name
    assign img_loading = loading | default: 'lazy'
    assign img_class = class | default: 'responsive-image'
    assign img_width = width | default: 1200
  -%}

  <img
    src="{{ image | image_url: width: img_width }}"
    srcset="
      {{ image | image_url: width: 400 }} 400w,
      {{ image | image_url: width: 600 }} 600w,
      {{ image | image_url: width: 800 }} 800w,
      {{ image | image_url: width: 1000 }} 1000w,
      {{ image | image_url: width: 1200 }} 1200w,
      {{ image | image_url: width: 1600 }} 1600w
    "
    sizes="(max-width: 767px) 100vw, (max-width: 1023px) 80vw, {{ img_width }}px"
    alt="{{ img_alt | escape }}"
    class="{{ img_class }}"
    loading="{{ img_loading }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    {% if fetchpriority %}fetchpriority="{{ fetchpriority }}"{% endif %}
  >
{%- else -%}
  <div class="{{ class | default: 'responsive-image' }} responsive-image--placeholder" role="img" aria-label="{{ alt | default: 'Placeholder image' | escape }}">
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
  </div>
{%- endif -%}
