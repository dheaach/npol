{%- comment -%}
  Per-section two-column grid widths (fr units) with responsive column gap.
  Usage: {% render 'section-column-widths', section: section, grid_class: 'hero-math__inner' %}
  Expects section.settings.column_1_width (0–100, default 50).
{%- endcomment -%}

{%- liquid
  assign col1 = section.settings.column_1_width | default: 50
  assign col2_setting = section.settings.column_2_width | default: 0
  if col2_setting > 0
    assign col2 = col2_setting
  else
    assign col2 = 100 | minus: col1
  endif
-%}

<style>
  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .{{ grid_class }} {
      {%- if col1 >= 100 or col2 <= 0 -%}
      grid-template-columns: 1fr;
      {%- elsif col1 <= 0 -%}
      grid-template-columns: minmax(0, 1fr);
      {%- else -%}
      grid-template-columns: minmax(0, {{ col1 }}fr) minmax(0, {{ col2 }}fr);
      {%- endif -%}
    }
  }

  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .{{ grid_class }} {
      grid-template-columns: 1fr;
    }
  }

  {%- assign gap_selector = grid_class | prepend: '.' -%}
  {% render 'section-spacing-gap',
    section: section,
    selector: gap_selector,
    stack_breakpoint: '1023',
    gap_fallback_tablet: gap_fallback_tablet,
    gap_fallback_mobile: gap_fallback_mobile
  %}
</style>
