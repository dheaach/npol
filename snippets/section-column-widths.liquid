{%- comment -%}
  Per-section two-column grid widths (fr units).
  Usage: {% render 'section-column-widths', section: section, grid_class: 'hero-math__inner' %}
  Expects section.settings.column_1_width (25–75, default 50).
{%- endcomment -%}

{%- liquid
  assign col1 = section.settings.column_1_width | default: 50
  assign col2_setting = section.settings.column_2_width | default: 0
  if col2_setting > 0
    assign col2 = col2_setting
  else
    assign col2 = 100 | minus: col1
  endif
  assign column_gap = section.settings.column_gap | default: 48
-%}

<style>
  #shopify-section-{{ section.id }} .{{ grid_class }} {
    grid-template-columns: minmax(0, {{ col1 }}fr) minmax(0, {{ col2 }}fr);
    gap: {{ column_gap }}px;
  }

  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .{{ grid_class }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
